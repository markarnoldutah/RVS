@page "/intake"
@rendermode InteractiveWebAssembly

<PageTitle>Service Request Intake</PageTitle>

<FluentStack Orientation="Orientation.Vertical" VerticalGap="20" HorizontalAlignment="HorizontalAlignment.Center"
             Style="max-width: 600px; margin: 0 auto; padding: 16px;">
    <FluentIcon Value="@(new Icons.Regular.Size48.ClipboardTextEdit())" Color="Color.Accent" />

    <FluentLabel Typo="Typography.H3" Alignment="HorizontalAlignment.Center">
        Service Request Intake
    </FluentLabel>

    <FluentLabel Typo="Typography.Body" Alignment="HorizontalAlignment.Center">
        To start a service request, please use the location-specific link provided by your dealer
        (e.g., from a QR code or email).
    </FluentLabel>

    <FluentLabel Typo="Typography.Body" Alignment="HorizontalAlignment.Center">
        The link format is: <code>/intake/your-location-slug</code>
    </FluentLabel>
</FluentStack>
