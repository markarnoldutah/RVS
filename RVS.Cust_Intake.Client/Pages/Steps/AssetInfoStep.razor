@using RVS.Cust_Intake.Client.State
@using RVS.UI.Shared.Validation

<FluentCard Style="width: 100%; padding: 24px;">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
        <FluentLabel Typo="Typography.H4">
            <FluentIcon Value="@(new Icons.Regular.Size20.VehicleTruckProfile())" Style="margin-right: 8px;" />
            Vehicle Information
        </FluentLabel>

        <FluentTextField @bind-Value="State.Vin"
                         Label="VIN (Vehicle Identification Number)"
                         Required="true"
                         Placeholder="17-character VIN"
                         MaxLength="17"
                         Style="width: 100%;" />

        @if (!string.IsNullOrWhiteSpace(State.Vin))
        {
            var vinResult = ClientVinValidator.Validate(State.Vin);
            if (vinResult.IsValid)
            {
                <FluentMessageBar Intent="MessageIntent.Success">
                    VIN format is valid.
                </FluentMessageBar>
            }
            else if (State.Vin.Length == 17)
            {
                <FluentMessageBar Intent="MessageIntent.Warning">
                    @vinResult.ErrorMessage
                </FluentMessageBar>
            }
        }

        <FluentTextField @bind-Value="State.Manufacturer"
                         Label="Manufacturer (optional)"
                         Placeholder="e.g., Winnebago, Thor, Jayco"
                         Style="width: 100%;" />

        <FluentTextField @bind-Value="State.Model"
                         Label="Model (optional)"
                         Placeholder="e.g., Vista, Aria, Eagle"
                         Style="width: 100%;" />

        <FluentNumberField @bind-Value="State.Year"
                           Label="Year (optional)"
                           Placeholder="e.g., 2023"
                           Min="@("1900")"
                           Max="@((DateTime.UtcNow.Year + 2).ToString())"
                           Style="width: 100%;" />

        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8"
                     HorizontalAlignment="HorizontalAlignment.Right" Style="width: 100%; margin-top: 8px;">
            <FluentButton Appearance="Appearance.Neutral" OnClick="HandleBack"
                          IconStart="@(new Icons.Regular.Size16.ArrowLeft())">
                Back
            </FluentButton>
            <FluentButton Appearance="Appearance.Accent" OnClick="HandleNext"
                          IconEnd="@(new Icons.Regular.Size16.ArrowRight())">
                Next
            </FluentButton>
        </FluentStack>
    </FluentStack>
</FluentCard>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnNext { get; set; }
    [Parameter, EditorRequired] public EventCallback OnBack { get; set; }

    private async Task HandleNext()
    {
        await State.NotifyAndPersistAsync();
        await OnNext.InvokeAsync();
    }

    private async Task HandleBack()
    {
        await OnBack.InvokeAsync();
    }
}
