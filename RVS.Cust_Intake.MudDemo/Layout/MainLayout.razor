@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.RvHookup"
                       Color="Color.Inherit"
                       Href="/"
                       aria-label="Back to the homepage" />
        <MudText Typo="Typo.h6" Class="ml-2">
            RV Service Flow
        </MudText>
        <MudSpacer />
        <MudChip T="string" Color="Color.Secondary" Size="Size.Small" Variant="Variant.Filled">
            MudBlazor Demo
        </MudChip>
    </MudAppBar>

    <MudMainContent Class="pa-4" Style="min-height: calc(100vh - 64px - 48px);">
        <MudContainer MaxWidth="MaxWidth.Medium">
            <ErrorBoundary>
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <MudAlert Severity="Severity.Error" Class="my-4">@ex.Message</MudAlert>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>

    <MudAppBar Bottom="true" Elevation="0" Color="Color.Transparent" Dense="true"
               Style="background: var(--mud-palette-background-gray);">
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            &copy; @DateTime.UtcNow.Year RV Service Flow
        </MudText>
        <MudSpacer />
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            Powered by MudBlazor
        </MudText>
    </MudAppBar>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1565C0",
            Secondary = "#00897B",
            AppbarBackground = "#1565C0",
            AppbarText = "#FFFFFF",
            Background = "#FAFAFA",
            Surface = "#FFFFFF",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Roboto", "Helvetica", "Arial", "sans-serif"]
            }
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "8px"
        }
    };
}
