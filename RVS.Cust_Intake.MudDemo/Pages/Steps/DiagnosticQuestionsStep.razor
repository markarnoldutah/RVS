<MudPaper Elevation="3" Class="pa-6">
    <MudStack Spacing="4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Psychology" Color="Color.Primary" />
            <MudText Typo="Typo.h5">AI Diagnostic Questions</MudText>
        </MudStack>

        @if (!_loaded)
        {
            <MudStack Spacing="3">
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="80%" />
                @for (var i = 0; i < 3; i++)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="100px" />
                }
            </MudStack>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(State.SmartSuggestion))
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true"
                          Icon="@Icons.Material.Filled.Lightbulb">
                    <strong>Suggestion:</strong> @State.SmartSuggestion
                </MudAlert>
            }

            @for (var i = 0; i < State.DiagnosticQuestions.Count; i++)
            {
                var question = State.DiagnosticQuestions[i];
                var questionIndex = i;
                var response = questionIndex < State.DiagnosticResponses.Count
                    ? State.DiagnosticResponses[questionIndex]
                    : null;

                <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 500;">
                            @question.QuestionText
                        </MudText>

                        @if (question.Options.Count > 0 && response is not null)
                        {
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                                @foreach (var option in question.Options)
                                {
                                    var opt = option;
                                    var isSelected = response.SelectedOptions.Contains(opt);
                                    <MudButton Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                                               Color="@(isSelected ? Color.Primary : Color.Default)"
                                               Size="Size.Small"
                                               OnClick="() => ToggleOption(questionIndex, opt)"
                                               Style="text-transform: none;">
                                        @if (isSelected)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small"
                                                     Class="mr-1" />
                                        }
                                        @opt
                                    </MudButton>
                                }
                            </MudStack>
                        }

                        @if (question.AllowFreeText && response is not null)
                        {
                            <MudTextField @bind-Value="response.FreeTextResponse"
                                          Placeholder="Additional details..."
                                          Lines="2"
                                          Variant="Variant.Outlined" />
                        }
                    </MudStack>
                </MudPaper>
            }
        }

        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="HandleBack"
                       Style="text-transform: none;">
                Back
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="HandleNext"
                       Disabled="!_loaded"
                       Style="text-transform: none;">
                @(_loaded ? "Next" : "Loading...")
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnNext { get; set; }
    [Parameter, EditorRequired] public EventCallback OnBack { get; set; }

    private bool _loaded;

    protected override async Task OnInitializedAsync()
    {
        // Simulate API delay for loading diagnostic questions
        await Task.Delay(800);
        State.LoadMockDiagnosticQuestions();
        _loaded = true;
    }

    private void ToggleOption(int questionIndex, string option)
    {
        if (questionIndex >= State.DiagnosticResponses.Count) return;

        var response = State.DiagnosticResponses[questionIndex];
        if (response.SelectedOptions.Contains(option))
            response.SelectedOptions.Remove(option);
        else
            response.SelectedOptions.Add(option);

        StateHasChanged();
    }

    private async Task HandleNext() => await OnNext.InvokeAsync();
    private async Task HandleBack() => await OnBack.InvokeAsync();
}
