@page "/confirmation"

<PageTitle>Request Submitted</PageTitle>

<MudStack AlignItems="AlignItems.Center" Spacing="5" Class="mt-8">
    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success"
             Style="font-size: 5rem;" />

    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">
        Request Submitted Successfully
    </MudText>

    <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">
        Your service request has been submitted. You will receive a confirmation email shortly.
    </MudText>

    <MudPaper Elevation="2" Class="pa-4" Style="background: var(--mud-palette-background);">
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudText Typo="Typo.caption" Color="Color.Secondary">CONFIRMATION NUMBER</MudText>
            <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-family: monospace;">
                SR-2026-00742
            </MudText>
        </MudStack>
    </MudPaper>

    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2" Style="max-width: 500px;">
        Save your confirmation number to check the status of your request anytime.
    </MudAlert>

    <MudStack Row="true" Spacing="3" Class="mt-4">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Home"
                   Href="/"
                   Style="text-transform: none;">
            Return Home
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Search"
                   Href="/status"
                   Style="text-transform: none;">
            Check Status
        </MudButton>
    </MudStack>
</MudStack>
