<MudPaper Elevation="2" Class="pa-6 rounded-lg wizard-step-card">
    <MudForm @ref="_form">
    <MudStack Spacing="4">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h5" Style="color: var(--mud-palette-text-primary);">RV Details</MudText>
            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">
                Review and edit your RV information below.
            </MudText>
        </MudStack>

        @if (!string.IsNullOrWhiteSpace(State.Vin))
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true"
                      Icon="@Icons.Material.Filled.Pin">
                VIN: @State.Vin
            </MudAlert>
        }

        @if (State.VinLookupSucceeded)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Text" Dense="true">
                Vehicle information retrieved from VIN lookup.
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true">
                No vehicle information was found for this VIN. Please enter details manually below.
            </MudAlert>
        }

        <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
            <MudStack Spacing="1">
                <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Manufacturer</MudText>
                <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">The RV or chassis manufacturer</MudText>
                <MudTextField @bind-Value="State.Manufacturer"
                              T="string"
                              Validation="@(new Func<string?, string?>(ValidateManufacturer))"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Placeholder="e.g., Winnebago, Thor, Jayco" />
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
            <MudStack Spacing="1">
                <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Model</MudText>
                <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">The specific vehicle model name</MudText>
                <MudTextField @bind-Value="State.Model"
                              T="string"
                              Validation="@(new Func<string?, string?>(ValidateModel))"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Placeholder="e.g., Vista, Aria, Eagle" />
            </MudStack>
        </MudPaper>

        <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
            <MudStack Spacing="1">
                <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Year</MudText>
                <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">The model year of the vehicle</MudText>
                <MudTextField @bind-Value="State.Year"
                              T="int?"
                              Validation="@(new Func<int?, string?>(ValidateYear))"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              InputMode="InputMode.numeric"
                              Placeholder="e.g., 2023" />
            </MudStack>
        </MudPaper>

        @if (!HideContinueButton)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       OnClick="HandleNext"
                       Style="text-transform: none;"
                       Class="mt-6">
                Continue
            </MudButton>
        }
    </MudStack>
    </MudForm>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IIntakeWizardState State { get; set; } = default!;
    [Parameter] public EventCallback OnNext { get; set; }

    /// <summary>Hides the per-step Continue button when the host renders multiple steps on one surface.</summary>
    [Parameter] public bool HideContinueButton { get; set; }

    private MudForm _form = default!;
    private bool _submitted;

    private string? ValidateManufacturer(string? value) =>
        _submitted && string.IsNullOrWhiteSpace(value) ? "Manufacturer is required" : null;

    private string? ValidateModel(string? value) =>
        _submitted && string.IsNullOrWhiteSpace(value) ? "Model is required" : null;

    private string? ValidateYear(int? value)
    {
        if (!_submitted) return null;
        if (!value.HasValue) return "Year is required";
        if (value < 1900) return "Year must be 1900 or later";
        if (value > DateTime.UtcNow.Year + 2) return $"Year must not exceed {DateTime.UtcNow.Year + 2}";
        return null;
    }

    private async Task HandleNext()
    {
        _submitted = true;
        await _form.Validate();
        if (!_form.IsValid) return;

        await State.NotifyAndPersistAsync();
        await OnNext.InvokeAsync();
    }
}
