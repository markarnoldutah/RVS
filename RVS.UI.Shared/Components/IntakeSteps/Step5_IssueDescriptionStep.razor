<MudPaper Elevation="2" Class="pa-6 rounded-lg wizard-step-card">
    <MudForm @ref="_form">
        <MudStack Spacing="4">
            <MudStack Spacing="1">
                <MudText Typo="Typo.h5" Style="color: var(--mud-palette-text-primary);">Issue</MudText>
                <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">
                    Describe the problem you're experiencing with your RV.
                </MudText>
            </MudStack>

            <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Description</MudText>
                    <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Tap the mic to describe the issue, or type it below</MudText>

                    @* Microphone capture button *@
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                        <MudButton Variant="Variant.Outlined"
                                   Color="@(_isRecording ? Color.Error : Color.Primary)"
                                   StartIcon="@(_isRecording ? Icons.Material.Filled.Stop : Icons.Material.Filled.Mic)"
                                   OnClick="ToggleRecording"
                                   Disabled="@(_isTranscribing || _isRefining)"
                                   Style="text-transform: none;">
                            @(_isRecording ? "Stop Recording" : "Tap to Speak")
                        </MudButton>
                        @if (_isTranscribing)
                        {
                            <MudProgressCircular Size="Size.Small" Color="Color.Primary" Indeterminate="true" />
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Transcribing...</MudText>
                        }
                        else if (_isRefining)
                        {
                            <MudProgressCircular Size="Size.Small" Color="Color.Primary" Indeterminate="true" />
                            <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Cleaning up transcript...</MudText>
                        }
                    </MudStack>

                    @if (!string.IsNullOrWhiteSpace(_transcriptionError))
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                            @_transcriptionError You can still type your description below.
                        </MudAlert>
                    }

                    <MudTextField @bind-Value="State.IssueDescription"
                                  T="string"
                                  Validation="@(new Func<string?, string?>(ValidateDescription))"
                                  Lines="5"
                                  MaxLength="2000"
                                  Counter="2000"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="Describe the issue in detail..." />
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Issue Category</MudText>
                        @if (State.IsCategorySuggestedByAi)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                Suggested
                            </MudChip>
                        }
                        @if (_isSuggestingCategory)
                        {
                            <MudProgressCircular Size="Size.Small" Color="Color.Info" Indeterminate="true" />
                        }
                    </MudStack>
                    <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Select the area that best describes the issue</MudText>
                    <MudSelect T="string"
                               Value="State.IssueCategory"
                               ValueChanged="OnCategoryChanged"
                               Validation="@(new Func<string?, string?>(ValidateIssueCategory))"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               AnchorOrigin="Origin.BottomCenter"
                               TransformOrigin="Origin.TopCenter"
                               RelativeWidth="DropdownWidth.Adaptive">
                        @foreach (var category in _categories)
                        {
                            <MudSelectItem T="string" Value="@category.Code">@category.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Urgency</MudText>
                        @if (State.IsUrgencySuggestedByAi)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                Suggested
                            </MudChip>
                        }
                        @if (_isSuggestingInsights)
                        {
                            <MudProgressCircular Size="Size.Small" Color="Color.Info" Indeterminate="true" />
                        }
                    </MudStack>
                    <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">How urgent is this service need?</MudText>
                    <MudSelect T="string"
                               Value="State.Urgency"
                               ValueChanged="OnUrgencyChanged"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               AnchorOrigin="Origin.BottomCenter"
                               TransformOrigin="Origin.TopCenter"
                               RelativeWidth="DropdownWidth.Adaptive">
                        <MudSelectItem T="string" Value="@("Low")">Low</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Medium")">Medium</MudSelectItem>
                        <MudSelectItem T="string" Value="@("High")">High</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Critical")">Critical</MudSelectItem>
                    </MudSelect>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">RV Usage</MudText>
                        @if (State.IsRvUsageSuggestedByAi)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                Suggested
                            </MudChip>
                        }
                    </MudStack>
                    <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">How often do you use your RV?</MudText>
                    <MudSelect T="string"
                               Value="State.RvUsage"
                               ValueChanged="OnRvUsageChanged"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               AnchorOrigin="Origin.BottomCenter"
                               TransformOrigin="Origin.TopCenter"
                               RelativeWidth="DropdownWidth.Adaptive">
                        <MudSelectItem T="string" Value="@("Full-Time")">Full-Time</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Part-Time")">Part-Time</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Seasonal")">Seasonal</MudSelectItem>
                        <MudSelectItem T="string" Value="@("Occasional")">Occasional</MudSelectItem>
                    </MudSelect>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Extended Warranty</MudText>
                    <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Do you have an extended warranty on your RV?</MudText>
                    <MudRadioGroup T="string" Value="State.HasExtendedWarranty" ValueChanged="OnExtendedWarrantyChanged"
                                   Validation="@(new Func<string?, string?>(ValidateExtendedWarranty))">
                        <MudRadio T="string" Value="@("Yes")" Color="Color.Primary">Yes</MudRadio>
                        <MudRadio T="string" Value="@("No")" Color="Color.Primary">No</MudRadio>
                        <MudRadio T="string" Value="@("Not Sure")" Color="Color.Primary">Not Sure</MudRadio>
                    </MudRadioGroup>
                </MudStack>
            </MudPaper>

            <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Approx. Purchase Date</MudText>
                    <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">When did you purchase your RV? (MM/YYYY)</MudText>
                    <div id="@PurchaseDateWrapperId">
                        <MudDatePicker Date="_approxPurchaseDate"
                                       DateChanged="HandlePurchaseDateChanged"
                                       Validation="@(new Func<DateTime?, string?>(ValidateApproxPurchaseDate))"
                                       DateFormat="MM/yyyy"
                                       FixDay="1"
                                       OpenTo="OpenTo.Month"
                                       Variant="Variant.Outlined"
                                       ShowToolbar="false"
                                       Margin="Margin.Dense"
                                       Editable="true"
                                       Placeholder="MM/YYYY"
                                       MaxDate="@DateTime.Today"
                                       MinDate="_minPurchaseDate"
                                       AutoClose="true" />
                    </div>
                </MudStack>
            </MudPaper>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       OnClick="HandleNext"
                       Style="text-transform: none;"
                       Class="mt-6">
                Continue
            </MudButton>
        </MudStack>
    </MudForm>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IIntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnNext { get; set; }
    [Inject] private IIntakeAiClient IntakeAi { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private MudForm _form = default!;
    private bool _submitted;
    private List<LookupItemDto> _categories = [];
    private DateTime? _approxPurchaseDate;
    private bool _isRecording;
    private bool _isTranscribing;
    private bool _isRefining;
    private bool _isSuggestingCategory;
    private bool _isSuggestingInsights;
    private string? _transcriptionError;
    private CancellationTokenSource? _suggestCategoryCts;
    private CancellationTokenSource? _suggestInsightsCts;
    private readonly DateTime _minPurchaseDate = new(1960, 1, 1);
    private const string PurchaseDateWrapperId = "approx-purchase-date-wrapper";

    protected override void OnInitialized()
    {
        if (State.Config?.IssueCategories is { Count: > 0 } categories)
        {
            _categories = categories.Where(c => c.IsSelectable).ToList();
        }

        if (!string.IsNullOrWhiteSpace(State.ApproxPurchaseDate) &&
            DateTime.TryParseExact(State.ApproxPurchaseDate, "MM/yyyy",
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out var parsedDate))
        {
            _approxPurchaseDate = parsedDate;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("rvs_attachDatePickerKeyboardGuard", PurchaseDateWrapperId);
            }
            catch
            {
                // Guard is a progressive enhancement; failure is non-fatal.
            }
        }
    }

    private async Task ToggleRecording()
    {
        if (_isRecording)
        {
            _isRecording = false;
            _isTranscribing = true;
            _transcriptionError = null;
            StateHasChanged();

            try
            {
                var recording = await JS.InvokeAsync<AudioRecordingResult?>("rvs_stopRecording");
                if (recording is null || string.IsNullOrWhiteSpace(recording.Audio))
                {
                    _transcriptionError = "No audio was captured.";
                    return;
                }

                var request = new IssueTranscriptionRequestDto
                {
                    AudioBase64 = recording.Audio,
                    ContentType = recording.MimeType
                };

                var result = await IntakeAi.TranscribeIssueAsync(request);
                if (result?.Result is not null)
                {
                    // Start with the Whisper result as a baseline
                    var rawTranscript = result.Result.RawTranscript ?? string.Empty;
                    State.IssueDescription = result.Result.CleanedDescription
                        ?? rawTranscript;

                    // Fire insights extraction from the raw transcript immediately —
                    // the refine prompt strips lifestyle/urgency context we need.
                    _isTranscribing = false;
                    _isRefining = true;
                    StateHasChanged();

                    var insightsTask = RequestInsightsSuggestion(rawTranscript);

                    try
                    {
                        var refinementRequest = new IssueTextRefinementRequestDto
                        {
                            RawTranscript = rawTranscript,
                            IssueCategory = State.IssueCategory
                        };

                        var refined = await IntakeAi.RefineIssueTextAsync(refinementRequest);
                        if (!string.IsNullOrWhiteSpace(refined?.Result?.CleanedDescription))
                        {
                            State.IssueDescription = refined.Result.CleanedDescription;
                        }
                    }
                    catch (Exception)
                    {
                        // Refinement is best-effort; the Whisper result is already set
                    }
                    finally
                    {
                        _isRefining = false;
                    }

                    StateHasChanged();
                    // Category uses the cleaned description; insights already in-flight from raw transcript
                    await Task.WhenAll(insightsTask, RequestCategorySuggestion());
                }
                else
                {
                    _transcriptionError = "Could not transcribe the audio.";
                }
            }
            catch (Exception)
            {
                _transcriptionError = "Transcription failed.";
            }
            finally
            {
                _isTranscribing = false;
                StateHasChanged();
            }
        }
        else
        {
            _transcriptionError = null;
            try
            {
                await JS.InvokeVoidAsync("rvs_startRecording");
                _isRecording = true;
            }
            catch (Exception)
            {
                _transcriptionError = "Microphone access was denied or is unavailable.";
            }
        }
    }

    private async Task RequestCategorySuggestion()
    {
        if (string.IsNullOrWhiteSpace(State.IssueDescription) || State.IssueDescription.Length < 10)
            return;

        _suggestCategoryCts?.Cancel();
        _suggestCategoryCts = new CancellationTokenSource();
        var ct = _suggestCategoryCts.Token;

        _isSuggestingCategory = true;
        StateHasChanged();

        try
        {
            await Task.Delay(500, ct);

            var request = new IssueCategorySuggestionRequestDto
            {
                IssueDescription = State.IssueDescription
            };

            var result = await IntakeAi.SuggestIssueCategoryAsync(request, ct);
            if (result?.Result?.IssueCategory is not null && !ct.IsCancellationRequested)
            {
                State.IssueCategory = result.Result.IssueCategory;
                State.IsCategorySuggestedByAi = true;
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception) { }
        finally
        {
            _isSuggestingCategory = false;
            StateHasChanged();
        }
    }

    private void OnCategoryChanged(string? value)
    {
        State.IssueCategory = value ?? string.Empty;
        State.IsCategorySuggestedByAi = false;
    }

    private void OnUrgencyChanged(string? value)
    {
        State.Urgency = value;
        State.IsUrgencySuggestedByAi = false;
    }

    private void OnRvUsageChanged(string? value)
    {
        State.RvUsage = value;
        State.IsRvUsageSuggestedByAi = false;
    }

    private void OnExtendedWarrantyChanged(string? value)
    {
        State.HasExtendedWarranty = value;
    }

    private async Task RequestInsightsSuggestion(string rawTranscript)
    {
        if (string.IsNullOrWhiteSpace(rawTranscript) || rawTranscript.Length < 10)
            return;

        _suggestInsightsCts?.Cancel();
        _suggestInsightsCts = new CancellationTokenSource();
        var ct = _suggestInsightsCts.Token;

        _isSuggestingInsights = true;
        StateHasChanged();

        try
        {
            await Task.Delay(500, ct);

            var request = new IssueInsightsSuggestionRequestDto
            {
                IssueDescription = rawTranscript
            };

            var result = await IntakeAi.SuggestIssueInsightsAsync(request, ct);
            if (result?.Result is not null && !ct.IsCancellationRequested)
            {
                if (result.Result.Urgency is not null)
                {
                    State.Urgency = result.Result.Urgency;
                    State.IsUrgencySuggestedByAi = true;
                }

                if (result.Result.RvUsage is not null)
                {
                    State.RvUsage = result.Result.RvUsage;
                    State.IsRvUsageSuggestedByAi = true;
                }

                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception) { }
        finally
        {
            _isSuggestingInsights = false;
            StateHasChanged();
        }
    }

    private void HandlePurchaseDateChanged(DateTime? date)
    {
        _approxPurchaseDate = date;
        State.ApproxPurchaseDate = date?.ToString("MM/yyyy");
    }

    private string? ValidateApproxPurchaseDate(DateTime? date)
    {
        if (!_submitted) return null;
        if (date is null) return "Approximate purchase date is required";
        return date > DateTime.Today ? "Purchase date cannot be in the future" : null;
    }

    private string? ValidateExtendedWarranty(string? value) =>
        _submitted && string.IsNullOrWhiteSpace(value) ? "Extended warranty selection is required" : null;

    private string? ValidateIssueCategory(string? value) =>
        _submitted && string.IsNullOrWhiteSpace(value) ? "Issue category is required" : null;

    private string? ValidateDescription(string? value)
    {
        if (!_submitted) return null;
        if (string.IsNullOrWhiteSpace(value)) return "Description is required";
        return value.Length > 2000 ? "Description must not exceed 2,000 characters" : null;
    }

    private async Task HandleNext()
    {
        _submitted = true;
        await _form.Validate();
        if (!_form.IsValid) return;

        await State.NotifyAndPersistAsync();
        await OnNext.InvokeAsync();
    }

    /// <summary>
    /// Mirrors the JS object returned by rvs_stopRecording: { audio, mimeType }.
    /// </summary>
    private sealed record AudioRecordingResult(string? Audio, string MimeType);
}
