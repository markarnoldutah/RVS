
<FluentCard Style="border-left: 4px solid var(--accent-fill-rest);">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                @PayerName
            </FluentLabel>
            <FluentBadge Appearance="@(Coverage.PlanType == "Vision" ? Appearance.Accent : Appearance.Neutral)">
                @Coverage.PlanType
            </FluentBadge>
            @if (Coverage.CobPriorityHint.HasValue)
            {
                <FluentBadge>Priority: @Coverage.CobPriorityHint</FluentBadge>
            }
            @if (!string.IsNullOrEmpty(Coverage.CoverageEnrollmentId))
            {
                <FluentBadge Appearance="Appearance.Neutral">Existing</FluentBadge>
            }
            else
            {
                <FluentBadge Appearance="Appearance.Accent">New</FluentBadge>
            }
            <FluentSpacer />
            <FluentButton Appearance="Appearance.Stealth" 
                          Title="@(_isExpanded ? "Collapse" : "Expand")"
                          OnClick="@(() => _isExpanded = !_isExpanded)">
                @if (_isExpanded)
                {
                    <FluentIcon Value="@(new Icons.Regular.Size16.ChevronUp())" />
                }
                else
                {
                    <FluentIcon Value="@(new Icons.Regular.Size16.ChevronDown())" />
                }
            </FluentButton>
            <FluentButton Appearance="Appearance.Stealth" 
                          Title="Remove"
                          OnClick="HandleRemove">
                <FluentIcon Value="@(new Icons.Regular.Size16.Delete())" Color="Color.Error" />
            </FluentButton>
        </FluentStack>

        @if (!_isExpanded)
        {
            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">
                Member ID: @Coverage.MemberId
                @if (!string.IsNullOrEmpty(Coverage.GroupNumber))
                {
                    <text> | Group: @Coverage.GroupNumber</text>
                }
            </FluentLabel>
        }
        else
        {
            <FluentGrid Spacing="3">
                <FluentGridItem xs="12" sm="6" md="4">
                    <FluentSelect TOption="PayerResponseDto"
                                  Label="Payer"
                                  Items="@Payers"
                                  OptionText="@(p => p.Name)"
                                  OptionValue="@(p => p.PayerId)"
                                  SelectedOption="@_selectedPayer"
                                  SelectedOptionChanged="@OnPayerChanged"
                                  Placeholder="Select a Payer"
                                  Required="true" />
                </FluentGridItem>
                <FluentGridItem xs="12" sm="6" md="4">
                    <FluentSelect TOption="LookupItemDto"
                                  Label="Plan Type"
                                  Items="@PlanTypes"
                                  OptionText="@(p => p.Name)"
                                  OptionValue="@(p => p.Code)"
                                  SelectedOption="@_selectedPlanType"
                                  SelectedOptionChanged="@OnPlanTypeChanged" />
                </FluentGridItem>
                <FluentGridItem xs="12" sm="6" md="4">
                    <FluentTextField Label="Member ID" 
                                     Value="@Coverage.MemberId"
                                     ValueChanged="@(v => UpdateCoverageAsync(Coverage with { MemberId = v }))"
                                     Required="true"
                                     Placeholder="Enter member ID" />
                </FluentGridItem>
                <FluentGridItem xs="12" sm="6" md="4">
                    <FluentTextField Label="Group Number" 
                                     Value="@Coverage.GroupNumber"
                                     ValueChanged="@(v => UpdateCoverageAsync(Coverage with { GroupNumber = v }))"
                                     Placeholder="Enter group number" />
                </FluentGridItem>
                <FluentGridItem xs="12" sm="6" md="4">
                    <FluentSelect TOption="LookupItemDto"
                                  Label="Relationship"
                                  Items="@RelationshipTypes"
                                  OptionText="@(p => p.Name)"
                                  OptionValue="@(p => p.Code)"
                                  SelectedOption="@_selectedRelationship"
                                  SelectedOptionChanged="@OnRelationshipChanged" />
                </FluentGridItem>
                <FluentGridItem xs="12" sm="6" md="4">
                    <FluentNumberField Label="COB Priority Hint" 
                                       Value="@((int?)(Coverage.CobPriorityHint))"
                                       ValueChanged="@((int? v) => UpdateCoverageAsync(Coverage with { CobPriorityHint = (byte?)v }))"
                                       Min="1"
                                       Max="9"
                                       Placeholder="1-9" />
                </FluentGridItem>
            </FluentGrid>

            @if (Coverage.RelationshipToSubscriber != "Self")
            {
                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Subscriber Information</FluentLabel>
                <FluentGrid Spacing="3">
                    <FluentGridItem xs="12" sm="6" md="4">
                        <FluentTextField Label="Subscriber First Name" 
                                         Value="@Coverage.SubscriberFirstName"
                                         ValueChanged="@(v => UpdateCoverageAsync(Coverage with { SubscriberFirstName = v }))"
                                         Placeholder="Enter first name" />
                    </FluentGridItem>
                    <FluentGridItem xs="12" sm="6" md="4">
                        <FluentTextField Label="Subscriber Last Name" 
                                         Value="@Coverage.SubscriberLastName"
                                         ValueChanged="@(v => UpdateCoverageAsync(Coverage with { SubscriberLastName = v }))"
                                         Placeholder="Enter last name" />
                    </FluentGridItem>
                    <FluentGridItem xs="12" sm="6" md="4">
                        <FluentDatePicker Label="Subscriber DOB"
                                          Value="@(_subscriberDob)"
                                          ValueChanged="@(v => { _subscriberDob = v; _ = UpdateCoverageAsync(Coverage with { SubscriberDob = v.HasValue ? DateOnly.FromDateTime(v.Value) : null }); })" />
                    </FluentGridItem>
                </FluentGrid>
            }
        }
    </FluentStack>
</FluentCard>

@code {
    [Parameter] public CoverageEnrollmentUpsertDto Coverage { get; set; } = default!;
    [Parameter] public int Index { get; set; }
    [Parameter] public string PayerName { get; set; } = string.Empty;
    [Parameter] public List<PayerResponseDto> Payers { get; set; } = [];
    [Parameter] public List<LookupItemDto> PlanTypes { get; set; } = [];
    [Parameter] public List<LookupItemDto> RelationshipTypes { get; set; } = [];
    [Parameter] public EventCallback<CoverageEnrollmentUpsertDto> OnUpdate { get; set; }
    [Parameter] public EventCallback OnRemove { get; set; }

    private bool _isExpanded;
    private DateTime? _subscriberDob;

    private PayerResponseDto? _selectedPayer => 
        Payers.FirstOrDefault(p => p.PayerId == Coverage.PayerId);

    private LookupItemDto? _selectedPlanType => 
        PlanTypes.FirstOrDefault(p => p.Code == Coverage.PlanType);

    private LookupItemDto? _selectedRelationship => 
        RelationshipTypes.FirstOrDefault(p => p.Code == Coverage.RelationshipToSubscriber);

    private async Task OnPayerChanged(PayerResponseDto? payer)
    {
        if (payer != null)
        {
            await UpdateCoverageAsync(Coverage with { PayerId = payer.PayerId });
        }
    }

    private async Task OnPlanTypeChanged(LookupItemDto? planType)
    {
        if (planType != null)
        {
            await UpdateCoverageAsync(Coverage with { PlanType = planType.Code });
        }
    }

    private async Task OnRelationshipChanged(LookupItemDto? relationship)
    {
        if (relationship != null)
        {
            await UpdateCoverageAsync(Coverage with { RelationshipToSubscriber = relationship.Code });
        }
    }

    protected override void OnParametersSet()
    {
        _subscriberDob = Coverage.SubscriberDob?.ToDateTime(TimeOnly.MinValue);
        
        // Auto-expand new coverages
        if (string.IsNullOrEmpty(Coverage.CoverageEnrollmentId) && string.IsNullOrEmpty(Coverage.PayerId))
        {
            _isExpanded = true;
        }
    }

    private async Task UpdateCoverageAsync(CoverageEnrollmentUpsertDto updated)
    {
        await OnUpdate.InvokeAsync(updated);
    }

    private void HandleRemove()
    {
        OnRemove.InvokeAsync();
    }
}
