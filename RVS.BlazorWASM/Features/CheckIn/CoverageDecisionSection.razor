@using RVS.BlazorWASM
@using RVS.BlazorWASM.Features.CheckIn
@using RVS.BlazorWASM.Layout
@using RVS.BlazorWASM.Services
@using RVS.Domain.DTOs
@inject ILookupCacheService LookupCache
@inject ILogger<CoverageDecisionSection> Logger
@implements IDisposable

<FluentCard>
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
        <FluentLabel Typo="Typography.Subject">
            <FluentIcon Value="@(new Icons.Regular.Size20.ShieldCheckmark())" />
            Coverage Decision (COB)
        </FluentLabel>

        @if (_isLoading)
        {
            <FluentProgressRing />
        }
        else if (State.DecisionSkipped)
        {
            <FluentMessageBar Intent="MessageIntent.Warning">
                <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                    <span>Coverage decision was skipped. You can set it later from the encounter details page.</span>
                    <FluentButton Appearance="Appearance.Outline" OnClick="HandleShowDecisionForm">
                        <FluentIcon Value="@(new Icons.Regular.Size20.ArrowUndo())" Slot="start" />
                        Set Coverage Decision Now
                    </FluentButton>
                </FluentStack>
            </FluentMessageBar>
        }
        else if (_primaryOptions.Count == 0)
        {
            <FluentMessageBar Intent="MessageIntent.Info">
                Add coverage enrollments above to set a coverage decision.
            </FluentMessageBar>
        }
        else
        {
            @if (State.RecommendedDecision != null)
            {
                <FluentMessageBar Intent="MessageIntent.Info">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                        <strong>Recommended:</strong>
                        <span>@State.RecommendedDecision.Recommendation</span>
                        <span class="text-muted">Reason: @State.RecommendedDecision.Reason</span>
                    </FluentStack>
                </FluentMessageBar>
            }

            <FluentGrid Spacing="3">
                <FluentGridItem xs="12" sm="6" md="4">
                     <FluentSelect TOption="CoverageOption"
                                  Label="Primary Coverage"
                                  Items="@_primaryOptions"
                                  OptionText="@(c => c.DisplayName)"
                                  OptionValue="@(c => c.CoverageEnrollmentId)"
                                  SelectedOption="@_selectedPrimaryCoverage"
                                  SelectedOptionChanged="HandlePrimaryCoverageChanged"
                                  Required="true" />
                     <FluentLabel Typo="Typography.H4" Color="Color.Info">
                         <FluentIcon Value="@(new Icons.Regular.Size16.Info())" />
                         Eligibility will be checked
                     </FluentLabel>
                </FluentGridItem>
                <FluentGridItem xs="12" sm="6" md="4">
                    <FluentSelect TOption="CoverageOption"
                                  Label="Secondary Coverage"
                                  Items="@_secondaryOptions"
                                  OptionText="@(c => c.DisplayName)"
                                  OptionValue="@(c => c.CoverageEnrollmentId)"
                                  SelectedOption="@_selectedSecondaryCoverage"
                                  SelectedOptionChanged="HandleSecondaryCoverageChanged" />
                    @if (!string.IsNullOrEmpty(_selectedSecondaryCoverage?.CoverageEnrollmentId))
                    {
                        <FluentLabel Typo="Typography.H4" Color="Color.Success">
                            <FluentIcon Value="@(new Icons.Regular.Size16.Checkmark())" />
                            Eligibility will be checked
                        </FluentLabel>
                    }
                    else
                    {
                        <FluentLabel Typo="Typography.H4" Color="Color.Lightweight">
                            <FluentIcon Value="@(new Icons.Regular.Size16.DismissCircle())" />
                            No eligibility check (optional)
                        </FluentLabel>
                    }
                </FluentGridItem>
                <FluentGridItem xs="12" sm="6" md="4">
                    <FluentSelect TOption="LookupItemDto"
                                  Label="COB Reason"
                                  Items="@_cobReasons"
                                  OptionText="@(c => c.Name)"
                                  OptionValue="@(c => c.Code)"
                                  SelectedOption="@_selectedCobReason"
                                  SelectedOptionChanged="HandleCobReasonChanged"
                                  Required="true" />
                </FluentGridItem>
            </FluentGrid>
            
            <FluentCheckbox Value="@State.OverrideRecommendation"
                            ValueChanged="HandleOverrideRecommendationChanged">
                Override recommended decision
            </FluentCheckbox>

            @if (State.OverrideRecommendation)
            {
                <FluentTextArea Label="Override Note"
                                Value="@State.OverrideNote"
                                ValueChanged="HandleOverrideNoteChanged"
                                Rows="2"
                                Placeholder="Explain why you are overriding the recommendation" />
            }
        }
    </FluentStack>
</FluentCard>

@code {
    /// <summary>
    /// The component's state container.
    /// </summary>
    [Parameter, EditorRequired] public CoverageDecisionSectionState State { get; set; } = default!;

    /// <summary>
    /// Callback when state changes. Parent should handle state propagation.
    /// </summary>
    [Parameter] public EventCallback<CoverageDecisionSectionState> StateChanged { get; set; }

    /// <summary>
    /// Coverage enrollments state from the CoverageEnrollmentsSection.
    /// </summary>
    [Parameter, EditorRequired] public CoverageEnrollmentsSectionState CoverageEnrollmentsState { get; set; } = default!;

    /// <summary>
    /// Encounter details state from the EncounterDetailsSection.
    /// </summary>
    [Parameter, EditorRequired] public EncounterDetailsSectionState EncounterDetailsState { get; set; } = default!;

    // Lookup data (from cache)
    private IReadOnlyList<LookupItemDto> _cobReasons = [];
    private bool _isLoading = true;
    private bool _disposed;

    // Local UI state for dropdown selections (derived from State)
    private List<CoverageOption> _primaryOptions = [];
    private List<CoverageOption> _secondaryOptions = [];
    private CoverageOption? _selectedPrimaryCoverage;
    private CoverageOption? _selectedSecondaryCoverage;
    private LookupItemDto? _selectedCobReason;

    protected override void OnInitialized()
    {
        LoadLookupsFromCache();
    }

    protected override void OnParametersSet()
    {
        BuildCoverageOptions();

        // Calculate recommendation if not already set and lookups are loaded
        if (State.RecommendedDecision == null && _primaryOptions.Count > 0 && !_isLoading && _cobReasons.Count > 0)
        {
            CalculateRecommendation();
        }

        // Always sync selections to ensure UI matches state
        SyncSelectionsFromState();
    }

    private void LoadLookupsFromCache()
    {
        try
        {
            _isLoading = true;

            // Use cached lookups - they should already be loaded by MainLayout
            if (LookupCache.IsLoaded)
            {
                _cobReasons = LookupCache.CobReasons;
                _isLoading = false;
            }
            else
            {
                // Subscribe to cache loaded event if not yet loaded
                LookupCache.CacheLoaded += OnCacheLoaded;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load COB reasons from cache");
            _isLoading = false;
        }
    }

    private void OnCacheLoaded(object? sender, EventArgs e)
    {
        // Guard against callbacks after disposal
        if (_disposed) return;

        _cobReasons = LookupCache.CobReasons;
        _isLoading = false;

        // Build options and calculate recommendation now that we have the COB reasons
        BuildCoverageOptions();
        CalculateRecommendation();
        SyncSelectionsFromState();

        // Unsubscribe after loading
        LookupCache.CacheLoaded -= OnCacheLoaded;

        // Trigger re-render to update UI bindings
        _ = InvokeAsync(StateHasChanged);
    }

    private void BuildCoverageOptions()
    {
        var options = CoverageEnrollmentsState.CoverageEnrollments
            .Where(c => !string.IsNullOrEmpty(c.PayerId))
            .Select((c, index) => new CoverageOption
            {
                CoverageEnrollmentId = c.CoverageEnrollmentId ?? $"new-{index}",
                DisplayName = $"{c.PlanType} - {c.PayerId} ({c.MemberId})",
                PlanType = c.PlanType ?? string.Empty,
                IsActive = true // In Phase 1, we don't have eligibility check results yet
            })
            .ToList();

        State.SetCoverageOptions(options);

        _primaryOptions = options;
        _secondaryOptions =
        [
            new CoverageOption { CoverageEnrollmentId = "", DisplayName = "(None)" },
            .. options
        ];
    }

    private void SyncSelectionsFromState()
    {
        _selectedPrimaryCoverage = _primaryOptions
            .FirstOrDefault(o => o.CoverageEnrollmentId == State.PrimaryCoverageEnrollmentId);

        _selectedSecondaryCoverage = _secondaryOptions
            .FirstOrDefault(o => o.CoverageEnrollmentId == State.SecondaryCoverageEnrollmentId)
            ?? _secondaryOptions.FirstOrDefault();

        _selectedCobReason = _cobReasons
            .FirstOrDefault(r => r.Code == State.CobReasonCode);
    }

    private void CalculateRecommendation()
    {
        if (_primaryOptions.Count == 0 || _cobReasons.Count == 0) return;

        // Get visit type from encounter details state
        var visitType = EncounterDetailsState.Encounter.VisitType;

        // Simple recommendation: Vision primary for vision visits
        var visionCoverage = _primaryOptions.FirstOrDefault(c => c.PlanType == "Vision");
        var medicalCoverage = _primaryOptions.FirstOrDefault(c => c.PlanType == "Medical");

        if (!string.IsNullOrEmpty(visitType) && visitType.Contains("Vision", StringComparison.OrdinalIgnoreCase) && visionCoverage != null)
        {
            var cobReason = medicalCoverage != null
                ? _cobReasons.FirstOrDefault(r => r.Code.Contains("Vision", StringComparison.OrdinalIgnoreCase))?.Code
                    ?? _cobReasons.FirstOrDefault()?.Code
                : _cobReasons.FirstOrDefault(r => r.Code.Contains("Single", StringComparison.OrdinalIgnoreCase))?.Code
                    ?? _cobReasons.FirstOrDefault()?.Code;

            State.ApplyRecommendation(
                visionCoverage.CoverageEnrollmentId,
                medicalCoverage?.CoverageEnrollmentId,
                cobReason ?? "",
                $"{visionCoverage.DisplayName} as Primary",
                "Routine Vision visit uses vision plan first");
        }
        else if (medicalCoverage != null)
        {
            var cobReason = visionCoverage != null
                ? _cobReasons.FirstOrDefault(r => r.Code.Contains("Medical", StringComparison.OrdinalIgnoreCase))?.Code
                    ?? _cobReasons.FirstOrDefault()?.Code
                : _cobReasons.FirstOrDefault(r => r.Code.Contains("Single", StringComparison.OrdinalIgnoreCase))?.Code
                    ?? _cobReasons.FirstOrDefault()?.Code;

            State.ApplyRecommendation(
                medicalCoverage.CoverageEnrollmentId,
                visionCoverage?.CoverageEnrollmentId,
                cobReason ?? "",
                $"{medicalCoverage.DisplayName} as Primary",
                "Medical visit uses medical plan first");
        }
        else if (_primaryOptions.Count == 1)
        {
            var coverage = _primaryOptions.First();
            var cobReason = _cobReasons.FirstOrDefault(r => r.Code.Contains("Single", StringComparison.OrdinalIgnoreCase))?.Code
                ?? _cobReasons.FirstOrDefault()?.Code;

            State.ApplyRecommendation(
                coverage.CoverageEnrollmentId,
                null,
                cobReason ?? "",
                $"{coverage.DisplayName} as Primary",
                "Single coverage available");
        }
        else if (_primaryOptions.Count > 0)
        {
            // Fallback: pick first coverage
            var coverage = _primaryOptions.First();
            State.SetPrimaryCoverage(coverage.CoverageEnrollmentId);
            State.SetCobReasonCode(_cobReasons.FirstOrDefault()?.Code);
        }

        // Always sync selections after applying recommendation
        SyncSelectionsFromState();
    }

    private async Task HandlePrimaryCoverageChanged(CoverageOption? option)
    {
        _selectedPrimaryCoverage = option;
        State.SetPrimaryCoverage(option?.CoverageEnrollmentId);
        await NotifyStateChanged();
    }

    private async Task HandleSecondaryCoverageChanged(CoverageOption? option)
    {
        _selectedSecondaryCoverage = option;
        State.SetSecondaryCoverage(option?.CoverageEnrollmentId);
        await NotifyStateChanged();
    }

    private async Task HandleCobReasonChanged(LookupItemDto? reason)
    {
        _selectedCobReason = reason;
        State.SetCobReasonCode(reason?.Code);
        await NotifyStateChanged();
    }

    private async Task HandleOverrideRecommendationChanged(bool value)
    {
        State.SetOverrideRecommendation(value);
        await NotifyStateChanged();
    }

    private async Task HandleOverrideNoteChanged(string? value)
    {
        State.SetOverrideNote(value);
        await NotifyStateChanged();
    }

    private async Task HandleSkipDecision()
    {
        State.SkipDecision();
        await NotifyStateChanged();
    }

    private async Task HandleShowDecisionForm()
    {
        State.ShowDecisionForm();
        await NotifyStateChanged();
    }

    private async Task NotifyStateChanged()
    {
        StateHasChanged();
        await StateChanged.InvokeAsync(State);
    }

    /// <summary>
    /// Resets the component's local UI state.
    /// </summary>
    public void ResetLocalState()
    {
        _primaryOptions = [];
        _secondaryOptions = [];
        _selectedPrimaryCoverage = null;
        _selectedSecondaryCoverage = null;
        _selectedCobReason = null;
    }

    public void Dispose()
    {
        _disposed = true;
        LookupCache.CacheLoaded -= OnCacheLoaded;
    }
}
