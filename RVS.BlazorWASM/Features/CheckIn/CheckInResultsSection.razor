@using RVS.BlazorWASM
@using RVS.BlazorWASM.Features.CheckIn
@using RVS.BlazorWASM.Layout
@using RVS.BlazorWASM.Services
@using RVS.Domain.DTOs
@inject ILookupCacheService LookupCache
@inject ILogger<CheckInResultsSection> Logger
@implements IDisposable

<FluentStack Orientation="Orientation.Vertical" VerticalGap="16">
    <!-- Success Banner -->
    <FluentMessageBar Title="Check-In Complete" Intent="MessageIntent.Success">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16">
            <span>
                Patient: <strong>@State.CheckInResult?.Patient.FirstName @State.CheckInResult?.Patient.LastName</strong>
            </span>
            <span>
                Encounter: <strong>#@State.CheckInResult?.EncounterId</strong>
            </span>
        </FluentStack>
    </FluentMessageBar>

    @if (State.Warnings.Count > 0)
    {
        <FluentMessageBar Title="Warnings" Intent="MessageIntent.Warning" AllowDismiss="true">
            <ul style="margin: 0; padding-left: 20px;">
                @foreach (var warning in State.Warnings)
                {
                    <li>@warning</li>
                }
            </ul>
        </FluentMessageBar>
    }

    <!-- Eligibility Results -->
    <FluentCard>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                <FluentLabel Typo="Typography.Subject">
                    <FluentIcon Value="@(new Icons.Regular.Size20.DocumentCheckmark())" />
                    Eligibility Verification Results
                </FluentLabel>
                @if (State.IsPolling)
                {
                    <FluentProgressRing Style="width: 20px; height: 20px;" />
                    <FluentLabel Color="Color.Neutral">Checking for updates...</FluentLabel>
                }
            </FluentStack>

            @if (State.EligibilityChecks.Count == 0)
            {
                <FluentMessageBar Intent="MessageIntent.Info">
                    No eligibility checks were requested.
                </FluentMessageBar>
            }
            else
            {
                @foreach (var check in State.EligibilityChecks)
                {
                    <EligibilityCheckResultCard Check="check"
                                                DetailedResult="@GetDetailedResult(check.EligibilityCheckId)" />
                }
            }
        </FluentStack>
    </FluentCard>
</FluentStack>

@code {
    // State container - contains all check-in result data
    [Parameter, EditorRequired] public CheckInResultsSectionState State { get; set; } = default!;
    [Parameter] public EventCallback<CheckInResultsSectionState> StateChanged { get; set; }

    private bool _disposed;

    private EligibilityCheckResultDto? GetDetailedResult(String eligibilityCheckId)
    {
        return State.CheckInResult?.EligibilityChecks
            .FirstOrDefault(c => c.EligibilityCheckId == eligibilityCheckId);
    }

    private async Task NotifyStateChanged()
    {
        StateHasChanged();
        await StateChanged.InvokeAsync(State);
    }

    /// <summary>
    /// Resets the component's local UI state.
    /// </summary>
    public void ResetLocalState()
    {
        // No local UI state to reset in this component after refactoring
    }

    public void Dispose()
    {
        _disposed = true;
    }
}
