@using RVS.BlazorWASM
@using RVS.BlazorWASM.Features.CheckIn
@using RVS.BlazorWASM.Layout
@using RVS.BlazorWASM.Services
@using RVS.Domain.DTOs
@inject IPatientApiService PatientApi
@inject IDialogService DialogService
@inject ILogger<PatientDiscoverySection> Logger

<FluentCard>
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
        <FluentLabel Typo="Typography.Subject">
            <FluentIcon Value="@(new Icons.Regular.Size20.PersonSearch())" />
            Find or Create Patient
        </FluentLabel>

        @if (State.DiscoveryState == PatientDiscoveryState.PatientSelected)
        {
            <!-- Selected Patient Banner -->
            <FluentMessageBar Title="Patient Selected" Intent="MessageIntent.Success">
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="16" VerticalAlignment="VerticalAlignment.Center">
                    <span>
                        <strong>@State.SelectedPatient?.FirstName @State.SelectedPatient?.LastName</strong>
                        @if (State.SelectedPatient?.DateOfBirth.HasValue == true)
                        {
                            <text> | DOB: @State.SelectedPatient.DateOfBirth.Value.ToString("MM/dd/yyyy")</text>
                        }
                        | ID: @State.SelectedPatientId
                    </span>
                    <FluentButton Appearance="Appearance.Lightweight" OnClick="HandleChangePatient">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Edit())" Slot="start" />
                        Change Patient
                    </FluentButton>
                    <FluentButton Appearance="Appearance.Lightweight" OnClick="HandleEditPatient">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Edit())" Slot="start" />
                        Edit Patient
                    </FluentButton>
                </FluentStack>
            </FluentMessageBar>
        }
        else
        {
            <!-- Search Form -->
            <FluentGrid Spacing="3">
                <FluentGridItem xs="12" sm="6" md="3">
                    <FluentTextField Label="Last Name"
                                     Value="@State.SearchLastName"
                                     ValueChanged="@(v => { State.SetSearchLastName(v); })"
                                     Placeholder="Enter last name"
                                     @onkeyup="HandleSearchKeyUp" />
                </FluentGridItem>
                <FluentGridItem xs="12" sm="6" md="3">
                    <FluentTextField Label="First Name"
                                     Value="@State.SearchFirstName"
                                     ValueChanged="@(v => { State.SetSearchFirstName(v); })"
                                     Placeholder="Enter first name"
                                     @onkeyup="HandleSearchKeyUp" />
                </FluentGridItem>
                <FluentGridItem xs="12" sm="6" md="3">
                    <FluentDatePicker Label="Date of Birth"
                                      @onkeyup="HandleSearchKeyUp"
                                      @bind-Value="_searchDobDateTime" />
                </FluentGridItem>
                <FluentGridItem xs="12" sm="6" md="3">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="4">
                        <FluentLabel>&nbsp;</FluentLabel>
                        <FluentButton Appearance="Appearance.Accent"
                                      OnClick="HandleSearchAsync"
                                      Disabled="@(!CanSearch())">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Search())" Slot="start" />
                            Search
                        </FluentButton>
                    </FluentStack>
                </FluentGridItem>
            </FluentGrid>

            @if (State.DiscoveryState == PatientDiscoveryState.Loading)
            {
                <FluentProgressRing />
            }
            else if (State.DiscoveryState == PatientDiscoveryState.NoResults)
            {
                <FluentMessageBar Title="No Results" Intent="MessageIntent.Warning">
                    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
                        <span>No patients found matching "@State.SearchLastName, @State.SearchFirstName"</span>
                        <FluentButton Appearance="Appearance.Accent" OnClick="HandleCreatePatientFromSearch">
                            <FluentIcon Value="@(new Icons.Regular.Size20.PersonAdd())" Slot="start" />
                            Create New Patient with This Info
                        </FluentButton>
                        <FluentButton Appearance="Appearance.Accent" OnClick="HandleSearchAgain">
                            <FluentIcon Value="@(new Icons.Regular.Size20.Search())" Slot="start" />
                            Try another search
                        </FluentButton>
                    </FluentStack>
                </FluentMessageBar>
            }
            else if (State.DiscoveryState == PatientDiscoveryState.ResultsDisplayed)
            {
                <FluentLabel Typo="Typography.Body">
                    <FluentIcon Value="@(new Icons.Regular.Size16.Search())" />
                    @State.SearchResults.Count match(es) found
                </FluentLabel>

                <FluentDataGrid Items="@State.SearchResults.AsQueryable()"
                                Pagination="@_pagination"
                                TGridItem="PatientSearchResultResponseDto">
                    <PropertyColumn Title="Name" Property="@(p => $"{p.LastName}, {p.FirstName}")" />
                    <PropertyColumn Title="DOB" Property="@(p => p.DateOfBirth)" Format="MM/dd/yyyy" />
                    <PropertyColumn Title="Payer" Property="@(p => p.PrimaryPayerName)" />
                    <PropertyColumn Title="Member ID" Property="@(p => p.PrimaryMemberId)" />
                    <TemplateColumn Title="Action">
                        <FluentButton Appearance="Appearance.Accent"
                                      Size="ButtonSize.Small"
                                      OnClick="@(() => HandleSelectPatientAsync(context.PatientId))">
                            Select
                        </FluentButton>
                    </TemplateColumn>
                </FluentDataGrid>

                <FluentDivider />

                <FluentButton Appearance="Appearance.Accent" OnClick="HandleCreatePatientFromSearch">
                    <FluentIcon Value="@(new Icons.Regular.Size20.PersonAdd())" Slot="start" />
                    Create New Patient with This Info
                </FluentButton>
                <FluentButton Appearance="Appearance.Accent" OnClick="HandleSearchAgain">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Search())" Slot="start" />
                    Try another search
                </FluentButton>
            }
            else if (State.DiscoveryState == PatientDiscoveryState.Searching)
            {
                <FluentMessageBar Intent="MessageIntent.Info">
                    Enter patient name and date of birth to search
                </FluentMessageBar>
            }
            else if (State.DiscoveryState == PatientDiscoveryState.CreatingNewPatient || State.DiscoveryState == PatientDiscoveryState.EditingPatient)
            {
                @* <PatientDemographicsSection State="State" OnDemographicsChanged="HandleDemographicsChanged" /> *@

@*                 if (State.DiscoveryState == PatientDiscoveryState.EditingPatient)
                {
                    <FluentButton Appearance="Appearance.Accent" OnClick="HandleCancelEdit">
                        <FluentIcon Value="@(new Icons.Regular.Size20.ArrowUndo())" Slot="start" />
                        Cancel
                    </FluentButton>
                } *@
            }
        }
    </FluentStack>
</FluentCard>

@code {
    /// <summary>
    /// The practice ID for API calls.
    /// </summary>
    [Parameter] public string PracticeId { get; set; } = default!;

    /// <summary>
    /// The component's state container.
    /// </summary>
    [Parameter, EditorRequired] public PatientDiscoverySectionState State { get; set; } = default!;

    /// <summary>
    /// Callback when state changes. Parent should handle state propagation.
    /// </summary>
    [Parameter] public EventCallback<PatientDiscoverySectionState> StateChanged { get; set; }

    private bool _isSearching;
    private DateTime? _searchDobDateTime;
    private PaginationState _pagination = new() { ItemsPerPage = 5 };
    private IDialogReference? _dialog;

    private bool CanSearch()
    {
        return !_isSearching &&
               (State.SearchLastName.Length >= 2 ||
                (State.SearchLastName.Length >= 1 && State.SearchFirstName.Length >= 1));
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && CanSearch())
        {
            await HandleSearchAsync();
        }
    }

    private async Task HandleSearchAsync()
    {
        if (!CanSearch()) return;

        State.ResetSearch();

        try
        {
            _isSearching = true;
            State.SetDiscoveryState(PatientDiscoveryState.Loading);
            await NotifyStateChanged();

            // Convert DateTime to DateOnly
            if (_searchDobDateTime.HasValue)
            {
                State.SetSearchDateOfBirth(DateOnly.FromDateTime(_searchDobDateTime.Value));
            }

            var request = new PatientSearchRequestDto
            {
                LastName = State.SearchLastName,
                FirstName = string.IsNullOrWhiteSpace(State.SearchFirstName) ? null : State.SearchFirstName,
                DateOfBirth = State.SearchDateOfBirth,
                PageSize = 10
            };

            var results = await PatientApi.SearchPatientsAsync(PracticeId, request);
            State.SetSearchResults(results.Items.ToList());

            State.SetDiscoveryState(State.SearchResults.Count > 0
                ? PatientDiscoveryState.ResultsDisplayed
                : PatientDiscoveryState.NoResults);

            await NotifyStateChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Patient search failed");
            State.SetDiscoveryState(PatientDiscoveryState.Searching);
            await NotifyStateChanged();
        }
        finally
        {
            _isSearching = false;
        }
    }

    private async Task HandleSelectPatientAsync(string patientId)
    {
        try
        {
            State.SetDiscoveryState(PatientDiscoveryState.Loading);
            await NotifyStateChanged();

            var patient = await PatientApi.GetPatientAsync(PracticeId, patientId);
            if (patient != null)
            {
                State.PopulateFromPatient(patient);
                State.SetDiscoveryState(PatientDiscoveryState.PatientSelected);
            }
            else
            {
                State.SetDiscoveryState(PatientDiscoveryState.Searching);
            }

            await NotifyStateChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load patient {PatientId}", patientId);
            State.SetDiscoveryState(PatientDiscoveryState.Searching);
            await NotifyStateChanged();
        }
    }

    private async Task HandleCreatePatientFromSearch()
    {
        State.PrepareNewPatientFromSearch();
        State.SetDiscoveryState(PatientDiscoveryState.CreatingNewPatient);
        await NotifyStateChanged();
    }

    private async Task HandleChangePatient()
    {
        State.ResetSearch();
        await NotifyStateChanged();
    }

    private async Task HandleSearchAgain()
    {
        State.ResetSearch();
        await NotifyStateChanged();
    }

    private async Task HandleDemographicsChanged()
    {
        await NotifyStateChanged();
    }

    private async Task HandleEditPatient()
    {
        State.SetDiscoveryState(PatientDiscoveryState.EditingPatient);
        await NotifyStateChanged();
        await OpenEditPatientAsync();
    }

    private async Task OpenEditPatientAsync()
    {
        _dialog = await DialogService.ShowPanelAsync<EditPatientPanel>(State, new DialogParameters()
        {
            ShowTitle = true,
            Title = "Edit Patient",
            Alignment = HorizontalAlignment.Right,
            PrimaryAction = "OK",
            SecondaryAction = null,
            ShowDismiss = true,
            Width = "500px"
        });

        DialogResult result = await _dialog.Result;

        // TODO : Handle result if needed, update state, etc (see HandleEditPatient)
    }


    private async Task HandleCancelEdit()
    {
        State.SetDiscoveryState(PatientDiscoveryState.PatientSelected);
        await NotifyStateChanged();
    }

    private async Task NotifyStateChanged()
    {
        StateHasChanged();
        await StateChanged.InvokeAsync(State);
    }

    /// <summary>
    /// Resets the component's local UI state.
    /// </summary>
    public void ResetLocalState()
    {
        _searchDobDateTime = null;
        _isSearching = false;
    }
}
