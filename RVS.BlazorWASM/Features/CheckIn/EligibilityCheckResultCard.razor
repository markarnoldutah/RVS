
<FluentCard Style="@GetCardStyle()">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8">
        <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
            @switch (Check.Status)
            {
                case "Complete":
                    <FluentIcon Value="@(new Icons.Filled.Size20.CheckmarkCircle())" Color="Color.Success" />
                    break;
                case "Failed":
                    <FluentIcon Value="@(new Icons.Filled.Size20.ErrorCircle())" Color="Color.Error" />
                    break;
                case "InProgress":
                case "Pending":
                    <FluentProgressRing Style="width: 20px; height: 20px;" />
                    break;
                default:
                    <FluentIcon Value="@(new Icons.Regular.Size20.QuestionCircle())" Color="Color.Neutral" />
                    break;
            }

            <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">
                @(Check.PayerName ?? Check.PayerId)
            </FluentLabel>

            <FluentBadge Appearance="@GetStatusAppearance()">
                @Check.Status
            </FluentBadge>

            <FluentSpacer />

            <FluentLabel Typo="Typography.Body" Color="Color.Neutral">
                @Check.RequestedAtUtc.ToLocalTime().ToString("g")
            </FluentLabel>
        </FluentStack>

        @if (Check.Status == "InProgress" || Check.Status == "Pending")
        {
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="8" VerticalAlignment="VerticalAlignment.Center">
                <FluentLabel Typo="Typography.Body" Color="Color.Neutral">
                    Poll attempt: @Check.PollCount
                </FluentLabel>
                @if (Check.NextPollAfterUtc.HasValue)
                {
                    var delay = Check.NextPollAfterUtc.Value - DateTime.UtcNow;
                    if (delay > TimeSpan.Zero)
                    {
                        <FluentLabel Typo="Typography.Body" Color="Color.Neutral">
                            | Next poll in @((int)delay.TotalSeconds)s
                        </FluentLabel>
                    }
                }
            </FluentStack>
        }
        else if (Check.Status == "Complete" && DetailedResult != null)
        {
            <FluentDivider />

            <FluentGrid Spacing="2">
                @if (!string.IsNullOrEmpty(DetailedResult.PlanName))
                {
                    <FluentGridItem xs="12" sm="6">
                        <FluentLabel Typo="Typography.Body">
                            <strong>Plan:</strong> @DetailedResult.PlanName
                        </FluentLabel>
                    </FluentGridItem>
                }
                @if (DetailedResult.EffectiveDate.HasValue)
                {
                    <FluentGridItem xs="12" sm="6">
                        <FluentLabel Typo="Typography.Body">
                            <strong>Effective:</strong> @DetailedResult.EffectiveDate.Value.ToString("MM/dd/yyyy")
                        </FluentLabel>
                    </FluentGridItem>
                }
            </FluentGrid>

            @if (DetailedResult.CoverageLines.Count > 0)
            {
                <FluentLabel Typo="Typography.Body" Weight="FontWeight.Bold">Coverage Details:</FluentLabel>
                
                <FluentDataGrid Items="@DetailedResult.CoverageLines.AsQueryable()" TGridItem="CoverageLineResponseDto">
                    <PropertyColumn Title="Service" Property="@(c => c.CoverageDescription ?? c.ServiceTypeCode)" />
                    <TemplateColumn Title="Copay">
                        @if (context.CopayAmount.HasValue)
                        {
                            <text>@context.CopayAmount.Value.ToString("C")</text>
                        }
                    </TemplateColumn>
                    <TemplateColumn Title="Allowance">
                        @if (context.AllowanceAmount.HasValue)
                        {
                            <text>@context.AllowanceAmount.Value.ToString("C")</text>
                        }
                    </TemplateColumn>
                    <PropertyColumn Title="Network" Property="@(c => c.NetworkIndicator)" />
                </FluentDataGrid>
            }
        }
        else if (Check.Status == "Failed" && DetailedResult != null)
        {
            <FluentMessageBar Intent="MessageIntent.Error">
                @DetailedResult.ErrorMessage
            </FluentMessageBar>

            @if (DetailedResult.ValidationMessages?.Count > 0)
            {
                <FluentLabel Typo="Typography.Body" Color="Color.Error">
                    Validation issues:
                </FluentLabel>
                <ul style="margin: 0; padding-left: 20px;">
                    @foreach (var msg in DetailedResult.ValidationMessages)
                    {
                        <li>@msg</li>
                    }
                </ul>
            }
        }
    </FluentStack>
</FluentCard>

@code {
    [Parameter] public EligibilityCheckSummaryResponseDto Check { get; set; } = default!;
    [Parameter] public EligibilityCheckResultDto? DetailedResult { get; set; }

    private string GetCardStyle()
    {
        var borderColor = Check.Status switch
        {
            "Complete" => "var(--success)",
            "Failed" => "var(--error)",
            "InProgress" or "Pending" => "var(--accent-fill-rest)",
            _ => "var(--neutral-stroke-rest)"
        };

        return $"border-left: 4px solid {borderColor};";
    }

    private Appearance GetStatusAppearance()
    {
        return Check.Status switch
        {
            "Complete" => Appearance.Accent,
            "Failed" => Appearance.Neutral,
            "InProgress" or "Pending" => Appearance.Accent,
            _ => Appearance.Neutral
        };
    }
}
