@using RVS.BlazorWASM
@using RVS.BlazorWASM.Features.CheckIn
@using RVS.BlazorWASM.Layout
@using RVS.BlazorWASM.Services
@using RVS.Domain.DTOs

<FluentCard>
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="12">
        <FluentLabel Typo="Typography.Subject">
            <FluentIcon Value="@(new Icons.Regular.Size20.Person())" />
            Patient Demographics
            @if (State.SelectedPatientId == null)
            {
                <FluentBadge Appearance="Appearance.Accent">New</FluentBadge>
            }
        </FluentLabel>

        <FluentTextField Label="First Name" 
                         @bind-Value="_firstName"
                         Required="true"
                         Placeholder="Enter first name" />

        <FluentTextField Label="Last Name" 
                         @bind-Value="_lastName"
                         Required="true"
                         Placeholder="Enter last name" />

        <FluentDatePicker Label="Date of Birth"
                          @bind-Value="_dateOfBirth" />

        <FluentTextField Label="Phone" 
                         @bind-Value="_phone"
                         Placeholder="(555) 123-4567"
                         InputMode="InputMode.Telephone" />

        <FluentTextField Label="Email" 
                         @bind-Value="_email"
                         Placeholder="patient@email.com"
                         InputMode="InputMode.Email" />

        <FluentButton Appearance="Appearance.Accent" OnClick="HandleCancelEdit">
            <FluentIcon Value="@(new Icons.Regular.Size20.ArrowUndo())" Slot="start" />
            Cancel
        </FluentButton>
    </FluentStack>
</FluentCard>

@code {
    /// <summary>
    /// The parent's discovery section state (used for demographics editing).
    /// </summary>
    [Parameter, EditorRequired] public PatientDiscoverySectionState State { get; set; } = default!;

    /// <summary>
    /// Callback when demographics are changed.
    /// </summary>
    [Parameter] public EventCallback OnDemographicsChanged { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await OnDemographicsChanged.InvokeAsync();
        }
    }

    private string _firstName
    {
        get => State.Demographics.FirstName;
        set
        {
            State.SetDemographics(State.Demographics with { FirstName = value });
            OnDemographicsChanged.InvokeAsync();
        }
    }

    private string _lastName
    {
        get => State.Demographics.LastName;
        set
        {
            State.SetDemographics(State.Demographics with { LastName = value });
            OnDemographicsChanged.InvokeAsync();
        }
    }

    private DateTime? _dateOfBirth
    {
        get => State.Demographics.DateOfBirth?.ToDateTime(TimeOnly.MinValue);
        set
        {
            State.SetDemographics(State.Demographics with 
            { 
                DateOfBirth = value.HasValue ? DateOnly.FromDateTime(value.Value) : null 
            });
            OnDemographicsChanged.InvokeAsync();
        }
    }

    private string? _phone
    {
        get => State.Demographics.Phone;
        set
        {
            State.SetDemographics(State.Demographics with { Phone = value });
            OnDemographicsChanged.InvokeAsync();
        }
    }

    private string? _email
    {
        get => State.Demographics.Email;
        set
        {
            State.SetDemographics(State.Demographics with { Email = value });
            OnDemographicsChanged.InvokeAsync();
        }
    }

    private void HandleCancelEdit(MouseEventArgs args)
    {
        // throw new NotImplementedException();
    }
}
