@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@using RVS.BlazorWASM
@using RVS.BlazorWASM.Features.CheckIn
@using RVS.BlazorWASM.Layout
@using RVS.BlazorWASM.Services
@using RVS.Domain.DTOs
@inject NavigationManager Navigation

<div class="unauthorized-container">
    <FluentCard class="unauthorized-card">
        <FluentStack Orientation="Orientation.Vertical" 
                     VerticalAlignment="VerticalAlignment.Center"
                     HorizontalAlignment="HorizontalAlignment.Center"
                     VerticalGap="20">
            
            <FluentIcon Value="@(new Icons.Regular.Size48.LockClosed())" 
                       Color="Color.Accent" />
            
            <h2>Authentication Required</h2>
            
            <p class="message">
                You need to sign in to access this page.
            </p>
            
            <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="10">
                <FluentButton Appearance="Appearance.Accent"
                             IconStart="@(new Icons.Regular.Size20.Person())"
                             @onclick="BeginLogin">
                    Sign In
                </FluentButton>
                
                <FluentButton Appearance="Appearance.Neutral"
                             IconStart="@(new Icons.Regular.Size20.Home())"
                             @onclick="GoHome">
                    Go to Home
                </FluentButton>
            </FluentStack>
        </FluentStack>
    </FluentCard>
</div>

<style>
    .unauthorized-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 400px;
        padding: 40px 20px;
    }

    .unauthorized-card {
        max-width: 500px;
        width: 100%;
        padding: 40px;
        text-align: center;
    }

    .unauthorized-card h2 {
        margin: 0;
        font-size: 24px;
        font-weight: 600;
        color: var(--neutral-foreground-rest);
    }

    .unauthorized-card .message {
        margin: 0;
        font-size: 16px;
        color: var(--neutral-foreground-hint);
        line-height: 1.5;
    }
</style>

@code {
    [Parameter]
    public string? ReturnUrl { get; set; }

    private void BeginLogin()
    {
        var returnUrl = ReturnUrl ?? Navigation.Uri;
        
        var requestOptions = new InteractiveRequestOptions
        {
            Interaction = InteractionType.SignIn,
            ReturnUrl = returnUrl
        };

        Navigation.NavigateToLogin("authentication/login", requestOptions);
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/");
    }
}
