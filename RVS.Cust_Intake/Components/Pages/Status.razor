@page "/status"

<PageTitle>Check Request Status</PageTitle>

<MudStack AlignItems="AlignItems.Center" Spacing="5" Class="mt-8">
    <MudIcon Icon="@Icons.Material.Filled.Search" Color="Color.Primary"
             Style="font-size: 4rem;" />

    <MudText Typo="Typo.h4" Align="Align.Center">
        Check Request Status
    </MudText>

    <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">
        Enter your confirmation number to view the status of your service request.
    </MudText>

    <form method="post" action="/status/lookup" style="width: 100%; max-width: 400px;">
        <MudStack AlignItems="AlignItems.Center" Spacing="3" Style="width: 100%;">

            <MudPaper Outlined="true" Class="d-flex align-center pa-3 gap-2"
                      Style="width: 100%; border-radius: var(--mud-default-borderradius);">
                <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber"
                         Color="Color.Default" Size="Size.Small" />
                <input type="text"
                       name="confirmationNumber"
                       placeholder="e.g., SR-2026-00742"
                       autocomplete="off"
                       style="flex: 1; border: none; outline: none; font-size: 1rem;
                              font-family: inherit; background: transparent;
                              color: var(--mud-palette-text-primary); width: 100%;" />
            </MudPaper>

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Search"
                       Style="text-transform: none; min-width: 200px;">
                Look Up Status
            </MudButton>

        </MudStack>
    </form>
</MudStack>
