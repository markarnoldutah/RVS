@page "/confirmation"

<PageTitle>Request Submitted</PageTitle>

<MudStack AlignItems="AlignItems.Center" Spacing="5" Class="mt-8">
    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success"
             Style="font-size: 5rem;" />

    <MudText Typo="Typo.h3" Align="Align.Center" GutterBottom="true">
        Request Submitted Successfully
    </MudText>

    <MudText Typo="Typo.body1" Align="Align.Center" Color="Color.Secondary">
        Your service request has been submitted. You will receive a confirmation email shortly.
    </MudText>

    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Home"
               Href="/"
               Style="text-transform: none;">
        Return Home
    </MudButton>
</MudStack>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;
}
