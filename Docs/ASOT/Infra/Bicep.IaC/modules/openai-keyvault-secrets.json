{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "17211019013467018981"
    }
  },
  "parameters": {
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "The name of the existing Key Vault where secrets will be stored."
      }
    },
    "openAiName": {
      "type": "string",
      "metadata": {
        "description": "The name of the Azure OpenAI resource to retrieve connection details from."
      }
    },
    "openAiResourceGroup": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "The resource group containing the Azure OpenAI resource. Defaults to the current resource group."
      }
    },
    "openAiDeploymentName": {
      "type": "string",
      "defaultValue": "gpt-4o",
      "metadata": {
        "description": "The name of the GPT-4o vision model deployment (used for VIN extraction)."
      }
    },
    "openAiTextDeploymentName": {
      "type": "string",
      "defaultValue": "[parameters('openAiDeploymentName')]",
      "metadata": {
        "description": "The name of the GPT-4o text model deployment (used for issue text refinement and category suggestion). Defaults to the vision deployment name when the same deployment handles both workloads."
      }
    },
    "openAiWhisperDeploymentName": {
      "type": "string",
      "defaultValue": "whisper",
      "metadata": {
        "description": "The name of the Whisper model deployment (used for speech-to-text transcription)."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', parameters('keyVaultName'), 'AzureOpenAi--Endpoint')]",
      "properties": {
        "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('openAiResourceGroup')), 'Microsoft.CognitiveServices/accounts', parameters('openAiName')), '2024-10-01').endpoint]",
        "contentType": "text/plain"
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', parameters('keyVaultName'), 'AzureOpenAi--ApiKey')]",
      "properties": {
        "value": "[listKeys(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('openAiResourceGroup')), 'Microsoft.CognitiveServices/accounts', parameters('openAiName')), '2024-10-01').key1]",
        "contentType": "text/plain"
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', parameters('keyVaultName'), 'AzureOpenAi--VisionDeploymentName')]",
      "properties": {
        "value": "[parameters('openAiDeploymentName')]",
        "contentType": "text/plain"
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', parameters('keyVaultName'), 'AzureOpenAi--TextDeploymentName')]",
      "properties": {
        "value": "[parameters('openAiTextDeploymentName')]",
        "contentType": "text/plain"
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', parameters('keyVaultName'), 'AzureOpenAi--WhisperDeploymentName')]",
      "properties": {
        "value": "[parameters('openAiWhisperDeploymentName')]",
        "contentType": "text/plain"
      }
    }
  ]
}