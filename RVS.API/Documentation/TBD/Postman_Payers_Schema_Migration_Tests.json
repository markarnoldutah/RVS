	"item": [
		{
			"name": "1. GLOBAL Payers",
			"item": [
				{
					"name": "Get All Payers (ten_001) - GLOBAL + Tenant-Specific",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is an array', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"});",
									"",
									"pm.test('Contains both GLOBAL and tenant-specific payers', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.length).to.equal(5); // 4 GLOBAL + 1 tenant-specific",
									"    ",
									"    // Check for GLOBAL payers",
									"    var globalPayers = jsonData.filter(p => p.tenantId === 'GLOBAL');",
									"    pm.expect(globalPayers.length).to.equal(4);",
									"    ",
									"    // Check for tenant-specific payer",
									"    var tenantPayers = jsonData.filter(p => p.tenantId === 'ten_001');",
									"    pm.expect(tenantPayers.length).to.equal(1);",
									"    pm.expect(tenantPayers[0].id).to.equal('payer_medicaid_ca_001');",
									"});",
									"",
									"pm.test('Contains expected payer IDs', function () {",
									"    var jsonData = pm.response.json();",
									"    var payerIds = jsonData.map(p => p.id);",
									"    ",
									"    // GLOBAL payers",
									"    pm.expect(payerIds).to.include('payer_vsp_001');",
									"    pm.expect(payerIds).to.include('payer_bcbs_001');",
									"    pm.expect(payerIds).to.include('payer_eyemed_001');",
									"    pm.expect(payerIds).to.include('payer_medicare_001');",
									"    ",
									"    // Tenant-specific payer",
									"    pm.expect(payerIds).to.include('payer_medicaid_ca_001');",
									"});",
									"",
									"pm.test('Payers have required fields', function () {",
									"    var jsonData = pm.response.json();",
									"    ",
									"    jsonData.forEach(function(payer) {",
									"        pm.expect(payer).to.have.property('id');",
									"        pm.expect(payer).to.have.property('name');",
									"        pm.expect(payer).to.have.property('planType');",
									"        pm.expect(payer).to.have.property('tenantId');",
									"        pm.expect(payer.type).to.equal('payer');",
									"    });",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/payers?tenantId={{tenant_001}}",
							"host": ["{{base_url}}"],
							"path": ["api", "payers"],
							"query": [
								{
									"key": "tenantId",
									"value": "{{tenant_001}}"
								}
							]
						},
						"description": "Returns all payers available to ten_001: 4 GLOBAL + 1 tenant-specific (CA Medicaid)"
					}
