			"name": "2. PayerConfigs - Per Tenant",
			"item": [
				{
					"name": "Get PayerConfigs for ten_001 (includes CA Medicaid)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response is an array', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"});",
									"",
									"pm.test('ten_001 has 4 payer configs', function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.length).to.equal(4);",
									"    ",
									"    var payerIds = jsonData.map(pc => pc.payerId);",
									"    pm.expect(payerIds).to.include('payer_vsp_001');",
									"    pm.expect(payerIds).to.include('payer_eyemed_001');",
									"    pm.expect(payerIds).to.include('payer_bcbs_001');",
									"    pm.expect(payerIds).to.include('payer_medicaid_ca_001'); // Tenant-specific!",
									"});",
									"",
									"pm.test('Configs have required fields', function () {",
									"    var jsonData = pm.response.json();",
									"    ",
									"    jsonData.forEach(function(config) {",
									"        pm.expect(config).to.have.property('id');",
									"        pm.expect(config).to.have.property('tenantId');",
									"        pm.expect(config).to.have.property('payerId');",
									"        pm.expect(config).to.have.property('isEnabled');",
									"        pm.expect(config).to.have.property('sortOrder');",
									"        pm.expect(config.type).to.equal('payerConfig');",
									"        pm.expect(config.tenantId).to.equal('ten_001');",
									"    });",
									"});",
									"",
									"pm.test('Configs are sorted by sortOrder', function () {",
									"    var jsonData = pm.response.json();",
									"    ",
									"    for (let i = 0; i < jsonData.length - 1; i++) {",
									"        pm.expect(jsonData[i].sortOrder).to.be.at.most(jsonData[i + 1].sortOrder);",
									"    }",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
