{
	"info": {
		"_postman_id": "bf-payers-schema-migration",
		"name": "BF - Payers Schema Migration Tests",
		"description": "Comprehensive test collection for validating Payers container schema migration:\n- PayerConfig moved from tenants to payers container\n- Payers container now uses /tenantId partition key\n- Supports both GLOBAL payers (shared) and tenant-specific payers\n- PayerConfigs stored per-tenant in payers container",
