{
	"info": {
		"_postman_id": "07d9d495-21ba-41a0-b452-cb1bdebda87a",
		"name": "Patient Check-In Flow Tests  v2",
		"description": "Test collection for patient check-in workflow. Uses the 'BF API Local' environment.\n\n## Prerequisites\n- BF.API running locally\n- Valid Auth0 token in `bearerToken` variable\n\n## Environment Variables Used\n- `baseUrl`: API base URL\n- `tenantId`: Test tenant ID\n- `practiceId`: Test practice ID\n- `locationId`: Test location ID\n- `bearerToken`: Auth0 bearer token\n- `patientId`: Existing patient ID for existing patient scenarios\n- `createdPatientId`: Auto-populated by new patient creation tests\n- `createdEncounterId`: Auto-populated by check-in tests\n- `createdCoverageEnrollmentId`: Auto-populated by check-in tests\n\n## Test Scenarios\nCovers the complete patient check-in workflow including:\n1. Existing patient check-in with coverage and eligibility\n2. New patient creation via check-in\n3. Check-in with multiple coverages\n4. Check-in with coverage decision (COB)\n5. Check-in without eligibility checks\n6. Update existing patient demographics during check-in\n7. ForceRefresh cache behavior testing\n\n## ForceRefresh Feature\n- `forceRefresh: false` (default) - Returns cached eligibility result if < 24 hours old\n- `forceRefresh: true` - Always calls Availity API regardless of cache",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "3424459"
	},
	"item": [
		{
			"name": "Prerequisites",
			"item": [
				{
					"name": "0.1 Search Existing Patient",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Verify response status",
									"pm.test(\"Status code is 200 OK\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Parse response",
									"var jsonData = pm.response.json();",
									"",
									"// Verify paged result structure",
									"pm.test(\"Response has paged result structure\", function () {",
									"    pm.expect(jsonData).to.have.property('items');",
									"    pm.expect(jsonData).to.have.property('totalCount');",
									"    pm.expect(jsonData).to.have.property('page');",
									"    pm.expect(jsonData).to.have.property('pageSize');",
									"});",
									"",
									"// Verify search results exist",
									"pm.test(\"Search returns results\", function () {",
									"    pm.expect(jsonData.items).to.be.an('array');",
									"    pm.expect(jsonData.items.length).to.be.greaterThan(0);",
									"});",
									"",
									"// Log first patient",
									"if (jsonData.items.length > 0) {",
									"    var patient = jsonData.items[0];",
									"    console.log(\"Found patient: \" + patient.firstName + \" \" + patient.lastName + \" (ID: \" + patient.patientId + \")\");",
									"}"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{bearerToken}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"lastName\": \"Rodriguez\",\n  \"firstName\": null,\n  \"dateOfBirth\": null,\n  \"memberId\": null,\n  \"page\": 1,\n  \"pageSize\": 25,\n  \"continuationToken\": null\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/practices/{{practiceId}}/patients/search",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"practices",
								"{{practiceId}}",
								"patients",
								"search"
							]
						},
						"description": "**Optional Prerequisite:** Search for existing patient by name.\n\n**Endpoint:** POST /api/practices/{practiceId}/patients/search\n\nUse this to verify patient data exists before running check-in tests."
					},
					"response": []
				},
				{
					"name": "0.2 Get Existing Patient Details",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Verify response status",
									"pm.test(\"Status code is 200 OK\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"// Parse response",
									"var jsonData = pm.response.json();",
									"",
									"// Verify patient structure",
									"pm.test(\"Patient has required fields\", function () {",
									"    pm.expect(jsonData.patientId).to.eql(pm.environment.get('patientId'));",
									"    pm.expect(jsonData.firstName).to.not.be.empty;",
									"    pm.expect(jsonData.lastName).to.not.be.empty;",
									"});",
									"",
									"// Check for existing coverages",
									"pm.test(\"Patient has coverage enrollments\", function () {",
									"    pm.expect(jsonData.coverageEnrollments).to.be.an('array');",
									"    if (jsonData.coverageEnrollments.length > 0) {",
									"        console.log(\"Existing coverages: \" + jsonData.coverageEnrollments.length);",
									"    }",
									"});",
									"",
									"// Check for existing recentEncounters",
									"pm.test(\"Patient has recentEncounters\", function () {",
									"    pm.expect(jsonData.recentEncounters).to.be.an('array');",
									"    if (jsonData.recentEncounters.length > 0) {",
									"        console.log(\"Existing recentEncounters: \" + jsonData.recentEncounters.length);",
									"    }",
									"});",
									"",
									"// Log patient summary",
									"console.log(\"Patient: \" + jsonData.firstName + \" \" + jsonData.lastName);",
									"console.log(\"DOB: \" + jsonData.dateOfBirth);",
									"console.log(\"Email: \" + jsonData.email);"
								],
								"type": "text/javascript",
								"packages": {},
								"requests": {}
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{bearerToken}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/practices/{{practiceId}}/patients/{{patientId}}",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"practices",
								"{{practiceId}}",
								"patients",
								"{{patientId}}"
							]
						},
						"description": "**Optional Prerequisite:** Get full patient details including coverages and encounters.\n\n**Endpoint:** GET /api/practices/{practiceId}/patients/{patientId}\n\nUse this to review patient data before running check-in tests."
					},
					"response": []
				}
			],
			"description": "Optional prerequisite requests to review existing patient data."
		},
		{
			"name": "1. Check-In Existing Patient (Simple)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Verify response status",
							"pm.test(\"Status code is 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"// Parse response",
							"var jsonData = pm.response.json();",
							"",
							"// Save encounter ID for later use",
							"if (jsonData.encounterId) {",
							"    pm.environment.set(\"createdEncounterId\", jsonData.encounterId);",
							"    console.log(\"Saved createdEncounterId: \" + jsonData.encounterId);",
							"}",
							"",
							"// Verify patient was not created (existing patient)",
							"pm.test(\"Patient was not created (existing)\", function () {",
							"    pm.expect(jsonData.patient.wasCreated).to.be.false;",
							"});",
							"",
							"// Verify patient ID matches",
							"pm.test(\"Patient ID matches\", function () {",
							"    pm.expect(jsonData.patientId).to.eql(pm.environment.get('patientId'));",
							"});",
							"",
							"// Verify encounter was created",
							"pm.test(\"Encounter was created\", function () {",
							"    pm.expect(jsonData.encounter.wasCreated).to.be.true;",
							"    pm.expect(jsonData.encounterId).to.not.be.empty;",
							"});",
							"",
							"// Verify encounter details",
							"pm.test(\"Encounter has expected details\", function () {",
							"    pm.expect(jsonData.encounter.locationId).to.eql(pm.environment.get('locationId'));",
							"    pm.expect(jsonData.encounter.visitType).to.eql('Routine Vision Exam');",
							"    pm.expect(jsonData.encounter.status).to.eql('scheduled');",
							"});",
							"",
							"// Verify no coverage enrollments added",
							"pm.test(\"No new coverage enrollments\", function () {",
							"    pm.expect(jsonData.coverageEnrollments).to.be.an('array');",
							"    pm.expect(jsonData.coverageEnrollments.length).to.eql(0);",
							"});",
							"",
							"// Verify no eligibility checks run",
							"pm.test(\"No eligibility checks run\", function () {",
							"    pm.expect(jsonData.eligibilityChecks).to.be.an('array');",
							"    pm.expect(jsonData.eligibilityChecks.length).to.eql(0);",
							"});",
							"",
							"// Verify no warnings",
							"pm.test(\"No warnings\", function () {",
							"    pm.expect(jsonData.warnings).to.be.an('array');",
							"    pm.expect(jsonData.warnings.length).to.eql(0);",
							"});",
							"",
							"// Log summary",
							"console.log(\"Check-in complete for: \" + jsonData.patient.firstName + \" \" + jsonData.patient.lastName);",
							"console.log(\"Encounter ID: \" + jsonData.encounterId);",
							"console.log(\"Visit Date: \" + jsonData.encounter.visitDate);"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				},
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// Ensure required environment variables are set",
							"const required = ['baseUrl', 'practiceId', 'patientId', 'locationId', 'bearerToken'];",
							"",
							"required.forEach(function(varName) {",
							"    if (!pm.environment.get(varName)) {",
							"        console.warn('Missing environment variable: ' + varName);",
							"    }",
							"});"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{bearerToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"encounter\": {\n    \"locationId\": \"{{locationId}}\",\n    \"visitDate\": \"{{$isoTimestamp}}\",\n    \"visitType\": \"Routine Vision Exam\"\n  }\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/practices/{{practiceId}}/check-in",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"practices",
						"{{practiceId}}",
						"check-in"
					]
				},
				"description": "**Scenario:** Check in an existing patient and create a new encounter.\n\n**Endpoint:** POST /api/practices/{practiceId}/check-in\n\n**Expected Behavior:**\n- Uses existing patient (wasCreated = false)\n- Creates new encounter (wasCreated = true)\n- No coverage enrollments added\n- No eligibility checks run"
			},
			"response": []
		},
		{
			"name": "2. Create New Patient via Check-In",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Verify response status (201 for new patient)",
							"pm.test(\"Status code is 201 Created\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"// Parse response",
							"var jsonData = pm.response.json();",
							"",
							"// Save patient and encounter IDs",
							"if (jsonData.patientId) {",
							"    pm.environment.set(\"createdPatientId\", jsonData.patientId);",
							"    console.log(\"Saved createdPatientId: \" + jsonData.patientId);",
							"}",
							"if (jsonData.encounterId) {",
							"    pm.environment.set(\"createdEncounterId\", jsonData.encounterId);",
							"    console.log(\"Saved createdEncounterId: \" + jsonData.encounterId);",
							"}",
							"",
							"// Verify patient was created",
							"pm.test(\"Patient was created\", function () {",
							"    pm.expect(jsonData.patient.wasCreated).to.be.true;",
							"    pm.expect(jsonData.patientId).to.not.be.empty;",
							"});",
							"",
							"// Verify patient demographics",
							"pm.test(\"Patient has expected demographics\", function () {",
							"    pm.expect(jsonData.patient.firstName).to.eql('John');",
							"    pm.expect(jsonData.patient.lastName).to.eql('Smith');",
							"    pm.expect(jsonData.patient.email).to.eql('john.smith@example.com');",
							"    pm.expect(jsonData.patient.phone).to.eql('555-0100');",
							"});",
							"",
							"// Verify encounter was created",
							"pm.test(\"Encounter was created\", function () {",
							"    pm.expect(jsonData.encounter.wasCreated).to.be.true;",
							"    pm.expect(jsonData.encounterId).to.not.be.empty;",
							"});",
							"",
							"// Verify encounter details",
							"pm.test(\"Encounter has expected details\", function () {",
							"    pm.expect(jsonData.encounter.locationId).to.eql(pm.environment.get('locationId'));",
							"    pm.expect(jsonData.encounter.visitType).to.eql('New Patient Exam');",
							"    pm.expect(jsonData.encounter.status).to.eql('scheduled');",
							"});",
							"",
							"// Verify no warnings",
							"pm.test(\"No warnings\", function () {",
							"    pm.expect(jsonData.warnings).to.be.an('array');",
							"    pm.expect(jsonData.warnings.length).to.eql(0);",
							"});",
							"",
							"// Verify Location header points to new patient",
							"pm.test(\"Location header is present\", function () {",
							"    pm.response.to.have.header('Location');",
							"    pm.expect(pm.response.headers.get('Location')).to.include(jsonData.patientId);",
							"});",
							"",
							"// Log summary",
							"console.log(\"New patient created: \" + jsonData.patient.firstName + \" \" + jsonData.patient.lastName);",
							"console.log(\"Patient ID: \" + jsonData.patientId);",
							"console.log(\"Encounter ID: \" + jsonData.encounterId);",
							"console.log(\"DOB: \" + jsonData.patient.dateOfBirth);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{bearerToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"patient\": {\n    \"firstName\": \"John\",\n    \"lastName\": \"Smith\",\n    \"dateOfBirth\": \"1985-06-15\",\n    \"email\": \"john.smith@example.com\",\n    \"phone\": \"555-0100\"\n  },\n  \"encounter\": {\n    \"locationId\": \"{{locationId}}\",\n    \"visitDate\": \"{{$isoTimestamp}}\",\n    \"visitType\": \"New Patient Exam\"\n  }\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/practices/{{practiceId}}/check-in",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"practices",
						"{{practiceId}}",
						"check-in"
					]
				},
				"description": "**Scenario:** Create a brand new patient during check-in.\n\n**Endpoint:** POST /api/practices/{practiceId}/check-in\n\n**Expected Behavior:**\n- Creates new patient (wasCreated = true)\n- Creates new encounter (wasCreated = true)\n- Returns 201 Created status\n- Location header points to new patient resource"
			},
			"response": []
		},
		{
			"name": "3. Check-In with Single Coverage",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Verify response status",
							"pm.test(\"Status code is 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"// Parse response",
							"var jsonData = pm.response.json();",
							"",
							"// Save coverage enrollment ID",
							"if (jsonData.coverageEnrollments && jsonData.coverageEnrollments.length > 0) {",
							"    pm.environment.set(\"createdCoverageEnrollmentId\", jsonData.coverageEnrollments[0].coverageEnrollmentId);",
							"    console.log(\"Saved createdCoverageEnrollmentId: \" + jsonData.coverageEnrollments[0].coverageEnrollmentId);",
							"}",
							"",
							"// Verify coverage enrollment was created",
							"pm.test(\"Coverage enrollment was created\", function () {",
							"    pm.expect(jsonData.coverageEnrollments).to.be.an('array');",
							"    pm.expect(jsonData.coverageEnrollments.length).to.eql(1);",
							"    pm.expect(jsonData.coverageEnrollments[0].wasCreated).to.be.true;",
							"});",
							"",
							"// Verify coverage details",
							"pm.test(\"Coverage has expected details\", function () {",
							"    var coverage = jsonData.coverageEnrollments[0];",
							"    pm.expect(coverage.payerId).to.eql('VSP');",
							"    pm.expect(coverage.planType).to.eql('Vision');",
							"    pm.expect(coverage.memberId).to.eql('VSP123456');",
							"    pm.expect(coverage.groupNumber).to.eql('GRP001');",
							"    pm.expect(coverage.cobPriorityHint).to.eql(1);",
							"});",
							"",
							"// Verify encounter was created",
							"pm.test(\"Encounter was created\", function () {",
							"    pm.expect(jsonData.encounter.wasCreated).to.be.true;",
							"});",
							"",
							"// Verify no eligibility checks run",
							"pm.test(\"No eligibility checks run\", function () {",
							"    pm.expect(jsonData.eligibilityChecks.length).to.eql(0);",
							"});",
							"",
							"// Log summary",
							"console.log(\"Coverage added: \" + jsonData.coverageEnrollments[0].payerId + \" \" + jsonData.coverageEnrollments[0].planType);",
							"console.log(\"Member ID: \" + jsonData.coverageEnrollments[0].memberId);",
							"console.log(\"Priority: \" + jsonData.coverageEnrollments[0].cobPriorityHint);"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{bearerToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"coverageEnrollments\": [\n    {\n      \"payerId\": \"VSP\",\n      \"planType\": \"Vision\",\n      \"memberId\": \"VSP123456\",\n      \"groupNumber\": \"GRP001\",\n      \"relationshipToSubscriber\": \"Self\",\n      \"isEmployerPlan\": true,\n      \"effectiveDate\": \"2024-01-01\",\n      \"cobPriorityHint\": 1\n    }\n  ],\n  \"encounter\": {\n    \"locationId\": \"{{locationId}}\",\n    \"visitDate\": \"{{$isoTimestamp}}\",\n    \"visitType\": \"Routine Vision Exam\"\n  }\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/api/practices/{{practiceId}}/check-in",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"api",
						"practices",
						"{{practiceId}}",
						"check-in"
					]
				},
				"description": "**Scenario:** Check in existing patient and add a single coverage enrollment.\n\n**Endpoint:** POST /api/practices/{practiceId}/check-in\n\n**Expected Behavior:**\n- Uses existing patient\n- Creates new encounter\n- Adds new coverage enrollment (wasCreated = true)\n- No eligibility checks run yet"
			},
			"response": []
		},
		{
			"name": "4. Check-In with Dual Coverage",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Verify response status",
							"pm.test(\"Status code is 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"// Parse response",
							"var jsonData = pm.response.json();",
							"",
							"// Verify two coverage enrollments created",
							"pm.test(\"Two coverage enrollments created\", function () {",
							"    pm.expect(jsonData.coverageEnrollments).to.be.an('array');",
							"    pm.expect(jsonData.coverageEnrollments.length).to.eql(2);",
							"    pm.expect(jsonData.coverageEnrollments[0].wasCreated).to.be.true;",
							"    pm.expect(jsonData.coverageEnrollments[1].wasCreated).to.be.true;",
							"});",
							"",
							"// Verify primary coverage",
							"pm.test(\"Primary coverage (VSP) has priority 1\", function () {",
							"    var primary = jsonData.coverageEnrollments.find(c => c.payerId === 'VSP');",
							"    pm.expect(primary).to.not.be.undefined;",
							"    pm.expect(primary.cobPriorityHint).to.eql(1);",
							"});",
							"",
							"// Verify secondary coverage",
							"pm.test(\"Secondary coverage (Aetna) has priority 2\", function () {",
							"    var secondary = jsonData.coverageEnrollments.find(c => c.payerId === 'Aetna');",
							"    pm.expect(secondary).to.not.be.undefined;",
							"    pm.expect(secondary.cobPriorityHint).to.eql(2);",
							"});",
							"",
							"// Verify encounter created",
							"pm.test(\"Encounter was created\", function () {",
							"    pm.expect(jsonData.encounter.wasCreated).to.be.true;",
							"});",
							"",
							"// Log summary",
							"console.log(\"Dual coverage added:\");",
							"jsonData.coverageEnrollments.forEach(function(cov, i) {",
							"    console.log(\"  \" + (i+1) + \". \" + cov.payerId + \" (Priority: \" + cov.cobPriorityHint + \")\");",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{bearerToken}}"
					}
				],
