<MudPaper Elevation="3" Class="pa-6" Style="width: 100%;">
    <MudStack Spacing="4">
        <MudText Typo="Typo.h4">Contact</MudText>

        @if (State.IsPrefilled)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true">
                Your information has been pre-filled from your previous visit.
            </MudAlert>
        }

        <MudStack Spacing="1">
            <MudText Typo="Typo.body1" Style="font-weight: 700;">First name</MudText>
            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Your given name as it appears on your ID</MudText>
            <MudTextField @bind-Value="State.FirstName"
                          T="string"
                          Required="true"
                          RequiredError="First name is required"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          autocomplete="given-name" />
        </MudStack>

        <MudStack Spacing="1">
            <MudText Typo="Typo.body1" Style="font-weight: 700;">Last name</MudText>
            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Your family or surname</MudText>
            <MudTextField @bind-Value="State.LastName"
                          T="string"
                          Required="true"
                          RequiredError="Last name is required"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          autocomplete="family-name" />
        </MudStack>

        <MudStack Spacing="1">
            <MudText Typo="Typo.body1" Style="font-weight: 700;">Email</MudText>
            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">We'll send service updates to this address</MudText>
            <MudTextField @bind-Value="State.Email"
                          T="string"
                          Required="true"
                          RequiredError="Email is required"
                          InputType="InputType.Email"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Placeholder="you@example.com"
                          autocomplete="email" />
        </MudStack>

        <MudStack Spacing="1">
            <MudText Typo="Typo.body1" Style="font-weight: 700;">Phone</MudText>
            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">In case we need to reach you about your service (optional)</MudText>
            <MudTextField @bind-Value="State.Phone"
                          T="string"
                          InputType="InputType.Telephone"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Placeholder="(555) 123-4567"
                          autocomplete="tel" />
        </MudStack>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="HandleNext"
                   Style="text-transform: none;"
                   Class="mt-2">
            Continue...
        </MudButton>
        <MudText Typo="Typo.caption" Align="Align.Center"
                 Style="color: var(--mud-palette-text-secondary);">
            Step @State.CurrentStep of @State.TotalSteps
        </MudText>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnNext { get; set; }

    private async Task HandleNext()
    {
        await State.NotifyAndPersistAsync();
        await OnNext.InvokeAsync();
    }
}
