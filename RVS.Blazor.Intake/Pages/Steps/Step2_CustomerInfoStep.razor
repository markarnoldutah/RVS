<MudPaper Elevation="3" Class="pa-6" Style="width: 100%;">
    <MudStack Spacing="4">
        <MudText Typo="Typo.h4">Contact</MudText>

        @if (State.IsPrefilled)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true">
                Your information has been pre-filled from your previous visit.
            </MudAlert>
        }

        <MudTextField @bind-Value="State.FirstName"
                      Label="First Name"
                      Required="true"
                      RequiredError="First name is required"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Badge"
                      autocomplete="given-name" />

        <MudTextField @bind-Value="State.LastName"
                      Label="Last Name"
                      Required="true"
                      RequiredError="Last name is required"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Badge"
                      autocomplete="family-name" />

        <MudTextField @bind-Value="State.Email"
                      Label="Email"
                      Required="true"
                      RequiredError="Email is required"
                      InputType="InputType.Email"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Email"
                      Placeholder="you@example.com"
                      autocomplete="email" />

        <MudTextField @bind-Value="State.Phone"
                      Label="Phone (optional)"
                      InputType="InputType.Telephone"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Phone"
                      Placeholder="(555) 123-4567"
                      autocomplete="tel" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="HandleNext"
                   Style="text-transform: none;"
                   Class="mt-2">
            Continue...
        </MudButton>
        <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary">
            Step @State.CurrentStep of @State.TotalSteps
        </MudText>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnNext { get; set; }

    private async Task HandleNext()
    {
        await State.NotifyAndPersistAsync();
        await OnNext.InvokeAsync();
    }
}
