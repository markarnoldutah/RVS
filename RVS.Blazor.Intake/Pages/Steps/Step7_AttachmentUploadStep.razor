<MudPaper Elevation="2" Class="pa-6 rounded-lg wizard-step-card">
    <MudStack Spacing="4">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h5" Style="color: var(--mud-palette-text-primary);">Attachments</MudText>
            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">
                <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary); text-align: center;">
                    Attach up to 10 photos or videos to help us with early diagnosis.
                </MudText>
            </MudText>
        </MudStack>

        @if (State.Config is not null)
        {
            @* <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                Max @State.Config.MaxAttachments files, up to @State.Config.MaxFileSizeMb MB each.
                Accepted: @string.Join(", ", State.Config.AcceptedFileTypes)
            </MudText> *@
        }
        else
        {
            <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                Max 10 files, up to 25 MB each.
            </MudText>
        }

        @*         <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" NoIcon="false"
                  Icon="@Icons.Material.Filled.Videocam" Class="mt-n2">
            <MudText Typo="Typo.body2">
                <strong>Recording a video?</strong> Keep clips under @EstimatedMaxVideoSeconds seconds
                (@MaxFileSizeMb MB limit). Shorter clips or lower resolution record better.
            </MudText>
        </MudAlert> *@

        <MudPaper Elevation="0" Outlined="true"
                  Class="pa-8 d-flex flex-column align-center justify-center"
                  Style="border-style: dashed; border-width: 2px; min-height: 140px; cursor: pointer;
                    border-color: var(--mud-palette-primary); position: relative;">
            <MudIcon Icon="@Icons.Material.Filled.PhotoCamera" Color="Color.Primary"
                     Style="font-size: 3rem;" />
            <MudText Typo="Typo.body1" Class="mt-2">
                Max video length: @EstimatedMaxVideoSeconds seconds
                Max upload size: @MaxFileSizeMb MB.
            </MudText>
            <InputFile OnChange="HandleFilesSelected"
                       multiple
                       accept="@AcceptedTypes"
                       style="opacity: 0.001; position: absolute; width: 100%; height: 100%; cursor: pointer; top: 0; left: 0; z-index: 1;" />
        </MudPaper>

        @if (State.Attachments.Count > 0)
        {
            <MudStack Spacing="2">
                @foreach (var file in State.Attachments)
                {
                    <MudPaper Elevation="1" Class="pa-3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@GetFileIcon(file.ContentType)" Color="Color.Primary" />
                            <MudStack Spacing="0" Style="flex: 1; min-width: 0;">
                                <MudText Typo="Typo.body2" Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                    @file.FileName
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                                    @FormatFileSize(file.SizeBytes)
                                </MudText>
                            </MudStack>

                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="() => RemoveFile(file)"
                                           aria-label="Remove file" />
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        }

        @if (_fileErrors.Count > 0)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                <ul style="margin: 0; padding-left: 16px;">
                    @foreach (var error in _fileErrors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </MudAlert>
        }

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="HandleNext"
                   Style="text-transform: none;"
                   Class="mt-6">
            Continue
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnNext { get; set; }

    private List<string> _fileErrors = [];

    private static readonly HashSet<string> AllowedMimeTypes =
    [
        "image/jpeg", "image/png", "image/gif", "image/webp", "image/heic",
        "video/mp4", "video/quicktime", "video/webm",
        "application/pdf"
    ];

    /// <summary>
    /// Infers MIME type from file extension when the browser reports an empty content type.
    /// Common with iPhone camera recordings in Safari.
    /// </summary>
    private static readonly Dictionary<string, string> ExtensionToMimeType = new(StringComparer.OrdinalIgnoreCase)
    {
        [".jpg"] = "image/jpeg",
        [".jpeg"] = "image/jpeg",
        [".png"] = "image/png",
        [".gif"] = "image/gif",
        [".webp"] = "image/webp",
        [".heic"] = "image/heic",
        [".mp4"] = "video/mp4",
        [".mov"] = "video/quicktime",
        [".webm"] = "video/webm",
        [".pdf"] = "application/pdf"
    };

    private static string ResolveContentType(Microsoft.AspNetCore.Components.Forms.IBrowserFile file)
    {
        if (!string.IsNullOrWhiteSpace(file.ContentType) && AllowedMimeTypes.Contains(file.ContentType))
            return file.ContentType;

        var extension = Path.GetExtension(file.Name);
        if (!string.IsNullOrEmpty(extension) && ExtensionToMimeType.TryGetValue(extension, out var inferred))
            return inferred;

        return file.ContentType;
    }

    private string AcceptedTypes => State.Config?.AcceptedFileTypes is { Count: > 0 } types
        ? string.Join(",", types)
        : "image/*,video/*,application/pdf";

    private int MaxAttachments => State.Config?.MaxAttachments ?? 10;
    private int MaxFileSizeMb => State.Config?.MaxFileSizeMb ?? 25;

    /// <summary>
    /// Conservative estimate of the longest video a phone can record within the file size limit.
    /// Based on ~14 Mbps (typical iPhone 1080p HEVC / Android 1080p H.264), rounded down to
    /// the nearest 5 seconds so the guidance feels intentional rather than falsely precise.
    /// </summary>
    private int EstimatedMaxVideoSeconds
    {
        get
        {
            const double typicalBitrateMbps = 14.0;
            var rawSeconds = MaxFileSizeMb * 8.0 / typicalBitrateMbps;
            var rounded = (int)(rawSeconds / 5) * 5;
            return Math.Max(rounded, 5);
        }
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        _fileErrors = [];

        var remainingSlots = MaxAttachments - State.Attachments.Count;
        if (remainingSlots <= 0)
        {
            _fileErrors.Add($"Maximum {MaxAttachments} files allowed.");
            return;
        }

        var files = e.GetMultipleFiles(MaxAttachments);

        foreach (var file in files.Take(remainingSlots))
        {
            if (file.Size > MaxFileSizeMb * 1024L * 1024L)
            {
                _fileErrors.Add($"{file.Name}: exceeds {MaxFileSizeMb} MB limit.");
                continue;
            }

            var contentType = ResolveContentType(file);

            if (!AllowedMimeTypes.Contains(contentType))
            {
                _fileErrors.Add($"{file.Name}: file type '{file.ContentType}' is not supported.");
                continue;
            }

            var attachment = new AttachmentFileInfo
            {
                FileName = file.Name,
                ContentType = contentType,
                SizeBytes = file.Size,
                BrowserFile = file
            };

            // Buffer file bytes immediately so the data survives if the user selects
            // another file on the same InputFile element (which invalidates older
            // IBrowserFile JS interop references).
            try
            {
                await using var stream = file.OpenReadStream(maxAllowedSize: MaxFileSizeMb * 1024L * 1024L);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                attachment.FileData = ms.ToArray();
            }
            catch (Exception ex)
            {
                _fileErrors.Add($"{file.Name}: failed to read file — it may be too large for in-browser processing.");
                continue;
            }

            State.Attachments.Add(attachment);
        }

        if (files.Count > remainingSlots)
        {
            _fileErrors.Add($"Only {remainingSlots} more file(s) can be added.");
        }

        StateHasChanged();
    }

    private void RemoveFile(AttachmentFileInfo file)
    {
        State.Attachments.Remove(file);
        _fileErrors = [];
        StateHasChanged();
    }

    private static string GetFileIcon(string contentType)
    {
        if (contentType.StartsWith("image/")) return Icons.Material.Filled.Image;
        if (contentType.StartsWith("video/")) return Icons.Material.Filled.VideoFile;
        return Icons.Material.Filled.InsertDriveFile;
    }

    private static string FormatFileSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };

    private async Task HandleNext()
    {
        await State.NotifyAndPersistAsync();
        await OnNext.InvokeAsync();
    }
}
