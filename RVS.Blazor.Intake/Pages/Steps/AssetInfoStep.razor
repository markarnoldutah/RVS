<MudPaper Elevation="3" Class="pa-6" Style="width: 100%;">
    <MudStack Spacing="4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.DirectionsCarFilled" Color="Color.Primary" />
            <MudText Typo="Typo.h5">Vehicle Information</MudText>
        </MudStack>

        <MudTextField T="string"
                      Value="@State.Vin"
                      ValueChanged="HandleVinChanged"
                      Label="VIN (Vehicle Identification Number)"
                      Required="true"
                      RequiredError="VIN is required"
                      MaxLength="17"
                      Counter="17"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Pin"
                      Placeholder="17-character VIN"
                      HelperText="Enter the 17-character Vehicle Identification Number"
                      Immediate="true" />

        @if (!string.IsNullOrWhiteSpace(State.Vin))
        {
            var vinResult = ClientVinValidator.Validate(State.Vin);
            if (vinResult.IsValid)
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Text" Dense="true">
                    VIN format is valid.
                </MudAlert>
            }
            else if (State.Vin.Length == 17)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Text" Dense="true">
                    @vinResult.ErrorMessage You can usually find the VIN on the driver's side dashboard or door jamb sticker.
                </MudAlert>
            }
        }

        <MudTextField @bind-Value="State.Manufacturer"
                      Label="Manufacturer (optional)"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Factory"
                      Placeholder="e.g., Winnebago, Thor, Jayco" />

        <MudTextField @bind-Value="State.Model"
                      Label="Model (optional)"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.DirectionsCar"
                      Placeholder="e.g., Vista, Aria, Eagle" />

        <MudNumericField @bind-Value="State.Year"
                         Label="Year (optional)"
                         Variant="Variant.Outlined"
                         Adornment="Adornment.Start"
                         AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                         Placeholder="e.g., 2023"
                         Min="1900"
                         Max="@(DateTime.UtcNow.Year + 2)" />

        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="HandleBack"
                       Style="text-transform: none;">
                Back
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="HandleNext"
                       Style="text-transform: none;">
                Next
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnNext { get; set; }
    [Parameter, EditorRequired] public EventCallback OnBack { get; set; }

    private void HandleVinChanged(string? value)
    {
        // Strip whitespace and uppercase to normalize VIN on input,
        // preventing MaxLength from silently truncating real characters
        // when clipboard paste includes leading/trailing spaces.
        State.Vin = value?.Trim().ToUpperInvariant() ?? string.Empty;
    }

    private async Task HandleNext()
    {
        await State.NotifyAndPersistAsync();
        await OnNext.InvokeAsync();
    }

    private async Task HandleBack()
    {
        await OnBack.InvokeAsync();
    }
}
