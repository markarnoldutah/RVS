<MudPaper Elevation="3" Class="pa-6" Style="width: 100%;">
    <MudStack Spacing="4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AttachFile" Color="Color.Primary" />
            <MudText Typo="Typo.h5">Attachments</MudText>
        </MudStack>

        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Upload photos or videos of the issue. Drag and drop files, browse, or take a photo.
        </MudText>

        @if (State.Config is not null)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Max @State.Config.MaxAttachments files, up to @State.Config.MaxFileSizeMb MB each.
                Accepted: @string.Join(", ", State.Config.AcceptedFileTypes)
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Max 10 files, up to 25 MB each.
            </MudText>
        }

        <MudPaper Elevation="0" Outlined="true"
                  Class="pa-8 d-flex flex-column align-center justify-center"
                  Style="border-style: dashed; border-width: 2px; min-height: 140px; cursor: pointer;
                         border-color: var(--mud-palette-primary); position: relative;">
            <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Color="Color.Primary"
                     Style="font-size: 3rem;" />
            <MudText Typo="Typo.body1" Class="mt-2">
                Drag files here or click to browse
            </MudText>
            <InputFile OnChange="HandleFilesSelected"
                       multiple
                       accept="@AcceptedTypes"
                       style="opacity: 0; position: absolute; width: 100%; height: 100%; cursor: pointer; top: 0; left: 0;" />
        </MudPaper>

        @* Camera capture button for mobile devices *@
        <MudPaper Elevation="0" Outlined="true"
                  Class="pa-4 d-flex flex-column align-center justify-center"
                  Style="border-style: dashed; border-width: 2px; cursor: pointer;
                         border-color: var(--mud-palette-secondary); position: relative;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.CameraAlt" Color="Color.Secondary" />
                <MudText Typo="Typo.body1">Take a Photo</MudText>
            </MudStack>
            <InputFile OnChange="HandleFilesSelected"
                       accept="image/*"
                       capture="environment"
                       style="opacity: 0; position: absolute; width: 100%; height: 100%; cursor: pointer; top: 0; left: 0;" />
        </MudPaper>

        @if (State.Attachments.Count > 0)
        {
            <MudStack Spacing="2">
                @foreach (var file in State.Attachments)
                {
                    <MudPaper Elevation="1" Class="pa-3">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@GetFileIcon(file.ContentType)" Color="Color.Primary" />
                            <MudStack Spacing="0" Style="flex: 1; min-width: 0;">
                                <MudText Typo="Typo.body2" Style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                    @file.FileName
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @FormatFileSize(file.SizeBytes)
                                </MudText>
                            </MudStack>

                            @if (!string.IsNullOrWhiteSpace(file.ErrorMessage))
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Text">
                                    Error
                                </MudChip>
                            }
                            else if (file.IsUploaded)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Text">
                                    Ready
                                </MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Text">
                                    Pending
                                </MudChip>
                            }

                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="() => RemoveFile(file)"
                                           aria-label="Remove file" />
                        </MudStack>
                    </MudPaper>
                }
            </MudStack>
        }

        @if (_fileErrors.Count > 0)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                <ul style="margin: 0; padding-left: 16px;">
                    @foreach (var error in _fileErrors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </MudAlert>
        }

        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="HandleBack"
                       Style="text-transform: none;">
                Back
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="HandleNext"
                       Style="text-transform: none;">
                Next
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnNext { get; set; }
    [Parameter, EditorRequired] public EventCallback OnBack { get; set; }

    private List<string> _fileErrors = [];

    private static readonly HashSet<string> AllowedMimeTypes =
    [
        "image/jpeg", "image/png", "image/gif", "image/webp", "image/heic",
        "video/mp4", "video/quicktime", "video/webm",
        "application/pdf"
    ];

    private string AcceptedTypes => State.Config?.AcceptedFileTypes is { Count: > 0 } types
        ? string.Join(",", types)
        : "image/*,video/*,application/pdf";

    private int MaxAttachments => State.Config?.MaxAttachments ?? 10;
    private int MaxFileSizeMb => State.Config?.MaxFileSizeMb ?? 25;

    private void HandleFilesSelected(InputFileChangeEventArgs e)
    {
        _fileErrors = [];

        var remainingSlots = MaxAttachments - State.Attachments.Count;
        if (remainingSlots <= 0)
        {
            _fileErrors.Add($"Maximum {MaxAttachments} files allowed.");
            return;
        }

        var files = e.GetMultipleFiles(MaxAttachments);

        foreach (var file in files.Take(remainingSlots))
        {
            if (file.Size > MaxFileSizeMb * 1024L * 1024L)
            {
                _fileErrors.Add($"{file.Name}: exceeds {MaxFileSizeMb} MB limit.");
                continue;
            }

            if (!AllowedMimeTypes.Contains(file.ContentType))
            {
                _fileErrors.Add($"{file.Name}: file type '{file.ContentType}' is not supported.");
                continue;
            }

            State.Attachments.Add(new AttachmentFileInfo
            {
                FileName = file.Name,
                ContentType = file.ContentType,
                SizeBytes = file.Size,
                BrowserFile = file
            });
        }

        if (files.Count > remainingSlots)
        {
            _fileErrors.Add($"Only {remainingSlots} more file(s) can be added.");
        }

        StateHasChanged();
    }

    private void RemoveFile(AttachmentFileInfo file)
    {
        State.Attachments.Remove(file);
        _fileErrors = [];
        StateHasChanged();
    }

    private static string GetFileIcon(string contentType)
    {
        if (contentType.StartsWith("image/")) return Icons.Material.Filled.Image;
        if (contentType.StartsWith("video/")) return Icons.Material.Filled.VideoFile;
        return Icons.Material.Filled.InsertDriveFile;
    }

    private static string FormatFileSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };

    private async Task HandleNext()
    {
        await State.NotifyAndPersistAsync();
        await OnNext.InvokeAsync();
    }

    private async Task HandleBack()
    {
        await OnBack.InvokeAsync();
    }
}
