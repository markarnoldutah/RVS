<MudPaper Elevation="2" Class="pa-6 rounded-lg wizard-step-card">
    <MudForm @ref="_form">
    <MudStack Spacing="4">
        <MudText Typo="Typo.h5" Class="mb-1" Style="color: var(--mud-palette-text-primary);">RV Lookup</MudText>

        @if (State.KnownAssets is { Count: > 0 })
        {
            <MudStack Spacing="1">
                <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Previously seen RVs</MudText>
                <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">
                    Select a previously seen RV or enter a new one below
                </MudText>
            </MudStack>

            <MudRadioGroup T="string" Value="@State.Vin" ValueChanged="HandleKnownAssetSelected"
                           InputStyle="display: flex; flex-direction: column; align-items: flex-start;">
                @foreach (var asset in State.KnownAssets)
                {
                    var label = FormatAssetLabel(asset);
                    <MudRadio T="string" Value="@asset.AssetId" Color="Color.Primary" Dense="true">
                        @label
                    </MudRadio>
                }
            </MudRadioGroup>

            <MudDivider Class="my-1" />
        }

        <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
            <MudStack Spacing="1">
                <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">VIN</MudText>
                <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Enter, speak, or snap a pic of your VIN</MudText>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                    <MudTextField T="string"
                                  Value="@State.Vin"
                                  ValueChanged="HandleVinChanged"
                                  Validation="@(new Func<string?, string?>(ValidateVin))"
                                  MaxLength="17"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="17-character VIN"
                                  Immediate="true"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_isRecording ? Icons.Material.Filled.MicOff : Icons.Material.Filled.Mic)"
                                  AdornmentColor="@(_isRecording ? Color.Error : Color.Primary)"
                                  OnAdornmentClick="ToggleVinRecording"
                                  Disabled="_isTranscribing"
                                  Style="max-width: 27ch;" />
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Outlined.CameraAlt"
                               Size="Size.Medium"
                               OnClick="TriggerCameraCapture"
                               Disabled="@(_isRecording || _isTranscribing)"
                               aria-label="Capture VIN with camera">
                        Camera
                    </MudButton>
                </MudStack>
                @if (_isRecording)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudProgressCircular Size="Size.Small" Color="Color.Error" Indeterminate="true" />
                        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Listening… tap mic to stop</MudText>
                    </MudStack>
                }
                @if (_isTranscribing)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudProgressCircular Size="Size.Small" Color="Color.Primary" Indeterminate="true" />
                        <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">Transcribing…</MudText>
                    </MudStack>
                }
                @if (_transcriptionError is not null)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Text" Dense="true">
                        <MudText Typo="Typo.body2">@_transcriptionError</MudText>
                    </MudAlert>
                }
            </MudStack>
        </MudPaper>

        @* Hidden camera input for native capture on mobile devices *@
        <InputFile @ref="_cameraInput"
                   accept="image/*"
                   capture="environment"
                   OnChange="HandleCameraCapture"
                   style="display: none;" />

        @if (_isExtracting && _capturedImageUrl is null)
        {
            <MudPaper Elevation="1" Class="pa-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                    <MudText Typo="Typo.body2">Processing image…</MudText>
                </MudStack>
            </MudPaper>
        }

        @if (_capturedImageUrl is not null)
        {
            <MudPaper Elevation="1" Class="pa-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <div style="position: relative; width: 48px; height: 48px; flex-shrink: 0;">
                        <img src="@_capturedImageUrl" alt="Captured VIN photo"
                             style="width: 48px; height: 48px; object-fit: cover; border-radius: 4px;" />
                        @if (_isExtracting)
                        {
                            <div style="position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.7); border-radius: 4px;">
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                            </div>
                        }
                    </div>
                    <MudStack Spacing="0" Style="flex: 1; min-width: 0;">
                        <MudText Typo="Typo.body2">
                            @(_isExtracting ? "Extracting VIN…" : "VIN photo captured")
                        </MudText>
                    </MudStack>
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Size="Size.Small"
                                   Disabled="_isExtracting"
                                   OnClick="ClearCapturedImage"
                                   aria-label="Remove captured photo" />
                </MudStack>
            </MudPaper>
        }

        @if (_extractionMessage is not null)
        {
            <MudAlert Severity="@_extractionSeverity" Variant="Variant.Outlined" Dense="true">
                <MudText Typo="Typo.body2">@_extractionMessage</MudText>
            </MudAlert>
        }

        @if (_lookupFailed)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="false"
                      Icon="@Icons.Material.Filled.ErrorOutline">
                <MudText Typo="Typo.body2">
                    We tried to retrieve your RV's information but could not. Are you sure the information is correct?
                </MudText>
            </MudAlert>
        }

        <MudStack Spacing="2" Class="mt-6">
            @if (_lookupFailed)
            {
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           FullWidth="true"
                           OnClick="HandleProceedAnyway"
                           Style="text-transform: none;">
                    Continue Anyway
                </MudButton>
            }
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Disabled="_isLookingUp"
                       OnClick="HandleLookup"
                       Style="text-transform: none;">
                @if (_isLookingUp)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    @:Looking up…
                }
                else if (_lookupFailed)
                {
                    @:Try Lookup Again
                }
                else
                {
                    @:Continue
                }
            </MudButton>
        </MudStack>
    </MudStack>
    </MudForm>
</MudPaper>

@code {
    private const long MaxCameraCaptureSizeBytes = 10 * 1024 * 1024;
    private const double VinAutoFillThreshold = 0.7;
    private const double VinAutoLookupThreshold = 0.9;

    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnNext { get; set; }
    [Inject] private IntakeApiClient IntakeApi { get; set; } = default!;
    [Inject] private IJSRuntime JsRuntime { get; set; } = default!;

    private MudForm _form = default!;
    private bool _submitted;
    private InputFile? _cameraInput;
    private string? _capturedImageUrl;
    private bool _isLookingUp;
    private bool _isExtracting;
    private bool _isRecording;
    private bool _isTranscribing;
    private bool _lookupFailed;
    private string? _extractionMessage;
    private string? _transcriptionError;
    private Severity _extractionSeverity = Severity.Info;

    private string? ValidateVin(string? value)
    {
        if (!_submitted) return null;
        if (string.IsNullOrWhiteSpace(value)) return "VIN is required";
        var result = ClientVinValidator.Validate(value);
        return result.IsValid ? null : result.ErrorMessage;
    }

    private void HandleVinChanged(string? value)
    {
        State.Vin = value?.Trim().ToUpperInvariant() ?? string.Empty;
        _lookupFailed = false;
    }

    private void HandleKnownAssetSelected(string? assetId)
    {
        if (string.IsNullOrWhiteSpace(assetId)) return;

        var asset = State.KnownAssets?.FirstOrDefault(a =>
            string.Equals(a.AssetId, assetId, StringComparison.OrdinalIgnoreCase));

        if (asset is null) return;

        SelectKnownAsset(asset);
    }

    private void SelectKnownAsset(AssetInfoDto asset)
    {
        State.Vin = asset.AssetId;
        State.Manufacturer = asset.Manufacturer;
        State.Model = asset.Model;
        State.Year = asset.Year;
        _lookupFailed = false;
        StateHasChanged();
    }

    private static string FormatAssetLabel(AssetInfoDto asset)
    {
        var parts = new List<string>();
        if (asset.Year.HasValue)
            parts.Add(asset.Year.Value.ToString());
        if (!string.IsNullOrWhiteSpace(asset.Manufacturer))
            parts.Add(asset.Manufacturer);
        if (!string.IsNullOrWhiteSpace(asset.Model))
            parts.Add(asset.Model);

        return parts.Count > 0 ? string.Join(" ", parts) : asset.AssetId;
    }

    private async Task TriggerCameraCapture()
    {
        if (_cameraInput?.Element is not null)
        {
            await JsRuntime.InvokeVoidAsync("rvs_triggerClick", _cameraInput.Element);
        }
    }

    private async Task ToggleVinRecording()
    {
        if (_isRecording)
        {
            _isRecording = false;
            _isTranscribing = true;
            _transcriptionError = null;
            StateHasChanged();

            try
            {
                var recording = await JsRuntime.InvokeAsync<AudioRecordingResult?>("rvs_stopRecording");
                if (recording is null || string.IsNullOrWhiteSpace(recording.Audio))
                {
                    _transcriptionError = "No audio was captured.";
                    return;
                }

                var request = new IssueTranscriptionRequestDto
                {
                    AudioBase64 = recording.Audio,
                    ContentType = recording.MimeType
                };

                var result = await IntakeApi.TranscribeIssueAsync(State.Slug, request);
                if (result?.Result?.RawTranscript is not null)
                {
                    var vin = VinTranscriptCleaner.Clean(result.Result.RawTranscript);
                    if (!string.IsNullOrEmpty(vin))
                    {
                        HandleVinChanged(vin);
                    }
                    else
                    {
                        _transcriptionError = "Could not recognize a VIN from the audio. Please try again or type it manually.";
                    }
                }
                else
                {
                    _transcriptionError = "Could not transcribe the audio. Please try again or type it manually.";
                }
            }
            catch (Exception)
            {
                _transcriptionError = "Transcription failed. Please try again or type the VIN manually.";
            }
            finally
            {
                _isTranscribing = false;
                StateHasChanged();
            }
        }
        else
        {
            _transcriptionError = null;
            try
            {
                await JsRuntime.InvokeVoidAsync("rvs_startRecording");
                _isRecording = true;
            }
            catch (Exception)
            {
                _transcriptionError = "Microphone access was denied or is unavailable.";
            }
        }
    }

    private async Task HandleCameraCapture(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;

        _extractionMessage = null;
        _isExtracting = true;
        StateHasChanged();

        var buffer = new byte[file.Size];
        await using var stream = file.OpenReadStream(maxAllowedSize: MaxCameraCaptureSizeBytes);
        _ = await stream.ReadAsync(buffer);
        var base64 = Convert.ToBase64String(buffer);
        _capturedImageUrl = $"data:{file.ContentType};base64,{base64}";
        StateHasChanged();

        try
        {
            var request = new VinExtractionRequestDto
            {
                ImageBase64 = base64,
                ContentType = file.ContentType
            };

            var response = await IntakeApi.ExtractVinFromImageAsync(State.Slug, request);

            if (response is { Success: true, Result.Vin: { } vin } && response.Confidence >= VinAutoFillThreshold)
            {
                HandleVinChanged(vin);
                _extractionMessage = $"VIN extracted from photo: {vin}";
                _extractionSeverity = Severity.Success;

                if (response.Confidence >= VinAutoLookupThreshold)
                {
                    StateHasChanged();
                    await Task.Yield();
                    await HandleLookup();
                    return;
                }
            }
            else
            {
                _extractionMessage = "We couldn't read the VIN from the photo. Please enter it manually.";
                _extractionSeverity = Severity.Info;
            }
        }
        catch (Exception ex) when (ex is HttpRequestException or TaskCanceledException)
        {
            _extractionMessage = "We couldn't read the VIN from the photo. Please enter it manually.";
            _extractionSeverity = Severity.Info;
        }
        finally
        {
            _isExtracting = false;
            StateHasChanged();
        }
    }

    private void ClearCapturedImage()
    {
        _capturedImageUrl = null;
        _extractionMessage = null;
    }

    private async Task HandleLookup()
    {
        _lookupFailed = false;

        _submitted = true;
        await _form.Validate();
        if (!_form.IsValid) return;

        _isLookingUp = true;
        StateHasChanged();

        try
        {
            var decoded = await IntakeApi.DecodeVinAsync(State.Slug, State.Vin);
            if (decoded is not null)
            {
                State.Manufacturer = decoded.Manufacturer;
                State.Model = decoded.Model;
                State.Year = decoded.Year;
                State.VinLookupSucceeded = true;
                await State.NotifyAndPersistAsync();
                await OnNext.InvokeAsync();
            }
            else
            {
                _lookupFailed = true;
            }
        }
        catch (HttpRequestException)
        {
            _lookupFailed = true;
        }
        catch (TaskCanceledException)
        {
            _lookupFailed = true;
        }
        finally
        {
            _isLookingUp = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Advances to the next step without a successful VIN decode,
    /// allowing the user to enter vehicle details manually.
    /// </summary>
    private async Task HandleProceedAnyway()
    {
        await State.NotifyAndPersistAsync();
        await OnNext.InvokeAsync();
    }

    /// <summary>
    /// Mirrors the JS object returned by rvs_stopRecording: { audio, mimeType }.
    /// </summary>
    private sealed record AudioRecordingResult(string? Audio, string MimeType);
}
