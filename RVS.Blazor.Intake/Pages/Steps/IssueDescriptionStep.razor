<MudPaper Elevation="3" Class="pa-6" Style="width: 100%;">
    <MudStack Spacing="4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" />
            <MudText Typo="Typo.h5">Describe the Issue</MudText>
        </MudStack>

        @if (_categories.Count > 0)
        {
            <MudSelect T="string"
                       @bind-Value="State.IssueCategory"
                       Label="Issue Category"
                       Required="true"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter"
                       AdornmentIcon="@Icons.Material.Filled.Category"
                       Error="@State.FieldErrors.ContainsKey("IssueCategory")"
                       ErrorText="@State.FieldErrors.GetValueOrDefault("IssueCategory")">
                @foreach (var category in _categories)
                {
                    <MudSelectItem T="string" Value="@category.Code">@category.Name</MudSelectItem>
                }
            </MudSelect>
        }
        else
        {
            <MudSelect T="string"
                       @bind-Value="State.IssueCategory"
                       Label="Issue Category"
                       Required="true"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter"
                       AdornmentIcon="@Icons.Material.Filled.Category"
                       Error="@State.FieldErrors.ContainsKey("IssueCategory")"
                       ErrorText="@State.FieldErrors.GetValueOrDefault("IssueCategory")">
                <MudSelectItem T="string" Value="@("Electrical")">Electrical</MudSelectItem>
                <MudSelectItem T="string" Value="@("Plumbing")">Plumbing</MudSelectItem>
                <MudSelectItem T="string" Value="@("HVAC")">HVAC / Climate Control</MudSelectItem>
                <MudSelectItem T="string" Value="@("Appliance")">Appliance</MudSelectItem>
                <MudSelectItem T="string" Value="@("Structural")">Structural / Body</MudSelectItem>
                <MudSelectItem T="string" Value="@("Slide-Out")">Slide-Out</MudSelectItem>
                <MudSelectItem T="string" Value="@("Awning")">Awning</MudSelectItem>
                <MudSelectItem T="string" Value="@("Other")">Other</MudSelectItem>
            </MudSelect>
        }

        <div>
            <MudTextField @bind-Value="State.IssueDescription"
                          Label="Description"
                          Required="true"
                          Lines="5"
                          MaxLength="2000"
                          Counter="2000"
                          Variant="Variant.Outlined"
                          Placeholder="e.g., The slide-out makes a grinding noise when retracting and stops halfway."
                          HelperText="Describe what's happening so our technicians can prepare before your visit."
                          Error="@State.FieldErrors.ContainsKey("IssueDescription")"
                          ErrorText="@State.FieldErrors.GetValueOrDefault("IssueDescription")" />
        </div>

        @* Urgency — button toggle group *@
        <div>
            <MudText Typo="Typo.body2" Class="mb-2">Urgency</MudText>
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                @foreach (var option in _urgencyOptions)
                {
                    var isSelected = State.Urgency == option.Value;
                    <MudButton Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                               Color="@(isSelected ? option.Color : Color.Default)"
                               Size="Size.Small"
                               StartIcon="@option.Icon"
                               OnClick="() => SelectUrgency(option.Value)"
                               Style="text-transform: none;">
                        @option.Value
                    </MudButton>
                }
            </MudStack>
        </div>

        @* RV Usage — button toggle group *@
        <div>
            <MudText Typo="Typo.body2" Class="mb-2">RV Usage</MudText>
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                @foreach (var usage in _rvUsageOptions)
                {
                    var isSelected = State.RvUsage == usage;
                    <MudButton Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                               Color="@(isSelected ? Color.Primary : Color.Default)"
                               Size="Size.Small"
                               OnClick="() => SelectRvUsage(usage)"
                               Style="text-transform: none;">
                        @if (isSelected)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Class="mr-1" />
                        }
                        @usage
                    </MudButton>
                }
            </MudStack>
        </div>

        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="HandleBack"
                       Style="text-transform: none;">
                Back
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="HandleNext"
                       Style="text-transform: none;">
                @(State.EditingFromReview ? "Save & Return to Review" : "Continue to Diagnostic Questions")
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnNext { get; set; }
    [Parameter, EditorRequired] public EventCallback OnBack { get; set; }

    private List<LookupItemDto> _categories = [];

    private static readonly (string Value, string Icon, Color Color)[] _urgencyOptions =
    [
        ("Low", Icons.Material.Filled.ArrowDownward, Color.Success),
        ("Medium", Icons.Material.Filled.Remove, Color.Info),
        ("High", Icons.Material.Filled.ArrowUpward, Color.Warning),
        ("Critical", Icons.Material.Filled.Warning, Color.Error),
    ];

    private static readonly string[] _rvUsageOptions =
        ["Full-Time", "Part-Time", "Seasonal", "Occasional"];

    protected override void OnInitialized()
    {
        if (State.Config?.IssueCategories is { Count: > 0 } categories)
        {
            _categories = categories.Where(c => c.IsSelectable).ToList();
        }
    }

    private void SelectUrgency(string value)
    {
        State.Urgency = ToggleSelection(State.Urgency, value);
        StateHasChanged();
    }

    private void SelectRvUsage(string value)
    {
        State.RvUsage = ToggleSelection(State.RvUsage, value);
        StateHasChanged();
    }

    private static string? ToggleSelection(string? current, string value) =>
        current == value ? null : value;

    private async Task HandleNext()
    {
        await State.NotifyAndPersistAsync();
        await OnNext.InvokeAsync();
    }

    private async Task HandleBack()
    {
        await OnBack.InvokeAsync();
    }
}
