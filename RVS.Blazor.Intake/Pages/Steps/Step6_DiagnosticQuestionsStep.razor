<MudPaper Elevation="3" Class="pa-6" Style="width: 100%;">
    <MudStack Spacing="4">
        <MudText Typo="Typo.h4">Diagnostics</MudText>

        @if (_isLoading)
        {
            <MudStack Spacing="3" aria-busy="true" aria-label="Generating diagnostic questions">
                <MudSkeleton SkeletonType="SkeletonType.Text" Width="80%" />
                @for (var i = 0; i < 3; i++)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="100px" />
                }
            </MudStack>
        }
        else if (_error is not null)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                @_error You can skip this step and continue.
            </MudAlert>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(State.SmartSuggestion))
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true"
                          Icon="@Icons.Material.Filled.Lightbulb">
                    <strong>Suggestion:</strong> @State.SmartSuggestion
                </MudAlert>
            }

            @for (var i = 0; i < State.DiagnosticQuestions.Count; i++)
            {
                var question = State.DiagnosticQuestions[i];
                var questionIndex = i;

                <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 500;">
                            @question.QuestionText
                        </MudText>

                        @if (!string.IsNullOrWhiteSpace(question.HelpText))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @question.HelpText
                            </MudText>
                        }

                        @if (question.Options.Count > 0)
                        {
                            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                                @foreach (var option in question.Options)
                                {
                                    var opt = option;
                                    var isSelected = GetResponse(questionIndex)?.SelectedOptions.Contains(opt) == true;
                                    <MudButton Variant="@(isSelected ? Variant.Filled : Variant.Outlined)"
                                               Color="@(isSelected ? Color.Primary : Color.Default)"
                                               Size="Size.Small"
                                               OnClick="() => ToggleOption(questionIndex, opt)"
                                               Style="text-transform: none;">
                                        @if (isSelected)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small"
                                                     Class="mr-1" />
                                        }
                                        @opt
                                    </MudButton>
                                }
                            </MudStack>
                        }

                        @if (question.AllowFreeText)
                        {
                            <MudTextField Value="@(GetResponse(questionIndex)?.FreeTextResponse ?? "")"
                                          ValueChanged="(string value) => SetFreeText(questionIndex, value)"
                                          Placeholder="Additional details..."
                                          Lines="2"
                                          Variant="Variant.Outlined" />
                        }
                    </MudStack>
                </MudPaper>
            }
        }

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   OnClick="HandleNext"
                   Disabled="_isLoading"
                   Style="text-transform: none;"
                   Class="mt-2">
            @(_isLoading ? "Loading..." : "Continue...")
        </MudButton>
        <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary">
            Step @State.CurrentStep of @State.TotalSteps
        </MudText>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnNext { get; set; }
    [Inject] private IntakeApiClient IntakeApi { get; set; } = default!;

    private bool _isLoading;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (State.DiagnosticQuestions.Count > 0) return;

        _isLoading = true;
        try
        {
            var request = State.BuildCreateRequest();
            var response = await IntakeApi.GetDiagnosticQuestionsAsync(State.Slug, request);

            State.DiagnosticQuestions = response.Questions;
            State.SmartSuggestion = response.SmartSuggestion;

            State.DiagnosticResponses = response.Questions.Select(q => new DiagnosticResponseDto
            {
                QuestionText = q.QuestionText,
                SelectedOptions = [],
                FreeTextResponse = null
            }).ToList();
        }
        catch (Exception)
        {
            _error = "Unable to generate diagnostic questions.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private DiagnosticResponseDto? GetResponse(int index)
    {
        return index < State.DiagnosticResponses.Count ? State.DiagnosticResponses[index] : null;
    }

    private void ToggleOption(int questionIndex, string option)
    {
        if (questionIndex >= State.DiagnosticResponses.Count) return;

        var response = State.DiagnosticResponses[questionIndex];
        var options = response.SelectedOptions.ToList();

        if (options.Contains(option))
            options.Remove(option);
        else
            options.Add(option);

        State.DiagnosticResponses[questionIndex] = response with { SelectedOptions = options };
        StateHasChanged();
    }

    private void SetFreeText(int questionIndex, string? value)
    {
        if (questionIndex >= State.DiagnosticResponses.Count) return;

        var response = State.DiagnosticResponses[questionIndex];
        State.DiagnosticResponses[questionIndex] = response with { FreeTextResponse = value };
    }

    private async Task HandleNext()
    {
        await State.NotifyAndPersistAsync();
        await OnNext.InvokeAsync();
    }
}
