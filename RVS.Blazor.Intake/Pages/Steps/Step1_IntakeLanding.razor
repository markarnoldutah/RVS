<MudPaper Elevation="2" Class="pa-6 rounded-lg wizard-step-card">
    @if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="5"
                  aria-busy="true" aria-label="Loading location information">
            <MudSkeleton SkeletonType="SkeletonType.Circle" Width="64px" Height="64px" />
            <MudSkeleton SkeletonType="SkeletonType.Text" Width="60%" />
            <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" />
            <MudSkeleton SkeletonType="SkeletonType.Text" Width="80%" />
            <MudDivider Style="width: 100%;" />
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Width="300px" Height="44px" />
        </MudStack>
    }
    else if (_error is not null)
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="4">
            <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error"
                     Style="font-size: 4rem;" />
            <MudText Typo="Typo.h5" Color="Color.Error" Align="Align.Center">
                Location Not Found
            </MudText>
            <MudText Typo="Typo.body1" Align="Align.Center"
                     Style="color: var(--mud-palette-text-secondary);">
                @_error
            </MudText>
        </MudStack>
    }
    else if (State.Config is not null)
    {
        <MudStack AlignItems="AlignItems.Center" Spacing="5">
            @if (State.Config.TokenExpired)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mb-2" Style="width: 100%;"
                          Icon="@Icons.Material.Filled.Schedule">
                    Your link has expired. You can still submit a service request below, but your information won't be pre-filled.
                    Contact the dealership if you need a new link.
                </MudAlert>
            }

            <MudIcon Icon="@Icons.Material.Filled.RvHookup" Color="Color.Primary"
                     Style="font-size: 4rem;" />

            <MudText Typo="Typo.h5" Align="Align.Center" Style="color: var(--mud-palette-text-primary);">
                Start a Service Request<br />
                with
            </MudText>

            <MudText Typo="Typo.h6" Align="Align.Center"
                     Style="color: var(--mud-palette-text-secondary);">
                @State.Config.LocationName
            </MudText>

            <MudDivider Class="my-2" Style="width: 100%;" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       FullWidth="true"
                       OnClick="HandleStart"
                       Style="text-transform: none;">
                Continue
            </MudButton>
        </MudStack>
    }
</MudPaper>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnStart { get; set; }
    [Inject] private IntakeApiClient IntakeApi { get; set; } = default!;

    private bool _isLoading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        if (State.Config is not null)
        {
            _isLoading = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(State.Slug))
        {
            _error = "Location not specified. Please use a valid intake link.";
            _isLoading = false;
            return;
        }

        try
        {
            State.Config = await IntakeApi.GetConfigAsync(State.Slug, State.Token);

            if (State.Config.PrefillCustomer is not null)
            {
                State.ApplyPrefill(State.Config.PrefillCustomer);
            }

            if (State.Config.PrefillAsset is not null)
            {
                State.ApplyAssetPrefill(State.Config.PrefillAsset);
            }

            if (State.Config.KnownAssets is { Count: > 0 })
            {
                State.KnownAssets = State.Config.KnownAssets;
            }
        }
        catch (HttpRequestException)
        {
            _error = "Unable to find this service location. Please check the URL and try again.";
        }
        catch (InvalidOperationException)
        {
            _error = "Unable to load location configuration. Please try again later.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleStart()
    {
        await OnStart.InvokeAsync();
    }
}
