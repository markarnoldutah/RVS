<MudPaper Elevation="3" Class="pa-6" Style="width: 100%;">
    <MudStack Spacing="4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" />
            <MudText Typo="Typo.h5">Review &amp; Submit</MudText>
        </MudStack>

        <MudText Typo="Typo.body1" Color="Color.Secondary">
            Please review your information before submitting.
        </MudText>

        <MudExpansionPanels MultiExpansion="true">
            @* Contact Information *@
            <MudExpansionPanel Expanded="true">
                <TitleContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.subtitle1"><strong>Contact Information</strong></MudText>
                        <MudSpacer />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="() => EditStep(2)"
                                       aria-label="Edit contact info" />
                    </MudStack>
                </TitleContent>
                <ChildContent>
                    <MudSimpleTable Dense="true" Elevation="0">
                        <tbody>
                            <tr><td><strong>Name</strong></td><td>@State.FirstName @State.LastName</td></tr>
                            <tr><td><strong>Email</strong></td><td>@State.Email</td></tr>
                            @if (!string.IsNullOrWhiteSpace(State.Phone))
                            {
                                <tr><td><strong>Phone</strong></td><td>@State.Phone</td></tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </ChildContent>
            </MudExpansionPanel>

            @* Vehicle Information *@
            <MudExpansionPanel Expanded="true">
                <TitleContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.DirectionsCarFilled" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.subtitle1"><strong>Vehicle Information</strong></MudText>
                        <MudSpacer />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="() => EditStep(3)"
                                       aria-label="Edit vehicle info" />
                    </MudStack>
                </TitleContent>
                <ChildContent>
                    <MudSimpleTable Dense="true" Elevation="0">
                        <tbody>
                            <tr><td><strong>VIN</strong></td><td>@State.Vin</td></tr>
                            @if (!string.IsNullOrWhiteSpace(State.Manufacturer))
                            {
                                <tr><td><strong>Manufacturer</strong></td><td>@State.Manufacturer</td></tr>
                            }
                            @if (!string.IsNullOrWhiteSpace(State.Model))
                            {
                                <tr><td><strong>Model</strong></td><td>@State.Model</td></tr>
                            }
                            @if (State.Year.HasValue)
                            {
                                <tr><td><strong>Year</strong></td><td>@State.Year</td></tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </ChildContent>
            </MudExpansionPanel>

            @* Issue Details *@
            <MudExpansionPanel Expanded="true">
                <TitleContent>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.subtitle1"><strong>Issue Details</strong></MudText>
                        <MudSpacer />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="() => EditStep(5)"
                                       aria-label="Edit issue details" />
                    </MudStack>
                </TitleContent>
                <ChildContent>
                    <MudSimpleTable Dense="true" Elevation="0">
                        <tbody>
                            <tr><td><strong>Category</strong></td><td>@State.IssueCategory</td></tr>
                            <tr><td><strong>Description</strong></td><td>@State.IssueDescription</td></tr>
                            @if (!string.IsNullOrWhiteSpace(State.Urgency))
                            {
                                <tr><td><strong>Urgency</strong></td><td>@State.Urgency</td></tr>
                            }
                            @if (!string.IsNullOrWhiteSpace(State.RvUsage))
                            {
                                <tr><td><strong>RV Usage</strong></td><td>@State.RvUsage</td></tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </ChildContent>
            </MudExpansionPanel>

            @* Diagnostic Responses *@
            @if (State.DiagnosticResponses.Count > 0)
            {
                <MudExpansionPanel Expanded="true">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Psychology" Color="Color.Primary" Size="Size.Small" />
                            <MudText Typo="Typo.subtitle1"><strong>Diagnostic Responses</strong></MudText>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="() => EditStep(6)"
                                           aria-label="Edit diagnostic responses" />
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Spacing="3">
                            @foreach (var response in State.DiagnosticResponses)
                            {
                                <div>
                                    <MudText Typo="Typo.body2" Style="font-weight: 500;">
                                        @response.QuestionText
                                    </MudText>
                                    @if (response.SelectedOptions.Count > 0)
                                    {
                                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-1">
                                            @foreach (var option in response.SelectedOptions)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                                         Variant="Variant.Outlined">
                                                    @option
                                                </MudChip>
                                            }
                                        </MudStack>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(response.FreeTextResponse))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                            @response.FreeTextResponse
                                        </MudText>
                                    }
                                </div>
                            }
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>
            }

            @* Attachments *@
            @if (State.Attachments.Count > 0)
            {
                <MudExpansionPanel Expanded="true">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.AttachFile" Color="Color.Primary" Size="Size.Small" />
                            <MudText Typo="Typo.subtitle1">
                                <strong>Attachments (@State.Attachments.Count)</strong>
                            </MudText>
                            <MudSpacer />
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="() => EditStep(7)"
                                           aria-label="Edit attachments" />
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudStack Spacing="1">
                            @foreach (var attachment in State.Attachments)
                            {
                                <MudText Typo="Typo.body2">
                                    📎 @attachment.FileName (@FormatFileSize(attachment.SizeBytes))
                                </MudText>
                            }
                        </MudStack>
                    </ChildContent>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>

        @* Submit error *@
        @if (_submitError is not null)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" role="alert">
                @_submitError
            </MudAlert>
        }

        @* Upload progress *@
        @if (_uploadStatus is not null)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Medium" />
                <MudText Typo="Typo.body2" Color="Color.Secondary">@_uploadStatus</MudText>
            </MudStack>
        }

        @* Submit button *@
        <MudStack AlignItems="AlignItems.Center" Class="mt-4">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.Send"
                       Disabled="_isSubmitting"
                       OnClick="HandleSubmit"
                       Style="text-transform: none; min-width: 250px;">
                @(_isSubmitting ? "Submitting..." : "Submit Service Request")
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback<int> OnEdit { get; set; }
    [Parameter, EditorRequired] public EventCallback OnSubmitted { get; set; }
    [Inject] private IntakeApiClient IntakeApi { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;

    private const long MaxUploadSizeBytes = 25 * 1024 * 1024;

    private bool _isSubmitting;
    private string? _submitError;
    private string? _uploadStatus;

    private async Task EditStep(int step)
    {
        await OnEdit.InvokeAsync(step);
    }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _submitError = null;
        _uploadStatus = null;
        StateHasChanged();

        try
        {
            var request = State.BuildCreateRequest();
            var result = await IntakeApi.SubmitServiceRequestAsync(State.Slug, request);

            State.IsSubmitted = true;
            State.CreatedServiceRequestId = result.Id;
            await State.PersistAsync();

            var pendingFiles = State.Attachments
                .Where(a => a.BrowserFile is not null && !a.IsUploaded)
                .ToList();

            if (pendingFiles.Count > 0)
            {
                _uploadStatus = $"Uploading attachments (0/{pendingFiles.Count})…";
                StateHasChanged();

                for (var i = 0; i < pendingFiles.Count; i++)
                {
                    var file = pendingFiles[i];
                    _uploadStatus = $"Uploading attachments ({i + 1}/{pendingFiles.Count})…";
                    StateHasChanged();

                    try
                    {
                        var sasResponse = await IntakeApi.GetUploadSasAsync(
                            State.Slug, result.Id, file.FileName, file.ContentType);

                        file.BlobName = sasResponse.BlobName;

                        await using var stream = file.BrowserFile!.OpenReadStream(maxAllowedSize: MaxUploadSizeBytes);
                        using var content = new StreamContent(stream);
                        content.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);

                        using var sasRequest = new HttpRequestMessage(HttpMethod.Put, sasResponse.SasUrl);
                        sasRequest.Content = content;
                        sasRequest.Headers.Add("x-ms-blob-type", "BlockBlob");

                        var sasResult = await Http.SendAsync(sasRequest);
                        sasResult.EnsureSuccessStatusCode();

                        await IntakeApi.ConfirmUploadAsync(State.Slug, result.Id, new AttachmentConfirmRequestDto
                        {
                            BlobName = sasResponse.BlobName,
                            FileName = file.FileName,
                            ContentType = file.ContentType,
                            SizeBytes = file.SizeBytes
                        });

                        file.IsUploaded = true;
                    }
                    catch (Exception ex)
                    {
                        file.ErrorMessage = $"Upload failed: {ex.Message}";
                    }
                }

                _uploadStatus = null;
            }

            await OnSubmitted.InvokeAsync();
        }
        catch (HttpRequestException ex)
        {
            _submitError = $"Unable to submit your request. Please try again. ({ex.StatusCode})";
        }
        catch (Exception)
        {
            _submitError = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private static string FormatFileSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };
}
