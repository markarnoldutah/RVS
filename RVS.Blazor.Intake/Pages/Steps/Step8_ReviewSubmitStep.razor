<MudPaper Elevation="2" Class="pa-6 rounded-lg wizard-step-card">
    <MudStack Spacing="4">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h5" Style="color: var(--mud-palette-text-primary);">Review &amp; Submit</MudText>
            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">
                Please review your information before submitting.
            </MudText>
        </MudStack>

        @* Contact Information *@
        <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.h6" Style="color: var(--mud-palette-text-primary);">Contact Information</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="() => EditStep(2)"
                               Style="text-transform: none;">Edit</MudButton>
                </MudStack>
                <MudSimpleTable Elevation="0" Class="review-table">
                    <tbody>
                        <tr><td><strong>Name</strong></td><td>@State.FirstName @State.LastName</td></tr>
                        <tr><td><strong>Email</strong></td><td>@State.Email</td></tr>
                        @if (!string.IsNullOrWhiteSpace(State.Phone))
                        {
                            <tr><td><strong>Phone</strong></td><td>@State.Phone</td></tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudStack>
        </MudPaper>

        @* Vehicle Information *@
        <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.h6" Style="color: var(--mud-palette-text-primary);">Vehicle Information</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="() => EditStep(3)"
                               Style="text-transform: none;">Edit</MudButton>
                </MudStack>
                <MudSimpleTable Elevation="0" Class="review-table">
                    <tbody>
                        <tr><td><strong>VIN</strong></td><td>@State.Vin</td></tr>
                        @if (!string.IsNullOrWhiteSpace(State.Manufacturer))
                        {
                            <tr><td><strong>Manufacturer</strong></td><td>@State.Manufacturer</td></tr>
                        }
                        @if (!string.IsNullOrWhiteSpace(State.Model))
                        {
                            <tr><td><strong>Model</strong></td><td>@State.Model</td></tr>
                        }
                        @if (State.Year.HasValue)
                        {
                            <tr><td><strong>Year</strong></td><td>@State.Year</td></tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudStack>
        </MudPaper>

        @* Issue Details *@
        <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
            <MudStack Spacing="2">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.h6" Style="color: var(--mud-palette-text-primary);">Issue Details</MudText>
                    <MudSpacer />
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Edit"
                               OnClick="() => EditStep(5)"
                               Style="text-transform: none;">Edit</MudButton>
                </MudStack>
                <MudSimpleTable Elevation="0" Class="review-table">
                    <tbody>
                        <tr><td><strong>Category</strong></td><td>@State.IssueCategory</td></tr>
                        <tr><td><strong>Description</strong></td><td style="white-space: pre-wrap;">@State.IssueDescription</td></tr>
                        @if (!string.IsNullOrWhiteSpace(State.Urgency))
                        {
                            <tr><td><strong>Urgency</strong></td><td>@State.Urgency</td></tr>
                        }
                        @if (!string.IsNullOrWhiteSpace(State.RvUsage))
                        {
                            <tr><td><strong>RV Usage</strong></td><td>@State.RvUsage</td></tr>
                        }
                        @if (!string.IsNullOrWhiteSpace(State.HasExtendedWarranty))
                        {
                            <tr><td><strong>Extended Warranty</strong></td><td>@State.HasExtendedWarranty</td></tr>
                        }
                        @if (!string.IsNullOrWhiteSpace(State.ApproxPurchaseDate))
                        {
                            <tr><td><strong>Approx. Purchase Date</strong></td><td>@State.ApproxPurchaseDate</td></tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudStack>
        </MudPaper>

        @* Diagnostic Responses *@
        @if (State.DiagnosticResponses.Count > 0)
        {
            <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.h6" Style="color: var(--mud-palette-text-primary);">Diagnostic Responses</MudText>
                        <MudSpacer />
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick="() => EditStep(6)"
                                   Style="text-transform: none;">Edit</MudButton>
                    </MudStack>
                    <MudStack Spacing="3">
                        @foreach (var response in State.DiagnosticResponses)
                        {
                            <div>
                                <MudText Typo="Typo.body1" Style="font-weight: 500;">
                                    @response.QuestionText
                                </MudText>
                                @if (response.SelectedOptions.Count > 0)
                                {
                                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mt-1">
                                        @foreach (var option in response.SelectedOptions)
                                        {
                                            <MudChip T="string" Color="Color.Primary"
                                                     Variant="Variant.Outlined">
                                                @option
                                            </MudChip>
                                        }
                                    </MudStack>
                                }
                                @if (!string.IsNullOrWhiteSpace(response.FreeTextResponse))
                                {
                                    <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);" Class="mt-1">
                                        @response.FreeTextResponse
                                    </MudText>
                                }
                            </div>
                        }
                    </MudStack>
                </MudStack>
            </MudPaper>
        }

        @* Attachments *@
        @if (State.Attachments.Count > 0)
        {
            <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudText Typo="Typo.h6" Style="color: var(--mud-palette-text-primary);">
                            Attachments (@State.Attachments.Count)
                        </MudText>
                        <MudSpacer />
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick="() => EditStep(7)"
                                   Style="text-transform: none;">Edit</MudButton>
                    </MudStack>
                    <MudStack Spacing="1">
                        @foreach (var attachment in State.Attachments)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@Icons.Material.Filled.Save" Size="Size.Small" Color="Color.Default" />
                                <MudText Typo="Typo.body1">
                                    @attachment.FileName (@FormatFileSize(attachment.SizeBytes))
                                </MudText>
                            </MudStack>
                        }
                    </MudStack>
                </MudStack>
            </MudPaper>
        }

        @* Submit error *@
        @if (_submitError is not null)
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Filled" role="alert">
                @_submitError
            </MudAlert>
        }

        @* Upload progress *@
        @if (_uploadProgress is not null)
        {
            <MudStack Spacing="1">
                <MudProgressLinear Color="Color.Primary"
                                   Value="@_uploadProgress.Value"
                                   Max="100"
                                   Rounded="true"
                                   Size="Size.Large"
                                   Class="my-2" />
                <MudText Typo="Typo.body2" Align="Align.Center"
                         Style="color: var(--mud-palette-text-secondary);">
                    @_uploadStatus
                </MudText>
            </MudStack>
        }

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   FullWidth="true"
                   Disabled="_isSubmitting"
                   OnClick="HandleSubmit"
                   Style="text-transform: none;"
                   Class="mt-6">
            @(_isSubmitting ? "Submitting..." : "Submit Service Request")
        </MudButton>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback<int> OnEdit { get; set; }
    [Parameter, EditorRequired] public EventCallback OnSubmitted { get; set; }
    [Inject] private IntakeApiClient IntakeApi { get; set; } = default!;
    [Inject] private HttpClient Http { get; set; } = default!;

    private bool _isSubmitting;
    private string? _submitError;
    private string? _uploadStatus;
    private double? _uploadProgress;

    private async Task EditStep(int step)
    {
        await OnEdit.InvokeAsync(step);
    }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _submitError = null;
        _uploadStatus = null;
        _uploadProgress = null;
        StateHasChanged();

        try
        {
            var request = State.BuildCreateRequest();
            var result = await IntakeApi.SubmitServiceRequestAsync(State.Slug, request);

            State.IsSubmitted = true;
            State.CreatedServiceRequestId = result.ServiceRequest.Id;
            State.SubmissionMagicLinkToken = result.MagicLinkToken;
            await State.PersistAsync();

            var pendingFiles = State.Attachments
                .Where(a => a.FileData is not null && !a.IsUploaded)
                .ToList();

            if (pendingFiles.Count > 0)
            {
                _uploadProgress = 0;
                _uploadStatus = $"Uploading attachments (0/{pendingFiles.Count})…";
                StateHasChanged();

                var failedUploadCount = 0;

                for (var i = 0; i < pendingFiles.Count; i++)
                {
                    var file = pendingFiles[i];
                    _uploadStatus = $"Uploading attachments ({i + 1}/{pendingFiles.Count})…";
                    _uploadProgress = (double)i / pendingFiles.Count * 100;
                    StateHasChanged();

                    try
                    {
                        var sasResponse = await IntakeApi.GetUploadSasAsync(
                            State.Slug, result.ServiceRequest.Id, file.FileName, file.ContentType);

                        file.BlobName = sasResponse.BlobName;

                        using var content = new ByteArrayContent(file.FileData!);
                        content.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);

                        using var sasRequest = new HttpRequestMessage(HttpMethod.Put, sasResponse.SasUrl);
                        sasRequest.Content = content;
                        sasRequest.Headers.Add("x-ms-blob-type", "BlockBlob");

                        var sasResult = await Http.SendAsync(sasRequest);
                        sasResult.EnsureSuccessStatusCode();

                        await IntakeApi.ConfirmUploadAsync(State.Slug, result.ServiceRequest.Id, new AttachmentConfirmRequestDto
                        {
                            BlobName = sasResponse.BlobName,
                            FileName = file.FileName,
                            ContentType = file.ContentType,
                            SizeBytes = file.SizeBytes
                        });

                        file.IsUploaded = true;
                    }
                    catch (Exception ex)
                    {
                        file.ErrorMessage = $"Upload failed: {ex.Message}";
                        failedUploadCount++;
                    }
                }

                _uploadProgress = 100;
                StateHasChanged();

                State.FailedUploadCount = failedUploadCount;
                _uploadStatus = null;
                _uploadProgress = null;
            }

            await OnSubmitted.InvokeAsync();
        }
        catch (HttpRequestException ex)
        {
            _submitError = $"Unable to submit your request. Please try again. ({ex.StatusCode})";
        }
        catch (Exception)
        {
            _submitError = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private static string FormatFileSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };
}
