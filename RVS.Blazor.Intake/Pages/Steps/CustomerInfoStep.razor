<MudPaper Elevation="3" Class="pa-6" Style="width: 100%;">
    <MudStack Spacing="4">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" />
            <MudText Typo="Typo.h5">Contact Information</MudText>
        </MudStack>

        @if (State.IsPrefilled)
        {
            <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true">
                Your information has been pre-filled from your previous visit.
            </MudAlert>
        }

        <MudTextField @bind-Value="State.FirstName"
                      Label="First Name"
                      Required="true"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Badge"
                      autocomplete="given-name"
                      Error="@State.FieldErrors.ContainsKey("FirstName")"
                      ErrorText="@State.FieldErrors.GetValueOrDefault("FirstName")" />

        <MudTextField @bind-Value="State.LastName"
                      Label="Last Name"
                      Required="true"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Badge"
                      autocomplete="family-name"
                      Error="@State.FieldErrors.ContainsKey("LastName")"
                      ErrorText="@State.FieldErrors.GetValueOrDefault("LastName")" />

        <MudTextField @bind-Value="State.Email"
                      Label="Email"
                      Required="true"
                      InputType="InputType.Email"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Email"
                      HelperText="We'll send your service request confirmation here."
                      autocomplete="email"
                      Error="@State.FieldErrors.ContainsKey("Email")"
                      ErrorText="@State.FieldErrors.GetValueOrDefault("Email")" />

        <MudTextField @bind-Value="State.Phone"
                      Label="Phone (optional)"
                      InputType="InputType.Telephone"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Phone"
                      HelperText="Optional — we'll only call to clarify your request."
                      autocomplete="tel" />

        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-2">
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="HandleBack"
                       Style="text-transform: none;">
                Back
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       EndIcon="@Icons.Material.Filled.ArrowForward"
                       OnClick="HandleNext"
                       Style="text-transform: none;">
                @(State.EditingFromReview ? "Save & Return to Review" : "Continue to VIN Lookup")
            </MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public IntakeWizardState State { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnNext { get; set; }
    [Parameter, EditorRequired] public EventCallback OnBack { get; set; }

    private async Task HandleNext()
    {
        await State.NotifyAndPersistAsync();
        await OnNext.InvokeAsync();
    }

    private async Task HandleBack()
    {
        await OnBack.InvokeAsync();
    }
}
