@page "/status"

<PageTitle>Check Request Status</PageTitle>

<MudStack AlignItems="AlignItems.Center" Class="mt-8">
    <MudPaper Elevation="2" Class="pa-6 rounded-lg" Style="width: 100%; max-width: 480px;">
        <MudStack Spacing="4">

            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Search" Color="Color.Primary"
                         Style="font-size: 3rem;" />
                <MudText Typo="Typo.h5" Align="Align.Center">
                    Check Request Status
                </MudText>
                <MudText Typo="Typo.body1" Align="Align.Center"
                         Style="color: var(--mud-palette-text-secondary);">
                    Enter your confirmation number to view the status of your service request.
                </MudText>
            </MudStack>

            <MudStack Spacing="1">
                <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">
                    Confirmation Number
                </MudText>
                <MudTextField @bind-Value="_confirmationNumber"
                              Placeholder="tIp-R0:3iAbwM7iJA5aqjGFxC2n5g"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Immediate="true"
                              autocomplete="off"
                              OnKeyDown="HandleKeyDown" />
            </MudStack>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Search"
                       OnClick="LookupStatus"
                       Disabled="@string.IsNullOrWhiteSpace(_confirmationNumber)"
                       Style="text-transform: none;">
                Look Up Status
            </MudButton>

        </MudStack>
    </MudPaper>
</MudStack>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private string _confirmationNumber = string.Empty;

    private void LookupStatus()
    {
        var token = _confirmationNumber.Trim();
        if (!string.IsNullOrWhiteSpace(token))
        {
            Navigation.NavigateTo($"/status/{Uri.EscapeDataString(token)}");
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            LookupStatus();
        }
    }
}
