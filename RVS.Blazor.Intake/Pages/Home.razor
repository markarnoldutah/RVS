@page "/"

<PageTitle>RV Service Flow — Customer Intake</PageTitle>
<MudPaper Elevation="1" Class="pa-4" Style="background: rgba(255, 255, 255, 0.85);">
<MudStack AlignItems="AlignItems.Center" Spacing="6" Class="mt-8">
    <MudIcon Icon="@Icons.Material.Filled.RvHookup" Color="Color.Primary" Size="Size.Large"
             Style="font-size: 4rem;" />


            <MudText Typo="Typo.h4" Align="Align.Center" Style="color: var(--mud-palette-text-primary);">
        RV Service Flow
    </MudText>



    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               Size="Size.Large"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/intake/blue-compass-slc"
               Style="text-transform: none; min-width: 250px;">
        New Service Request
    </MudButton>
    @* <MudDivider Class="my-4" Style="width: 300px;" /> *@



    <MudButton Variant="Variant.Filled"
               Color="Color.Info"
               Size="Size.Large"
               StartIcon="@Icons.Material.Filled.Search"
               Href="/status"
               Style="text-transform: none; min-width: 250px;">
        Check Status
    </MudButton>
</MudStack>
</MudPaper>