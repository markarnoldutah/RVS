@page "/confirmation"

<PageTitle>Request Submitted</PageTitle>

<MudStack AlignItems="AlignItems.Center" Class="mt-8">
    <MudPaper Elevation="2" Class="pa-6 rounded-lg" Style="width: 100%; max-width: 480px;">
        <MudStack AlignItems="AlignItems.Center" Spacing="4">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success"
                     Style="font-size: 4rem;" />

            <MudText Typo="Typo.h5" Align="Align.Center">
                Request Submitted Successfully
            </MudText>

            <MudText Typo="Typo.body1" Align="Align.Center"
                     Style="color: var(--mud-palette-text-secondary);">
                Your service request has been submitted. A service advisor will review your request
                and contact you to schedule service. You will receive a confirmation email shortly.
            </MudText>

            @if (UploadFailures > 0)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mt-2" Style="width: 100%;">
                    @(UploadFailures == 1
                        ? "1 attachment failed to upload. Please contact us if you need to resubmit your files."
                        : $"{UploadFailures} attachments failed to upload. Please contact us if you need to resubmit your files.")
                </MudAlert>
            }

            <MudDivider Style="width: 100%;" />

            <MudStack Spacing="2" Style="width: 100%;">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Search"
                           Href="/status"
                           Style="text-transform: none;">
                    Check Request Status
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Home"
                           Href="/"
                           Style="text-transform: none;">
                    Return Home
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    [SupplyParameterFromQuery(Name = "uploadFailures")]
    public int UploadFailures { get; set; }
}
