@page "/intake/{Slug}"
@implements IDisposable

<PageTitle>Service Request Intake — @(_state.Config?.LocationName ?? "Loading...")</PageTitle>

@if (_initializing)
{
    <MudStack AlignItems="AlignItems.Center" Class="mt-8">
        <MudPaper Elevation="2" Class="pa-6 rounded-lg wizard-step-card" Style="width: 100%; max-width: 700px;">
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">
                    Loading…
                </MudText>
            </MudStack>
        </MudPaper>
    </MudStack>
}
else
{
<MudStack AlignItems="AlignItems.Center" Spacing="4"
          Style="max-width: 700px; margin: 0 auto;">

    @* Header row — Back button (left) + step progress (right), visible on steps 2–8 *@
    @if (_state.CurrentStep > 1)
    {
        <MudPaper Elevation="1" Class="pa-2" Style="width: 100%;">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Text"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="HandlePreviousStep"
                           Style="text-transform: none;"
                           aria-label="Go back">
                    Back
                </MudButton>
                <MudSpacer />
                <MudText Typo="Typo.caption">
                    Step @_state.CurrentStep of @_state.TotalSteps
                </MudText>
            </MudStack>
        </MudPaper>
    }

    @* Wizard step content *@
    <div style="width: 100%;" @key="_state.CurrentStep" class="wizard-step">
        @switch (_state.CurrentStep)
        {
            case 1:
                <Step1_IntakeLanding State="_state"
                                     OnStart="HandleNextStep" />
                break;
            case 2:
                <Step2_CustomerInfoStep State="_state"
                                        OnNext="HandleNextStep" />
                break;
            case 3:
                <Step3_VinLookupStep State="_state"
                                     OnNext="HandleNextStep" />
                break;
            case 4:
                <Step4_VehicleDetailsStep State="_state"
                                          OnNext="HandleNextStep" />
                break;
            case 5:
                <Step5_IssueDescriptionStep State="_state"
                                            OnNext="HandleNextStep" />
                break;
            case 6:
                <Step6_DiagnosticQuestionsStep State="_state"
                                               OnNext="HandleNextStep" />
                break;
            case 7:
                <Step7_AttachmentUploadStep State="_state"
                                            OnNext="HandleNextStep" />
                break;
            case 8:
                <Step8_ReviewSubmitStep State="_state"
                                        OnEdit="HandleEditStep"
                                        OnSubmitted="HandleSubmitted" />
                break;
        }
    </div>
</MudStack>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    [SupplyParameterFromQuery(Name = "token")] public string? Token { get; set; }

    [Inject] private IntakeWizardState _state { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private List<string> _validationErrors = [];
    private bool _initializing = true;

    protected override async Task OnInitializedAsync()
    {
        _state.OnChange += StateHasChanged;
       _state.Slug = Slug;
       _state.Token = Token;

        await _state.RestoreAsync();

       // RestoreAsync may have overwritten Slug with a stale session value — correct it
       if (_state.Slug != Slug || _state.IsSubmitted)
        {
            await _state.ClearAsync();
            _state.Slug = Slug;
           _state.Token = Token;
        }

        _initializing = false;
    }

    protected override void OnParametersSet()
    {
        _state.Slug = Slug;
        _state.Token = Token;
    }

    private async Task HandleNextStep()
    {
        _validationErrors = _state.ValidateCurrentStep();
        if (_validationErrors.Count > 0)
        {
            StateHasChanged();
            return;
        }

        if (_state.ReturnToStepAfterEdit.HasValue)
        {
            _state.ReturnToStepAfterEdit = null;
            await _state.GoToStepAsync(8);
        }
        else
        {
            await _state.GoToNextStepAsync();
        }

        _validationErrors = [];
    }

    private async Task HandlePreviousStep()
    {
        _validationErrors = [];
        _state.FieldErrors = [];
        await _state.GoToPreviousStepAsync();
    }

    private async Task HandleEditStep(int step)
    {
        _validationErrors = [];
        _state.ReturnToStepAfterEdit = _state.CurrentStep;
        await _state.GoToStepAsync(step);
    }

    private void HandleSubmitted()
    {
        var url = $"/confirmation?slug={Uri.EscapeDataString(Slug)}";
        if (!string.IsNullOrWhiteSpace(_state.SubmissionMagicLinkToken))
        {
            url += $"&token={Uri.EscapeDataString(_state.SubmissionMagicLinkToken)}";
        }
        if (_state.FailedUploadCount > 0)
        {
            url += $"&uploadFailures={_state.FailedUploadCount}";
        }

        Navigation.NavigateTo(url);
    }

    public void Dispose()
    {
        _state.OnChange -= StateHasChanged;
    }
}
