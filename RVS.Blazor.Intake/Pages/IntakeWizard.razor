@page "/intake/{Slug}"
@implements IDisposable

<PageTitle>Service Request Intake — @(_state.Config?.LocationName ?? "Loading...")</PageTitle>

<MudStack AlignItems="AlignItems.Center" Spacing="4"
          Style="max-width: 700px; margin: 0 auto;">

    @* Header row — Back button (left) + step progress (right), visible on steps 2–8 *@
    @if (_state.CurrentStep > 1)
    {
        <MudStack Row="true" AlignItems="AlignItems.Center"
                  Class="pa-2 rounded"
                  Style="width: 100%; background: color-mix(in srgb, var(--mud-palette-background-gray) 75%, transparent);">
            <MudButton Variant="Variant.Text"
                       Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="HandlePreviousStep"
                       Style="text-transform: none;"
                       aria-label="Go back">
                Back
            </MudButton>
            <MudSpacer />
            <MudText Typo="Typo.caption">
                Step @_state.CurrentStep of @_state.TotalSteps
            </MudText>
        </MudStack>
    }

    @* Wizard step content *@
    <div style="width: 100%;" @key="_state.CurrentStep" class="wizard-step">
        @switch (_state.CurrentStep)
        {
            case 1:
                <Step1_IntakeLanding State="_state"
                                     OnStart="HandleNextStep" />
                break;
            case 2:
                <Step2_CustomerInfoStep State="_state"
                                        OnNext="HandleNextStep" />
                break;
            case 3:
                <Step3_VinLookupStep State="_state"
                                     OnNext="HandleNextStep" />
                break;
            case 4:
                <Step4_VehicleDetailsStep State="_state"
                                          OnNext="HandleNextStep" />
                break;
            case 5:
                <Step5_IssueDescriptionStep State="_state"
                                            OnNext="HandleNextStep" />
                break;
            case 6:
                <Step6_DiagnosticQuestionsStep State="_state"
                                               OnNext="HandleNextStep" />
                break;
            case 7:
                <Step7_AttachmentUploadStep State="_state"
                                            OnNext="HandleNextStep" />
                break;
            case 8:
                <Step8_ReviewSubmitStep State="_state"
                                        OnEdit="HandleEditStep"
                                        OnSubmitted="HandleSubmitted" />
                break;
        }
    </div>
</MudStack>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    [SupplyParameterFromQuery(Name = "token")] public string? Token { get; set; }

    [Inject] private IntakeWizardState _state { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private List<string> _validationErrors = [];

    protected override async Task OnInitializedAsync()
    {
        _state.OnChange += StateHasChanged;
       _state.Slug = Slug;
       _state.Token = Token;

        await _state.RestoreAsync();

       // RestoreAsync may have overwritten Slug with a stale session value — correct it
       if (_state.Slug != Slug || _state.IsSubmitted)
        {
            await _state.ClearAsync();
            _state.Slug = Slug;
           _state.Token = Token;
        }
    }

    protected override void OnParametersSet()
    {
        _state.Slug = Slug;
        _state.Token = Token;
    }

    private async Task HandleNextStep()
    {
        _validationErrors = _state.ValidateCurrentStep();
        if (_validationErrors.Count > 0)
        {
            StateHasChanged();
            return;
        }

        await _state.GoToNextStepAsync();
        _validationErrors = [];
    }

    private async Task HandlePreviousStep()
    {
        _validationErrors = [];
        await _state.GoToPreviousStepAsync();
    }

    private async Task HandleEditStep(int step)
    {
        _validationErrors = [];
        _state.ReturnToStepAfterEdit = _state.CurrentStep;
        await _state.GoToStepAsync(step);
    }

    private void HandleSubmitted()
    {
        Navigation.NavigateTo($"/confirmation?slug={Uri.EscapeDataString(Slug)}");
    }

    public void Dispose()
    {
        _state.OnChange -= StateHasChanged;
    }
}
