@page "/intake/{Slug}"
@implements IDisposable

<PageTitle>Service Request Intake — @(_state.Config?.LocationName ?? "Loading...")</PageTitle>

<MudStack AlignItems="AlignItems.Center" Spacing="4"
          Style="max-width: 700px; margin: 0 auto;">

    @* Step progress indicator — visible on steps 2–7 *@
    @if (_state.CurrentStep > 1 && _state.CurrentStep < 8)
    {
        <MudPaper Elevation="0" Class="pa-3" Style="width: 100%; background: transparent;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="0">
                @for (var i = 1; i <= _state.TotalSteps; i++)
                {
                    var step = i;
                    @if (i > 1)
                    {
                        <div style="width: 28px; height: 2px;
                                    background: @(step <= _state.CurrentStep
                                        ? "var(--mud-palette-primary)"
                                        : "var(--mud-palette-lines-default)");
                                    transition: background 0.3s ease;"
                             aria-hidden="true"></div>
                    }
                    <MudAvatar Size="Size.Small"
                               Style="@GetStepStyle(step)"
                               Color="@(step <= _state.CurrentStep ? Color.Primary : Color.Default)"
                               Variant="@(step <= _state.CurrentStep ? Variant.Filled : Variant.Outlined)"
                               aria-label="@($"Step {step}{(step < _state.CurrentStep ? " completed" : step == _state.CurrentStep ? " current" : "")}")">
                        @if (step < _state.CurrentStep)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" />
                        }
                        else
                        {
                            @step
                        }
                    </MudAvatar>
                }
            </MudStack>
            <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary" Class="mt-2">
                Step @_state.CurrentStep of @_state.TotalSteps
            </MudText>
        </MudPaper>
    }

    @* Validation errors *@
    @if (_validationErrors.Count > 0)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="mb-2" Style="width: 100%;"
                  role="alert">
            <ul style="margin: 0; padding-left: 16px;">
                @foreach (var error in _validationErrors)
                {
                    <li>@error</li>
                }
            </ul>
        </MudAlert>
    }

    @* Wizard step content *@
    <div style="width: 100%;" @key="_state.CurrentStep" class="wizard-step">
        @switch (_state.CurrentStep)
        {
            case 1:
                <IntakeLanding State="_state"
                               OnStart="HandleNextStep" />
                break;
            case 2:
                <CustomerInfoStep State="_state"
                                  OnNext="HandleNextStep"
                                  OnBack="HandlePreviousStep" />
                break;
            case 3:
                <VinLookupStep State="_state"
                               OnNext="HandleNextStep"
                               OnBack="HandlePreviousStep" />
                break;
            case 4:
                <VehicleDetailsStep State="_state"
                                    OnNext="HandleNextStep"
                                    OnBack="HandlePreviousStep" />
                break;
            case 5:
                <IssueDescriptionStep State="_state"
                                      OnNext="HandleNextStep"
                                      OnBack="HandlePreviousStep" />
                break;
            case 6:
                <DiagnosticQuestionsStep State="_state"
                                         OnNext="HandleNextStep"
                                         OnBack="HandlePreviousStep" />
                break;
            case 7:
                <AttachmentUploadStep State="_state"
                                      OnNext="HandleNextStep"
                                      OnBack="HandlePreviousStep" />
                break;
            case 8:
                <ReviewSubmitStep State="_state"
                                  OnEdit="HandleEditStep"
                                  OnSubmitted="HandleSubmitted" />
                break;
        }
    </div>
</MudStack>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    [SupplyParameterFromQuery(Name = "token")] public string? Token { get; set; }

    [Inject] private IntakeWizardState _state { get; set; } = default!;
    [Inject] private IJSRuntime JsRuntime { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private List<string> _validationErrors = [];

    private string GetStepStyle(int step)
    {
        var baseStyle = "width:32px;height:32px;font-size:0.8rem;transition:all 0.3s ease;";
        return step == _state.CurrentStep
            ? baseStyle + "box-shadow: 0 0 0 3px var(--mud-palette-primary-lighten);"
            : baseStyle;
    }

    protected override void OnInitialized()
    {
        _state.OnChange += StateHasChanged;
    }

    protected override void OnParametersSet()
    {
        _state.Slug = Slug;
        _state.Token = Token;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _state.SetJsRuntime(JsRuntime);
        await _state.RestoreAsync();

        if (_state.Slug != Slug || _state.IsSubmitted)
        {
            await _state.ClearAsync();
            _state.Slug = Slug;
            StateHasChanged();
        }
    }

    private async Task HandleNextStep()
    {
        _validationErrors = _state.ValidateCurrentStep();
        if (_validationErrors.Count > 0)
        {
            StateHasChanged();
            return;
        }

        await _state.GoToNextStepAsync();
        _validationErrors = [];
    }

    private async Task HandlePreviousStep()
    {
        _validationErrors = [];
        await _state.GoToPreviousStepAsync();
    }

    private async Task HandleEditStep(int step)
    {
        _validationErrors = [];
        await _state.GoToStepAsync(step);
    }

    private void HandleSubmitted()
    {
        Navigation.NavigateTo($"/confirmation?slug={Uri.EscapeDataString(Slug)}");
    }

    public void Dispose()
    {
        _state.OnChange -= StateHasChanged;
    }
}
