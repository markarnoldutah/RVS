@inject ThemeService ThemeService

<MudToggleIconButton Toggled="ThemeService.IsHighContrast"
                     ToggledChanged="OnToggled"
                     Icon="@Icons.Material.Filled.Contrast"
                     ToggledIcon="@Icons.Material.Filled.LightMode"
                     Color="Color.Inherit"
                     ToggledColor="Color.Inherit"
                     Size="Size.Small"
                     aria-label="@(ThemeService.IsHighContrast ? "Switch to light theme" : "Switch to high-contrast theme")" />

@code {
    private void OnToggled(bool toggled)
    {
        ThemeService.Toggle();
    }
}
