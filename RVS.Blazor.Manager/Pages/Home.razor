@page "/"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@inject NavigationManager Navigation
@inject RVS.UI.Shared.Services.LookupApiClient LookupClient

<PageTitle>RVS Manager — Home</PageTitle>

<AuthorizeView>
    <Authorized>
        <MudStack Spacing="5" Class="pa-6">
            <MudText Typo="Typo.h4" GutterBottom="true">
                Welcome, @GetDisplayName(context)!
            </MudText>

            <LocationSelector />

            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.Dashboard"
                                 Color="Color.Primary" Size="Size.Large"
                                 aria-hidden="true" />
                        <MudText Typo="Typo.h6">Manager Dashboard</MudText>
                        <MudText Typo="Typo.body1" Color="Color.Secondary">
                            Select a location above to begin managing service requests.
                        </MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>

            <OutcomeComplianceWidget @ref="_complianceWidget"
                                    DealershipId="@_dealershipId" />
        </MudStack>
    </Authorized>
    <NotAuthorized>
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center"
                  Style="min-height: 400px;" Spacing="4">
            <MudIcon Icon="@Icons.Material.Filled.RvHookup"
                     Color="Color.Primary" Size="Size.Large"
                     aria-hidden="true" />
            <MudText Typo="Typo.h5">RVS Manager</MudText>
@*             <MudText Typo="Typo.body1" Color="Color.Secondary">
                Sign in to manage service requests.
            </MudText> *@
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Login"
                       OnClick="BeginLogin">
                Log In
            </MudButton>
        </MudStack>
    </NotAuthorized>
</AuthorizeView>

@code {
    private OutcomeComplianceWidget? _complianceWidget;
    private string? _dealershipId;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask is null) return;
        var authState = await AuthStateTask;
        if (authState.User.Identity?.IsAuthenticated != true) return;

        try
        {
            var dealerships = await LookupClient.GetDealershipsAsync();
            _dealershipId = dealerships.FirstOrDefault()?.Id;
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
    }

    private static string GetDisplayName(AuthenticationState context)
    {
        return context.User.Identity?.Name
            ?? context.User.FindFirst("email")?.Value
            ?? "Manager";
    }

    private void BeginLogin()
    {
        Navigation.NavigateToLogin("authentication/login");
    }
}
