@page "/"

<PageTitle>RVS Manager — Home</PageTitle>

<AuthorizeView>
    <Authorized>
        <MudStack Spacing="5" Class="pa-6">
            <MudText Typo="Typo.h4" GutterBottom="true">
                Welcome, @GetDisplayName(context)!
            </MudText>

            <LocationSelector />

            <MudCard Elevation="2">
                <MudCardContent>
                    <MudStack Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.Dashboard"
                                 Color="Color.Primary" Size="Size.Large"
                                 aria-hidden="true" />
                        <MudText Typo="Typo.h6">Manager Dashboard</MudText>
                        <MudText Typo="Typo.body1" Color="Color.Secondary">
                            Select a location above to begin managing service requests.
                        </MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudStack>
    </Authorized>
</AuthorizeView>

@code {
    private static string GetDisplayName(AuthenticationState context)
    {
        return context.User.Identity?.Name
            ?? context.User.FindFirst("email")?.Value
            ?? "Manager";
    }
}
