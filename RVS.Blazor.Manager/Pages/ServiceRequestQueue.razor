@page "/service-requests"
@inject ServiceRequestApiClient SrClient
@inject LookupApiClient LookupClient
@inject NavigationManager Navigation
@inject RVS.Blazor.Manager.State.ManagerAppState AppState

<PageTitle>RVS Manager — Service Requests</PageTitle>

<MudStack Spacing="4" Class="pa-2">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.h4">Service Requests</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateDialog"
                   Style="text-transform: none;">
            New service request
        </MudButton>
    </MudStack>

    @* Search / Filter Panel *@
    <MudExpansionPanels>
        <MudExpansionPanel Text="Search &amp; filter" Expanded="_filtersExpanded">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6" md="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Keyword</MudText>
                        <MudTextField T="string" @bind-Value="_search.Keyword"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                      Placeholder="Customer, asset, category..." />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Status</MudText>
                        <MudSelect T="string" @bind-Value="_search.Status"
                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Clearable="true"
                                   AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                            <MudSelectItem T="string" Value="@("New")">New</MudSelectItem>
                            <MudSelectItem T="string" Value="@("InProgress")">In Progress</MudSelectItem>
                            <MudSelectItem T="string" Value="@("WaitingOnParts")">Waiting on Parts</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Completed")">Completed</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Cancelled")">Cancelled</MudSelectItem>
                        </MudSelect>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Issue category</MudText>
                        <MudTextField T="string" @bind-Value="_search.IssueCategory"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Placeholder="e.g., Electrical" />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Location</MudText>
                        <MudSelect T="string" @bind-Value="_search.LocationId"
                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Clearable="true"
                                   AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                            @foreach (var loc in _locations)
                            {
                                <MudSelectItem T="string" Value="@loc.LocationId">@loc.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Assigned technician</MudText>
                        <MudTextField T="string" @bind-Value="_search.AssignedTechnicianId"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Placeholder="Technician ID" />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Assigned bay</MudText>
                        <MudTextField T="string" @bind-Value="_search.AssignedBayId"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Placeholder="Bay ID" />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Asset / VIN</MudText>
                        <MudTextField T="string" @bind-Value="_search.AssetId"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Placeholder="Full or partial VIN" />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Priority</MudText>
                        <MudSelect T="string" @bind-Value="_search.Priority"
                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Clearable="true"
                                   AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                            <MudSelectItem T="string" Value="@("Critical")">Critical</MudSelectItem>
                            <MudSelectItem T="string" Value="@("High")">High</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Medium")">Medium</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Low")">Low</MudSelectItem>
                        </MudSelect>
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Date from</MudText>
                        <MudDatePicker Variant="Variant.Outlined" Margin="Margin.Dense"
                                       @bind-Date="_dateFrom" Clearable="true"
                                       Placeholder="Start date" />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Date to</MudText>
                        <MudDatePicker Variant="Variant.Outlined" Margin="Margin.Dense"
                                       @bind-Date="_dateTo" Clearable="true"
                                       Placeholder="End date" />
                    </MudStack>
                </MudItem>
                <MudItem xs="12" Class="d-flex gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Search"
                               OnClick="SearchAsync"
                               Style="text-transform: none;">
                        Search
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               OnClick="ClearFilters"
                               Style="text-transform: none;">
                        Clear
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudExpansionPanel>
    </MudExpansionPanels>

    @* Results Table *@
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_error is not null)
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else
    {
        <MudTable Items="@_results" Hover="true" Striped="true" Dense="true"
                  OnRowClick="OnRowClick" T="ServiceRequestSummaryResponseDto"
                  RowClass="cursor-pointer">
            <HeaderContent>
                <MudTh>ID</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Priority</MudTh>
                <MudTh>Customer</MudTh>
                <MudTh>Asset</MudTh>
                <MudTh>Category</MudTh>
                <MudTh>Location</MudTh>
                <MudTh>Technician</MudTh>
                <MudTh>Created</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ID">
                    <MudText Typo="Typo.body2">@context.Id[..Math.Min(8, context.Id.Length)]…</MudText>
                </MudTd>
                <MudTd DataLabel="Status">
                    <StatusBadge Status="@context.Status" />
                </MudTd>
                <MudTd DataLabel="Priority">
                    @if (!string.IsNullOrEmpty(context.Priority))
                    {
                        <PriorityBadge Priority="@context.Priority" />
                    }
                </MudTd>
                <MudTd DataLabel="Customer">@context.CustomerFullName</MudTd>
                <MudTd DataLabel="Asset">@(context.AssetDisplay ?? "—")</MudTd>
                <MudTd DataLabel="Category">@context.IssueCategory</MudTd>
                <MudTd DataLabel="Location">@(context.LocationName ?? context.LocationId)</MudTd>
                <MudTd DataLabel="Technician">@(context.AssignedTechnicianId ?? "Unassigned")</MudTd>
                <MudTd DataLabel="Created">@context.CreatedAtUtc.ToLocalTime().ToString("g")</MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Typo="Typo.body1" Color="Color.Secondary">No service requests found.</MudText>
            </NoRecordsContent>
        </MudTable>

        @* Pagination *@
        @if (_totalPages > 1)
        {
            <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="2" Class="mt-4">
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                               Disabled="@(_currentPage <= 1)"
                               OnClick="PreviousPageAsync"
                               aria-label="Previous page" />
                <MudText Typo="Typo.body2">Page @_currentPage of @_totalPages (@_totalCount total)</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                               Disabled="@(_currentPage >= _totalPages)"
                               OnClick="NextPageAsync"
                               aria-label="Next page" />
            </MudStack>
        }
    }
</MudStack>

<ServiceRequestDetailDialog @bind-Visible="_detailDialogOpen"
                            ServiceRequestId="@_detailDialogSrId"
                            CurrentStatus="@_detailDialogStatus"
                            OnChanged="OnDialogChangedAsync" />

@code {
    private const int PageSize = 25;
    private SearchModel _search = new();
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private List<LocationSummaryResponseDto> _locations = [];
    private List<ServiceRequestSummaryResponseDto> _results = [];
    private bool _loading;
    private string? _error;
    private int _currentPage = 1;
    private long _totalCount;
    private int _totalPages;
    private bool _filtersExpanded = true;
    private string? _dealershipId;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _locations = await LookupClient.GetLocationsAsync();
            var dealerships = await LookupClient.GetDealershipsAsync();
            _dealershipId = dealerships.FirstOrDefault()?.Id;

            // Pre-populate location filter from centralized state
            if (AppState.SelectedLocation is not null)
            {
                _search.LocationId = AppState.SelectedLocation;
            }

            if (_dealershipId is not null)
            {
                await SearchAsync();
            }
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task SearchAsync()
    {
        if (_dealershipId is null)
        {
            _error = "No dealership found. Please contact your administrator.";
            return;
        }

        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var request = new ServiceRequestSearchRequestDto
            {
                Keyword = _search.Keyword,
                Status = _search.Status,
                IssueCategory = _search.IssueCategory,
                LocationId = _search.LocationId,
                AssignedTechnicianId = _search.AssignedTechnicianId,
                AssignedBayId = _search.AssignedBayId,
                AssetId = _search.AssetId,
                Priority = _search.Priority,
                DateFrom = _dateFrom?.ToUniversalTime(),
                DateTo = _dateTo?.ToUniversalTime(),
                Page = _currentPage,
                PageSize = PageSize
            };

            var response = await SrClient.SearchAsync(_dealershipId, request);
            _results = response.Results.Items;
            _totalCount = response.Results.TotalCount;
            _totalPages = (int)Math.Ceiling((double)_totalCount / PageSize);
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void ClearFilters()
    {
        _search = new();
        _dateFrom = null;
        _dateTo = null;
        _currentPage = 1;
    }

    private async Task PreviousPageAsync()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            await SearchAsync();
        }
    }

    private async Task NextPageAsync()
    {
        if (_currentPage < _totalPages)
        {
            _currentPage++;
            await SearchAsync();
        }
    }

    private void OnRowClick(TableRowClickEventArgs<ServiceRequestSummaryResponseDto> args)
    {
        _detailDialogSrId = args.Item!.Id;
        _detailDialogStatus = args.Item.Status;
        _detailDialogOpen = true;
    }

    private void OpenCreateDialog()
    {
        _detailDialogSrId = null;
        _detailDialogStatus = null;
        _detailDialogOpen = true;
    }

    private async Task OnDialogChangedAsync()
    {
        await SearchAsync();
    }

    private bool _detailDialogOpen;
    private string? _detailDialogSrId;
    private string? _detailDialogStatus;

    private sealed class SearchModel
    {
        public string? Keyword { get; set; }
        public string? Status { get; set; }
        public string? IssueCategory { get; set; }
        public string? LocationId { get; set; }
        public string? AssignedTechnicianId { get; set; }
        public string? AssignedBayId { get; set; }
        public string? AssetId { get; set; }
        public string? Priority { get; set; }
    }
}
