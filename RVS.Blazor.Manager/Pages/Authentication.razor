@page "/authentication/{action}"
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@attribute [AllowAnonymous]

<RemoteAuthenticatorView Action="@Action">
    <LoggingIn>
        <AuthStatePanel Message="Redirecting for authentication..." ShowSpinner="true" />
    </LoggingIn>
    <CompletingLoggingIn>
        <AuthStatePanel Message="Completing login..." ShowSpinner="true" />
    </CompletingLoggingIn>
    <LogInFailed>
        <AuthStatePanel Message="There was an error logging in. Please try again."
                        ErrorDetail="@context"
                        ButtonText="Try Again"
                        ButtonHref="authentication/login" />
    </LogInFailed>
    <LogOut>
        <AuthStatePanel Message="Logging out..." ShowSpinner="true" />
    </LogOut>
    <CompletingLogOut>
        <AuthStatePanel Message="Completing logout..." ShowSpinner="true" />
    </CompletingLogOut>
    <LogOutFailed>
        <AuthStatePanel Message="There was an error logging out."
                        ButtonText="Log In"
                        ButtonHref="authentication/login" />
    </LogOutFailed>
    <LogOutSucceeded>
        <AuthStatePanel Message="You have been successfully logged out."
                        ButtonText="Log In"
                        ButtonHref="authentication/login" />
    </LogOutSucceeded>
</RemoteAuthenticatorView>

@code {
    [Parameter]
    public string? Action { get; set; }
}
