@page "/authentication/{action}"
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication

<RemoteAuthenticatorView Action="@Action">
    <LoggingIn>
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 400px;" Spacing="4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" aria-label="Redirecting to Auth0" />
            <MudText Typo="Typo.body1">Redirecting to Auth0...</MudText>
        </MudStack>
    </LoggingIn>
    <CompletingLoggingIn>
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 400px;" Spacing="4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" aria-label="Completing login" />
            <MudText Typo="Typo.body1">Completing login...</MudText>
        </MudStack>
    </CompletingLoggingIn>
    <LogInFailed>
        @{
            var errorMessage = context;
        }
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 400px;" Spacing="4">
            <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" aria-hidden="true" />
            <MudText Typo="Typo.h6" Color="Color.Error">Login Failed</MudText>
            <MudText Typo="Typo.body1">There was an error logging in. Please try again.</MudText>
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-2" Style="max-width: 600px; word-break: break-all;">
                <MudText Typo="Typo.caption">@errorMessage</MudText>
            </MudAlert>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">Return to Home</MudButton>
        </MudStack>
    </LogInFailed>
    <LogOut>
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 400px;" Spacing="4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" aria-label="Logging out" />
            <MudText Typo="Typo.body1">Logging out...</MudText>
        </MudStack>
    </LogOut>
    <CompletingLogOut>
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 400px;" Spacing="4">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" aria-label="Completing logout" />
            <MudText Typo="Typo.body1">Completing logout...</MudText>
        </MudStack>
    </CompletingLogOut>
    <LogOutFailed>
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 400px;" Spacing="4">
            <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Large" aria-hidden="true" />
            <MudText Typo="Typo.h6" Color="Color.Error">Logout Failed</MudText>
            <MudText Typo="Typo.body1">There was an error logging out.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">Return to Home</MudButton>
        </MudStack>
    </LogOutFailed>
    <LogOutSucceeded>
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 400px;" Spacing="4">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" aria-hidden="true" />
            <MudText Typo="Typo.body1">You have been successfully logged out.</MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">Return to Home</MudButton>
        </MudStack>
    </LogOutSucceeded>
</RemoteAuthenticatorView>

@code {
    [Parameter]
    public string? Action { get; set; }
}
