@page "/locations"
@inject LookupApiClient LookupClient
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>RVS Manager — Locations</PageTitle>

<MudStack Spacing="4" Class="pa-2">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.h4">Locations</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="ShowCreateDialog">
            Add Location
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_error is not null)
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else
    {
        <MudTable Items="@_locations" Hover="true" Elevation="2" Dense="true"
                  Breakpoint="Breakpoint.Sm" Loading="@_loading"
                  LoadingProgressColor="Color.Primary">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Slug</MudTh>
                <MudTh>Phone</MudTh>
                <MudTh>City / State</MudTh>
                <MudTh>Created</MudTh>
                <MudTh Style="text-align:right">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Slug">@context.Slug</MudTd>
                <MudTd DataLabel="Phone">@(context.Phone ?? "—")</MudTd>
                <MudTd DataLabel="City / State">@FormatCityState(context.Address)</MudTd>
                <MudTd DataLabel="Created">@context.CreatedAtUtc.ToLocalTime().ToString("g")</MudTd>
                <MudTd DataLabel="Actions" Style="text-align:right">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary"
                                   Size="Size.Small" aria-label="Edit location"
                                   OnClick="@(() => ShowEditDialog(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.QrCode2" Color="Color.Secondary"
                                   Size="Size.Small" aria-label="Download QR code"
                                   OnClick="@(() => DownloadQrCodeAsync(context.LocationId, context.Slug))" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Typo="Typo.body1">No locations found. Click <strong>Add Location</strong> to create one.</MudText>
            </NoRecordsContent>
        </MudTable>
    }

    @* Create / Edit Dialog *@
    <MudDialog @bind-Visible="_dialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
        <TitleContent>
            <MudText Typo="Typo.h6">@(_editingLocationId is null ? "Create Location" : "Edit Location")</MudText>
        </TitleContent>
        <DialogContent>
            <MudStack Spacing="3">
                <MudTextField T="string" Label="Name" Variant="Variant.Outlined"
                              @bind-Value="_form.Name" Required="true" />
                <MudTextField T="string" Label="Slug" Variant="Variant.Outlined"
                              @bind-Value="_form.Slug"
                              HelperText="@(_editingLocationId is null ? "Leave blank to auto-generate from dealership + location name" : "URL-friendly identifier (e.g., 'salt-lake-city')")" />
                <MudTextField T="string" Label="Phone" Variant="Variant.Outlined"
                              @bind-Value="_form.Phone" />

                <MudText Typo="Typo.subtitle2">Address</MudText>
                <MudTextField T="string" Label="Address Line 1" Variant="Variant.Outlined"
                              @bind-Value="_form.Address1" />
                <MudTextField T="string" Label="Address Line 2" Variant="Variant.Outlined"
                              @bind-Value="_form.Address2" />
                <MudGrid Spacing="2">
                    <MudItem xs="12" sm="5">
                        <MudTextField T="string" Label="City" Variant="Variant.Outlined"
                                      @bind-Value="_form.City" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudTextField T="string" Label="State" Variant="Variant.Outlined"
                                      @bind-Value="_form.State" />
                    </MudItem>
                    <MudItem xs="6" sm="4">
                        <MudTextField T="string" Label="Postal Code" Variant="Variant.Outlined"
                                      @bind-Value="_form.PostalCode" />
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-2" />
                <MudText Typo="Typo.subtitle2">Intake Configuration</MudText>

                <MudTextField T="string" Label="Accepted File Types (comma-separated)" Variant="Variant.Outlined"
                              @bind-Value="_form.AcceptedFileTypes"
                              HelperText="e.g., .jpg, .png, .mp4" />
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudNumericField T="int" Label="Max File Size (MB)" Variant="Variant.Outlined"
                                         @bind-Value="_form.MaxFileSizeMb" Min="1" Max="100" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField T="int" Label="Max Attachments" Variant="Variant.Outlined"
                                         @bind-Value="_form.MaxAttachments" Min="1" Max="10" />
                    </MudItem>
                </MudGrid>
                <MudTextField T="string" Label="AI Context" Variant="Variant.Outlined"
                              @bind-Value="_form.AiContext" Lines="3"
                              HelperText="Optional context appended to AI prompts (max 500 chars)" />
                <MudSwitch T="bool" @bind-Value="_form.AllowAnonymousIntake"
                           Label="Allow Anonymous Intake" Color="Color.Primary" />
            </MudStack>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseDialog">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="SaveLocationAsync" Disabled="_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Save
            </MudButton>
        </DialogActions>
    </MudDialog>
</MudStack>

@code {
    private List<LocationSummaryResponseDto> _locations = [];
    private bool _loading = true;
    private string? _error;
    private bool _dialogOpen;
    private bool _saving;
    private string? _editingLocationId;
    private LocationForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadLocationsAsync();
    }

    private async Task LoadLocationsAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _locations = await LookupClient.GetLocationsAsync();
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void ShowCreateDialog()
    {
        _editingLocationId = null;
        _form = new LocationForm();
        _dialogOpen = true;
    }

    private async Task ShowEditDialog(LocationSummaryResponseDto summary)
    {
        try
        {
            var location = await LookupClient.GetLocationByIdAsync(summary.LocationId);
            _editingLocationId = location.Id;
            _form = new LocationForm
            {
                Name = location.Name,
                Slug = location.Slug,
                Phone = location.Phone,
                Address1 = location.Address?.Address1,
                Address2 = location.Address?.Address2,
                City = location.Address?.City,
                State = location.Address?.State,
                PostalCode = location.Address?.PostalCode,
                AcceptedFileTypes = location.IntakeConfig is not null
                    ? string.Join(", ", location.IntakeConfig.AcceptedFileTypes)
                    : ".jpg, .jpeg, .png, .mp4, .m4a, .wav",
                MaxFileSizeMb = location.IntakeConfig?.MaxFileSizeMb ?? 25,
                MaxAttachments = location.IntakeConfig?.MaxAttachments ?? 10,
                AiContext = location.IntakeConfig?.AiContext,
                AllowAnonymousIntake = location.IntakeConfig?.AllowAnonymousIntake ?? true
            };
            _dialogOpen = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load location details: {ex.Message}", Severity.Error);
        }
    }

    private void CloseDialog()
    {
        _dialogOpen = false;
    }

    private async Task SaveLocationAsync()
    {
        _saving = true;
        StateHasChanged();

        try
        {
            var acceptedTypes = string.IsNullOrWhiteSpace(_form.AcceptedFileTypes)
                ? []
                : _form.AcceptedFileTypes
                    .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .ToList();

            var request = new LocationCreateRequestDto
            {
                Name = _form.Name ?? string.Empty,
                Slug = string.IsNullOrWhiteSpace(_form.Slug) ? null : _form.Slug,
                Phone = _form.Phone,
                Address = new AddressDto
                {
                    Address1 = _form.Address1,
                    Address2 = _form.Address2,
                    City = _form.City,
                    State = _form.State,
                    PostalCode = _form.PostalCode
                },
                IntakeConfig = new IntakeConfigDto
                {
                    AcceptedFileTypes = acceptedTypes,
                    MaxFileSizeMb = _form.MaxFileSizeMb,
                    MaxAttachments = _form.MaxAttachments,
                    AiContext = _form.AiContext,
                    AllowAnonymousIntake = _form.AllowAnonymousIntake
                }
            };

            if (_editingLocationId is not null)
            {
                await LookupClient.UpdateLocationAsync(_editingLocationId, request);
                Snackbar.Add("Location updated.", Severity.Success);
            }
            else
            {
                await LookupClient.CreateLocationAsync(request);
                Snackbar.Add("Location created.", Severity.Success);
            }

            _dialogOpen = false;
            await LoadLocationsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save location: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DownloadQrCodeAsync(string locationId, string slug)
    {
        try
        {
            var bytes = await LookupClient.GetLocationQrCodeAsync(locationId);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("rvs_downloadBase64", $"qr-{Uri.EscapeDataString(slug)}.png", base64, "image/png");
            Snackbar.Add("QR code downloaded.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to download QR code: {ex.Message}", Severity.Error);
        }
    }

    private static string FormatCityState(AddressDto? address)
    {
        if (address is null) return "—";
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(address.City)) parts.Add(address.City);
        if (!string.IsNullOrEmpty(address.State)) parts.Add(address.State);
        return parts.Count > 0 ? string.Join(", ", parts) : "—";
    }

    private sealed class LocationForm
    {
        public string? Name { get; set; }
        public string? Slug { get; set; }
        public string? Phone { get; set; }
        public string? Address1 { get; set; }
        public string? Address2 { get; set; }
        public string? City { get; set; }
        public string? State { get; set; }
        public string? PostalCode { get; set; }
        public string? AcceptedFileTypes { get; set; } = ".jpg, .jpeg, .png, .mp4, .m4a, .wav";
        public int MaxFileSizeMb { get; set; } = 25;
        public int MaxAttachments { get; set; } = 10;
        public string? AiContext { get; set; }
        public bool AllowAnonymousIntake { get; set; } = true;
    }
}
