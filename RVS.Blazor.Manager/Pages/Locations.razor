@page "/locations"
@inject LookupApiClient LookupClient
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>RVS Manager — Locations</PageTitle>

<MudStack Spacing="4" Class="pa-2">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.h4">Locations</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="ShowCreateDialog">
            Add Location
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_error is not null)
    {
        <MudAlert Severity="Severity.Error">@_error</MudAlert>
    }
    else
    {
        @* ───────────────────────── Locations table ─────────────────────────
           Single network call returns LocationSummaryResponseDto rows containing
           name, slug, phone, address, and capability badges. We only fetch the
           full LocationDetailDto when a row is clicked (drawer opens).         *@
        <MudTable Items="_summaries"
                  Dense="true"
                  Hover="true"
                  Striped="true"
                  Bordered="false"
                  Elevation="1"
                  OnRowClick="OnRowClickAsync"
                  T="LocationSummaryResponseDto"
                  RowStyle="cursor: pointer;">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Slug</MudTh>
                <MudTh>Phone</MudTh>
                <MudTh>Location</MudTh>
                <MudTh Style="text-align: center;">Capabilities</MudTh>
                <MudTh Style="text-align: right;">Created</MudTh>
                <MudTh Style="text-align: right;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Primary" Size="Size.Small" />
                        <MudText Typo="Typo.body2"><strong>@context.Name</strong></MudText>
                    </MudStack>
                </MudTd>
                <MudTd DataLabel="Slug">
                    <MudText Typo="Typo.body2" Style="font-family: monospace;">@context.Slug</MudText>
                </MudTd>
                <MudTd DataLabel="Phone">@(context.Phone ?? "—")</MudTd>
                <MudTd DataLabel="Location">@FormatCityState(context.Address)</MudTd>
                <MudTd DataLabel="Capabilities" Style="text-align: center;">
                    @if (context.EnabledCapabilities.Count > 0)
                    {
                        <MudBadge Content="@context.EnabledCapabilities.Count"
                                  Color="Color.Primary"
                                  Overlap="false"
                                  Bordered="true">
                            <MudIcon Icon="@Icons.Material.Outlined.Build" Size="Size.Small" />
                        </MudBadge>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                    }
                </MudTd>
                <MudTd DataLabel="Created" Style="text-align: right;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @context.CreatedAtUtc.ToLocalTime().ToString("d")
                    </MudText>
                </MudTd>
                <MudTd Style="text-align: right;">
                    <div @onclick:stopPropagation="true">
                        <MudIconButton Icon="@Icons.Material.Filled.QrCode2"
                                       Size="Size.Small"
                                       aria-label="Download QR code"
                                       OnClick="@(() => DownloadQrCodeAsync(context.LocationId, context.Slug))" />
                    </div>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-4" Color="Color.Secondary">No locations yet — click <strong>Add Location</strong> to create your first one.</MudText>
            </NoRecordsContent>
        </MudTable>
    }

    @* Create / Edit Drawer *@
    <MudDrawer @bind-Open="_dialogOpen"
               Anchor="Anchor.End"
               Variant="DrawerVariant.Temporary"
               Width="480px"
               Elevation="0"
               Style="border-left: 4px solid var(--mud-palette-primary);">
        <MudDrawerHeader Style="border-bottom: 1px solid var(--mud-palette-divider);">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width: 100%;">
                <MudText Typo="Typo.h6">@(_editingLocationId is null ? "Create Location" : "Edit Location")</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               aria-label="Close"
                               OnClick="CloseDialog" />
            </MudStack>
        </MudDrawerHeader>

        <MudStack Style="flex: 1; overflow-y: auto; min-height: 0;" Class="pa-4" Spacing="0">
            <MudForm @ref="_form2">
                <MudStack Spacing="3">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">How this location appears to staff and customers</MudText>
                        <MudTextField T="string" @bind-Value="_form.Name"
                                      Validation="@(new Func<string?, string?>(ValidateName))"
                                      Label="Name"
                                      Variant="Variant.Filled"
                                      Margin="Margin.Dense"
                                      Placeholder="e.g., Salt Lake City"
                                      autocomplete="off" />
                    </MudStack>

                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Optional — shown on intake landing page</MudText>
                        <MudTextField T="string" @bind-Value="_form.Phone"
                                      InputType="InputType.Telephone"
                                      Label="Phone"
                                      Variant="Variant.Filled"
                                      Margin="Margin.Dense"
                                      Placeholder="(555) 123-4567"
                                      autocomplete="tel" />
                    </MudStack>

                    <MudStack Spacing="1">
                        <MudTextField T="string" @bind-Value="_form.Address1"
                                      Label="Address line 1"
                                      Variant="Variant.Filled"
                                      Margin="Margin.Dense"
                                      Placeholder="123 Main St"
                                      autocomplete="address-line1" />
                    </MudStack>

                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Apartment, suite, or unit (optional)</MudText>
                        <MudTextField T="string" @bind-Value="_form.Address2"
                                      Label="Address line 2"
                                      Variant="Variant.Filled"
                                      Margin="Margin.Dense"
                                      Placeholder="Suite 200"
                                      autocomplete="address-line2" />
                    </MudStack>

                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="5">
                            <MudStack Spacing="1">
                                <MudTextField T="string" @bind-Value="_form.City"
                                              Label="City"
                                              Variant="Variant.Filled"
                                              Margin="Margin.Dense"
                                              Placeholder="Salt Lake City"
                                              autocomplete="address-level2" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="6" sm="3">
                            <MudStack Spacing="1">
                                <MudTextField T="string" @bind-Value="_form.State"
                                              Label="State"
                                              Variant="Variant.Filled"
                                              Margin="Margin.Dense"
                                              Placeholder="UT"
                                              autocomplete="address-level1" />
                            </MudStack>
                        </MudItem>
                        <MudItem xs="6" sm="4">
                            <MudStack Spacing="1">
                                <MudTextField T="string" @bind-Value="_form.PostalCode"
                                              Label="Postal code"
                                              Variant="Variant.Filled"
                                              Margin="Margin.Dense"
                                              Placeholder="84101"
                                              autocomplete="postal-code" />
                            </MudStack>
                        </MudItem>
                    </MudGrid>

                    @* Capabilities Section *@
                    @if (_tenantCapabilities.Count > 0)
                    {
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Service Capabilities</MudText>
                            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">
                                Select which services this location offers. Managed at the tenant level in Settings.
                            </MudText>
                            <MudPaper Elevation="0" Outlined="true" Class="pa-2">
                                <MudStack Spacing="0">
                                    @foreach (var cap in _tenantCapabilities.Where(c => c.IsActive))
                                    {
                                        var code = cap.Code;
                                        <MudCheckBox T="bool"
                                                     Value="@_form.EnabledCapabilities.Contains(code)"
                                                     ValueChanged="@(v => ToggleCapability(code, v))"
                                                     Label="@cap.Name"
                                                     Color="Color.Primary"
                                                     Dense="true" />
                                    }
                                </MudStack>
                            </MudPaper>
                        </MudStack>
                    }
                </MudStack>
            </MudForm>
        </MudStack>

        <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2"
                  Class="pa-4"
                  Style="border-top: 1px solid var(--mud-palette-divider);">
            <MudButton OnClick="CloseDialog" Style="text-transform: none;">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="SaveLocationAsync" Disabled="_saving"
                       Style="text-transform: none;">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Save location
            </MudButton>
        </MudStack>
    </MudDrawer>
</MudStack>

@code {
    // ──────────────────────────────────────────────────────────────────────────
    //  Recommended additional metadata that should be editable per location
    //  (placeholder — left for a future change as called out in the issue):
    //   • Service capabilities (already supported via checkboxes below)
    //   • Intake form configuration:
    //       – AllowAnonymousIntake (toggle)
    //       – MaxFileSizeMb / MaxAttachments (numeric inputs)
    //       – AcceptedFileTypes (chip-list editor)
    //       – AiContext (multiline text area for system-prompt augmentation)
    //   • Operating hours / timezone
    //   • Service email and dedicated SMS sender phone for ACS notifications
    //   • Branding overrides (logo URL, accent color)
    //   • Default service-advisor / round-robin queue assignment rules
    //   • Tax / labor-rate codes per location (for downstream estimating)
    // ──────────────────────────────────────────────────────────────────────────

    private List<LocationSummaryResponseDto> _summaries = [];
    private List<TenantCapabilityDto> _tenantCapabilities = [];
    private bool _loading = true;
    private string? _error;
    private bool _dialogOpen;
    private bool _saving;
    private bool _submitted;
    private string? _editingLocationId;
    private string? _editingLocationSlug; // preserved on update; we do not change slugs from the UI
    private LocationForm _form = new();
    private MudForm? _form2;

    private string? ValidateName(string? value) =>
        _submitted && string.IsNullOrWhiteSpace(value) ? "Enter a location name" : null;

    private string GetCapabilityName(string code) =>
        _tenantCapabilities.FirstOrDefault(c => c.Code == code)?.Name ?? code;

    private void ToggleCapability(string code, bool enabled)
    {
        if (enabled)
        {
            if (!_form.EnabledCapabilities.Contains(code))
                _form.EnabledCapabilities.Add(code);
        }
        else
        {
            _form.EnabledCapabilities.Remove(code);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadLocationsAsync(), LoadTenantCapabilitiesAsync());
    }

    private async Task LoadLocationsAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            // Single network call — the summary DTO now includes slug, phone, address,
            // enabled capabilities, and createdAtUtc, so the table no longer needs a
            // per-row detail fetch (was N+1 before).
            _summaries = await LookupClient.GetLocationsAsync();
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadTenantCapabilitiesAsync()
    {
        try
        {
            var config = await LookupClient.GetTenantConfigAsync();
            _tenantCapabilities = config.AvailableCapabilities;
        }
        catch
        {
            // Capabilities are optional; don't block location load on failure
            _tenantCapabilities = [];
        }
    }

    private void ShowCreateDialog()
    {
        _editingLocationId = null;
        _editingLocationSlug = null;
        _form = new LocationForm();
        _submitted = false;
        _dialogOpen = true;
    }

    private async Task OnRowClickAsync(TableRowClickEventArgs<LocationSummaryResponseDto> args)
    {
        if (args.Item is null)
        {
            return;
        }

        try
        {
            // Detail call only happens when a row is clicked.
            var detail = await LookupClient.GetLocationByIdAsync(args.Item.LocationId);
            ShowEditDialog(detail);
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load location details: {ex.Message}", Severity.Error);
        }
    }

    private void ShowEditDialog(LocationDetailDto location)
    {
        _editingLocationId = location.Id;
        _editingLocationSlug = location.Slug;
        _submitted = false;
        _form = new LocationForm
        {
            Name = location.Name,
            Phone = location.Phone,
            Address1 = location.Address?.Address1,
            Address2 = location.Address?.Address2,
            City = location.Address?.City,
            State = location.Address?.State,
            PostalCode = location.Address?.PostalCode,
            EnabledCapabilities = [.. location.EnabledCapabilities]
        };
        _dialogOpen = true;
    }

    private void CloseDialog()
    {
        _dialogOpen = false;
    }

    private async Task SaveLocationAsync()
    {
        _submitted = true;
        if (_form2 is not null)
        {
            await _form2.ValidateAsync();
            if (!_form2.IsValid)
            {
                Snackbar.Add("Fix the highlighted fields and try again.", Severity.Warning);
                return;
            }
        }

        _saving = true;
        StateHasChanged();

        try
        {
            // On create: leave Slug null so the API auto-generates {org-slug}-{name}.
            // On update: pass back the existing slug so it is preserved (changing slugs
            // from the UI is intentionally not supported here — the URL is sticky).
            var request = new LocationCreateRequestDto
            {
                Name = _form.Name ?? string.Empty,
                Slug = _editingLocationId is not null ? _editingLocationSlug : null,
                Phone = _form.Phone,
                Address = new AddressDto
                {
                    Address1 = _form.Address1,
                    Address2 = _form.Address2,
                    City = _form.City,
                    State = _form.State,
                    PostalCode = _form.PostalCode
                },
                EnabledCapabilities = [.. _form.EnabledCapabilities]
            };

            if (_editingLocationId is not null)
            {
                await LookupClient.UpdateLocationAsync(_editingLocationId, request);
                Snackbar.Add("Location updated.", Severity.Success);
            }
            else
            {
                await LookupClient.CreateLocationAsync(request);
                Snackbar.Add("Location created.", Severity.Success);
            }

            _dialogOpen = false;
            await LoadLocationsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save location: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DownloadQrCodeAsync(string locationId, string slug)
    {
        try
        {
            var bytes = await LookupClient.GetLocationQrCodeAsync(locationId);
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("rvs_downloadBase64", $"qr-{Uri.EscapeDataString(slug)}.png", base64, "image/png");
            Snackbar.Add("QR code downloaded.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to download QR code: {ex.Message}", Severity.Error);
        }
    }

    private static string FormatCityState(AddressDto? address)
    {
        if (address is null)
        {
            return "—";
        }

        var parts = new List<string>();
        if (!string.IsNullOrWhiteSpace(address.City)) parts.Add(address.City);
        if (!string.IsNullOrWhiteSpace(address.State)) parts.Add(address.State);
        return parts.Count > 0 ? string.Join(", ", parts) : "—";
    }

    private sealed class LocationForm
    {
        public string? Name { get; set; }
        public string? Phone { get; set; }
        public string? Address1 { get; set; }
        public string? Address2 { get; set; }
        public string? City { get; set; }
        public string? State { get; set; }
        public string? PostalCode { get; set; }
        public List<string> EnabledCapabilities { get; set; } = [];
    }
}
