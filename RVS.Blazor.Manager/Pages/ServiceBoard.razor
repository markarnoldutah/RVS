@page "/board"
@implements IDisposable
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@inject RVS.UI.Shared.Services.ServiceRequestApiClient SrClient
@inject RVS.UI.Shared.Services.LookupApiClient LookupClient
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject RVS.Blazor.Manager.State.ManagerAppState AppState
@using RVS.Domain.Validation

<PageTitle>RVS Manager — Service Board</PageTitle>

<AuthorizeView>
    <Authorized>
        <MudStack Spacing="2" Class="pa-2" Style="height: calc(100vh - 160px); overflow: hidden;">
            @* Header row *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.h4">Service Board</MudText>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    @if (_lastRefreshed is not null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Updated @_lastRefreshed.Value.ToLocalTime().ToString("h:mm tt")
                        </MudText>
                    }
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Color="Color.Primary"
                                   OnClick="RefreshBoardAsync"
                                   Disabled="_loading"
                                   aria-label="Refresh board" />
                </MudStack>
            </MudStack>

            @* Location filter *@
            <LocationSelector />

            @* Loading skeleton *@
            @if (_loading && _boardItems.Count == 0)
            {
                <MudGrid>
                    @for (var col = 0; col < 4; col++)
                    {
                        <MudItem xs="12" sm="6" md="3">
                            <MudPaper Elevation="1" Class="pa-4">
                                <MudSkeleton SkeletonType="SkeletonType.Text" Width="60%" Class="mb-4" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="120px" Class="mb-2" />
                                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="120px" />
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
            else if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Class="my-4">
                    @_error
                    <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="RefreshBoardAsync"
                               Style="text-transform: none;">
                        Retry
                    </MudButton>
                </MudAlert>
            }
            else if (AppState.SelectedLocation is null)
            {
                <MudAlert Severity="Severity.Info" Class="my-4">
                    Select a location above to view the service board.
                </MudAlert>
            }
            else
            {
                @* Drag-and-drop Kanban columns *@
                <MudDropContainer T="BoardItem"
                                  @ref="_dropContainer"
                                  Items="_boardItems"
                                  ItemsSelector="@((item, zone) => item.Status == zone)"
                                  ItemDropped="OnItemDroppedAsync"
                                  ApplyDropClassesOnDragStarted="true"
                                  CanDropClass="mud-border-success"
                                  NoDropClass="mud-border-error"
                                   Class="d-flex flex-row flex-wrap gap-4 flex-grow-1"
                                  Style="min-height: 0;">
                    <ChildContent>
                        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; height: 100%;">
                            @foreach (var column in _columns)
                            {
                                var columnItems = _boardItems.Where(i => i.Status == column.Status).ToList();
                                <div style="display: flex; flex-direction: column; min-width: 0; min-height: 0; overflow: hidden;">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                            <MudIcon Icon="@column.Icon" Color="@column.Color" Size="Size.Small"
                                                     aria-hidden="true" />
                                            <MudText Typo="Typo.h6">@column.Title</MudText>
                                            <MudChip T="string" Size="Size.Small" Color="@column.Color"
                                                     Variant="Variant.Outlined">
                                                @columnItems.Count
                                            </MudChip>
                                        </MudStack>

                                        <MudDropZone T="BoardItem"
                                                     Identifier="@column.Status"
                                                     Class="d-flex flex-column gap-2 flex-grow-1"
                                                     Style="overflow-y: auto; overflow-x: hidden; background: var(--mud-palette-background-gray); border-radius: 4px; padding: 8px;"
                                                     AllowReorder="true" />
                                                </div>
                                            }
                                        </div>
                                    </ChildContent>
                    <ItemRenderer Context="boardItem">
                        <MudCard Elevation="2"
                                 Style="cursor: grab; min-width: 0; overflow: hidden;"
                                 @onclick="() => NavigateToDetail(boardItem.Summary.Id)">
                            <MudCardContent Class="pa-3">
                                <MudStack Spacing="1">
                                    @* Header row: customer name + drag handle *@
                                    <MudStack Row="true" AlignItems="AlignItems.Center"
                                              Justify="Justify.SpaceBetween">
                                        <MudText Typo="Typo.subtitle2">
                                            @boardItem.Summary.CustomerFullName
                                        </MudText>
                                        <MudIcon Icon="@Icons.Material.Filled.DragIndicator"
                                                 Size="Size.Small"
                                                 Color="Color.Default"
                                                 Class="mud-text-disabled"
                                                 aria-hidden="true" />
                                    </MudStack>

                                    @* Asset info *@
                                    @if (!string.IsNullOrWhiteSpace(boardItem.Summary.AssetDisplay))
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            @boardItem.Summary.AssetDisplay
                                        </MudText>
                                    }

                                    @* Category *@
                                    @if (!string.IsNullOrWhiteSpace(boardItem.Summary.IssueCategory))
                                    {
                                        <MudChip T="string" Size="Size.Small"
                                                 Variant="Variant.Outlined"
                                                 Color="Color.Default">
                                            @boardItem.Summary.IssueCategory
                                        </MudChip>
                                    }

                                    @* Age and priority row *@
                                    <MudStack Row="true" AlignItems="AlignItems.Center"
                                               Justify="Justify.SpaceBetween" Class="mt-1">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @FormatAge(boardItem.Summary.CreatedAtUtc)
                                        </MudText>
                                        @if (!string.IsNullOrWhiteSpace(boardItem.Summary.Priority))
                                        {
                                            <RVS.UI.Shared.Components.PriorityBadge
                                                Priority="@boardItem.Summary.Priority" />
                                        }
                                    </MudStack>
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </ItemRenderer>
                </MudDropContainer>
            }
        </MudStack>
    </Authorized>
</AuthorizeView>

@code {
    private bool _loading;
    private string? _error;
    private DateTime? _lastRefreshed;
    private List<BoardItem> _boardItems = [];
    private CancellationTokenSource? _pollCts;
    private PeriodicTimer? _pollTimer;
    private MudDropContainer<BoardItem>? _dropContainer;
    private bool _needsContainerRefresh;

    /// <summary>
    /// Polling interval in seconds. Configurable; defaults to 300 (5 minutes).
    /// </summary>
    private const int DefaultPollIntervalSeconds = 300;

    private string? _dealershipId;

    private static readonly BoardColumn[] _columns =
    [
        new("New", "New", Icons.Material.Filled.FiberNew, Color.Info),
        new("In Progress", "InProgress", Icons.Material.Filled.Autorenew, Color.Warning),
        new("Completed", "Completed", Icons.Material.Filled.CheckCircle, Color.Success),
        new("Blocked", "WaitingOnParts", Icons.Material.Filled.Block, Color.Error),
    ];

    // Board-visible statuses — Cancelled is managed via the SR table, not the board
    private static readonly HashSet<string> _boardStatuses = _columns.Select(c => c.Status).ToHashSet();

    protected override async Task OnInitializedAsync()
    {
        _dealershipId = await ResolveDealershipIdAsync();

        AppState.OnLocationChanged += HandleLocationChangedAsync;

        // If a location was already persisted, load data immediately
        if (AppState.SelectedLocation is not null)
        {
            await LoadBoardDataAsync();
            StartPolling();
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (_needsContainerRefresh)
        {
            _needsContainerRefresh = false;
            _dropContainer?.Refresh();
        }
    }

    private async Task<string?> ResolveDealershipIdAsync()
    {
        var dealerships = await LookupClient.GetDealershipsAsync();
        return dealerships.FirstOrDefault()?.Id;
    }

    private async Task LoadBoardDataAsync()
    {
        if (_dealershipId is null) return;

        _loading = true;
        _error = null;

        try
        {
            var request = new ServiceRequestSearchRequestDto
            {
                LocationId = AppState.SelectedLocation,
                PageSize = 100,
            };

            var result = await SrClient.SearchAsync(_dealershipId, request);
            var items = result.Results?.Items ?? [];
            _boardItems = items
                .Where(sr => _boardStatuses.Contains(sr.Status))
                .OrderBy(sr => sr.BoardSequence)
                .ThenByDescending(sr => sr.CreatedAtUtc)
                .Select(sr => new BoardItem(sr))
                .ToList();
            _lastRefreshed = DateTime.UtcNow;
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = $"Unable to load service requests. {ex.Message}";
        }
        finally
        {
            _loading = false;
            _needsContainerRefresh = true;
        }
    }

    private async Task OnItemDroppedAsync(MudItemDropInfo<BoardItem> dropInfo)
    {
        var item = dropInfo.Item;
        var newStatus = dropInfo.DropzoneIdentifier;

        if (item is null) return;

        var statusChanged = !string.Equals(item.Status, newStatus, StringComparison.Ordinal);
        var previousStatus = item.Status;
        var previousSequence = item.Sequence;

        // Optimistic update — move the card immediately
        item.Status = newStatus;

        // Update sequence numbers for all items in the target column
        var targetColumnItems = _boardItems
            .Where(i => i.Status == newStatus)
            .ToList();

        // Determine the new index from MudBlazor drop info
        var newIndex = dropInfo.IndexInZone;
        if (newIndex < 0 || newIndex > targetColumnItems.Count)
            newIndex = targetColumnItems.Count;

        // Remove item from its current position in the target list (if it's already there)
        targetColumnItems.Remove(item);
        // Insert at the new position
        if (newIndex > targetColumnItems.Count)
            newIndex = targetColumnItems.Count;
        targetColumnItems.Insert(newIndex, item);

        // Reassign sequence numbers for the target column
        for (var i = 0; i < targetColumnItems.Count; i++)
        {
            targetColumnItems[i].Sequence = i;
        }

        // If the item moved out of a column, also renumber the source column
        if (statusChanged)
        {
            var sourceColumnItems = _boardItems
                .Where(i => i.Status == previousStatus)
                .OrderBy(i => i.Sequence)
                .ToList();
            for (var i = 0; i < sourceColumnItems.Count; i++)
            {
                sourceColumnItems[i].Sequence = i;
            }
        }

        if (_dealershipId is null) return;

        try
        {
            // Persist the updated sequence for the dropped item
            var detail = await SrClient.GetByIdAsync(_dealershipId, item.Summary.Id);

            var updateRequest = new ServiceRequestUpdateRequestDto
            {
                Status = newStatus,
                IssueDescription = detail.IssueDescription,
                Priority = detail.Priority ?? "Medium",
                IssueCategory = detail.IssueCategory,
                TechnicianSummary = detail.TechnicianSummary,
                Urgency = detail.Urgency,
                RvUsage = detail.RvUsage,
                HasExtendedWarranty = detail.HasExtendedWarranty,
                ApproxPurchaseDate = detail.ApproxPurchaseDate,
                AssignedTechnicianId = detail.AssignedTechnicianId,
                AssignedBayId = detail.AssignedBayId,
                ScheduledDateUtc = detail.ScheduledDateUtc,
                RequiredSkills = detail.RequiredSkills,
                BoardSequence = item.Sequence,
                UpdatedAtUtc = detail.UpdatedAtUtc,
            };

            await SrClient.UpdateAsync(_dealershipId, item.Summary.Id, updateRequest);

            // Persist reordered siblings in the target column (fire-and-forget style, but awaited)
            foreach (var sibling in targetColumnItems.Where(i => i.Summary.Id != item.Summary.Id))
            {
                var siblingDetail = await SrClient.GetByIdAsync(_dealershipId, sibling.Summary.Id);
                var siblingUpdate = new ServiceRequestUpdateRequestDto
                {
                    Status = sibling.Status,
                    IssueDescription = siblingDetail.IssueDescription,
                    Priority = siblingDetail.Priority ?? "Medium",
                    IssueCategory = siblingDetail.IssueCategory,
                    TechnicianSummary = siblingDetail.TechnicianSummary,
                    Urgency = siblingDetail.Urgency,
                    RvUsage = siblingDetail.RvUsage,
                    HasExtendedWarranty = siblingDetail.HasExtendedWarranty,
                    ApproxPurchaseDate = siblingDetail.ApproxPurchaseDate,
                    AssignedTechnicianId = siblingDetail.AssignedTechnicianId,
                    AssignedBayId = siblingDetail.AssignedBayId,
                    ScheduledDateUtc = siblingDetail.ScheduledDateUtc,
                    RequiredSkills = siblingDetail.RequiredSkills,
                    BoardSequence = sibling.Sequence,
                    UpdatedAtUtc = siblingDetail.UpdatedAtUtc,
                };
                await SrClient.UpdateAsync(_dealershipId, sibling.Summary.Id, siblingUpdate);
            }

            var columnTitle = _columns.FirstOrDefault(c => c.Status == newStatus)?.Title ?? newStatus;
            Snackbar.Add(statusChanged ? $"Moved to {columnTitle}." : "Card reordered.", Severity.Success);
        }
        catch (Exception ex)
        {
            // Revert on failure
            item.Status = previousStatus;
            item.Sequence = previousSequence;
            _dropContainer?.Refresh();

            var message = ex.Message.Contains("status transition", StringComparison.OrdinalIgnoreCase)
                ? ex.Message
                : "Unable to update card position.";
            Snackbar.Add(message, Severity.Error);
        }
    }

    private async Task RefreshBoardAsync()
    {
        await LoadBoardDataAsync();
    }

    private async Task HandleLocationChangedAsync(string? location)
    {
        if (location is null) return;

        await LoadBoardDataAsync();
        await InvokeAsync(StateHasChanged);

        // Start polling on first location selection
        if (_pollTimer is null)
        {
            StartPolling();
        }
    }

    private void NavigateToDetail(string srId)
    {
        Navigation.NavigateTo($"/service-requests/{srId}");
    }

    private void StartPolling()
    {
        _pollCts = new CancellationTokenSource();
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(DefaultPollIntervalSeconds));
        _ = PollLoopAsync(_pollTimer, _pollCts.Token);
    }

    private async Task PollLoopAsync(PeriodicTimer timer, CancellationToken ct)
    {
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                await LoadBoardDataAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Polling cancelled — expected on dispose.
        }
        catch (Exception)
        {
            // Swallow to prevent unobserved task exceptions; errors surface via _error in LoadBoardDataAsync.
        }
    }

    private static string FormatAge(DateTime createdAtUtc)
    {
        var age = DateTime.UtcNow - createdAtUtc;

        if (age.TotalMinutes < 60)
            return $"{(int)age.TotalMinutes}m ago";
        if (age.TotalHours < 24)
            return $"{(int)age.TotalHours}h ago";
        if (age.TotalDays < 30)
            return $"{(int)age.TotalDays}d ago";

        return $"{(int)(age.TotalDays / 30)}mo ago";
    }

    public void Dispose()
    {
        AppState.OnLocationChanged -= HandleLocationChangedAsync;
        _pollCts?.Cancel();
        _pollCts?.Dispose();
        _pollTimer?.Dispose();
    }

    /// <summary>
    /// Mutable wrapper around <see cref="ServiceRequestSummaryResponseDto"/> for drag-and-drop.
    /// MudDropContainer requires a mutable zone identifier property.
    /// </summary>
    private sealed class BoardItem(ServiceRequestSummaryResponseDto summary)
    {
        public ServiceRequestSummaryResponseDto Summary { get; } = summary;
        public string Status { get; set; } = summary.Status;
        public int Sequence { get; set; } = summary.BoardSequence;
    }

    private sealed record BoardColumn(string Title, string Status, string Icon, Color Color);
}
