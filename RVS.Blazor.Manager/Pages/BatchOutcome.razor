@page "/service-requests/batch-outcome"
@inject ServiceRequestApiClient SrClient
@inject LookupApiClient LookupClient
@inject ISnackbar Snackbar

<PageTitle>RVS Manager — Batch Outcome</PageTitle>

<MudStack Spacing="4" Class="pa-2">
    <MudText Typo="Typo.h4">Batch Outcome</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary">
        Search for service requests, select up to 25, and apply a shared repair outcome.
    </MudText>

    @* Search for SRs to select *@
    <MudPaper Elevation="1" Class="pa-4">
        <MudStack Spacing="1">
            <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Search</MudText>
            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">
                Search by customer name, asset ID, category, or technician.
            </MudText>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudTextField T="string" @bind-Value="_keyword"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              Placeholder="Start typing to find service requests"
                              Style="flex: 1;" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SearchAsync"
                           Disabled="_searching"
                           Style="text-transform: none;">
                    Search
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_searching)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_searchError is not null)
    {
        <MudAlert Severity="Severity.Error">@_searchError</MudAlert>
    }

    @* Selection table *@
    @if (_searchResults.Count > 0)
    {
        <MudTable Items="@_searchResults" MultiSelection="true" @bind-SelectedItems="_selectedItems"
                  Hover="true" Dense="true" T="ServiceRequestSummaryResponseDto">
            <HeaderContent>
                <MudTh>ID</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Customer</MudTh>
                <MudTh>Category</MudTh>
                <MudTh>Created</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="ID">@context.Id[..Math.Min(8, context.Id.Length)]…</MudTd>
                <MudTd DataLabel="Status"><StatusBadge Status="@context.Status" /></MudTd>
                <MudTd DataLabel="Customer">@context.CustomerFullName</MudTd>
                <MudTd DataLabel="Category">@context.IssueCategory</MudTd>
                <MudTd DataLabel="Created">@context.CreatedAtUtc.ToLocalTime().ToString("g")</MudTd>
            </RowTemplate>
        </MudTable>

        @if (_selectedItems.Count > 25)
        {
            <MudAlert Severity="Severity.Warning">Maximum of 25 service requests can be selected at once.</MudAlert>
        }

        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @_selectedItems.Count of @_searchResults.Count selected (max 25)
        </MudText>
    }

    @* Outcome Form *@
    @if (_selectedItems.Count > 0 && _selectedItems.Count <= 25)
    {
        <MudPaper Elevation="2" Class="pa-6 rounded-lg">
            <MudStack Spacing="4">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h5" Style="color: var(--mud-palette-text-primary);">Repair outcome</MudText>
                    <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">
                        This outcome will be applied to every selected service request.
                    </MudText>
                </MudStack>

                <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Failure mode</MudText>
                        <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">What went wrong (e.g. "Water pump failure")</MudText>
                        <MudTextField T="string" @bind-Value="_outcome.FailureMode"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Placeholder="Describe the failure"
                                      autocomplete="off" />
                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Repair action</MudText>
                        <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">What was done to fix it</MudText>
                        <MudTextField T="string" @bind-Value="_outcome.RepairAction"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Placeholder="Describe the repair"
                                      autocomplete="off" />
                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Parts used</MudText>
                        <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Separate multiple parts with commas</MudText>
                        <MudTextField T="string" @bind-Value="_partsInput"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Placeholder="e.g., Water pump, O-ring, hose clamp"
                                      autocomplete="off" />
                    </MudStack>
                </MudPaper>

                <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Labor hours</MudText>
                        <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Total hours applied to each SR</MudText>
                        <MudNumericField T="decimal?" @bind-Value="_outcome.LaborHours"
                                         Min="0"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         Placeholder="0.0"
                                         InputMode="@(InputMode.@decimal)" />
                    </MudStack>
                </MudPaper>

                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CheckCircle"
                               OnClick="ApplyOutcomeAsync" Disabled="_applying"
                               Style="text-transform: none;">
                        @if (_applying)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Apply outcome to @_selectedItems.Count SRs
                    </MudButton>
                </MudStack>
            </MudStack>
        </MudPaper>
    }

    @* Results *@
    @if (_batchResult is not null)
    {
        <MudPaper Elevation="1" Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-2">Batch Results</MudText>
            @if (_batchResult.Succeeded.Count > 0)
            {
                <MudAlert Severity="Severity.Success" Class="mb-2">
                    @_batchResult.Succeeded.Count service request(s) updated successfully.
                </MudAlert>
            }
            @if (_batchResult.Failed.Count > 0)
            {
                <MudAlert Severity="Severity.Error" Class="mb-2">
                    @_batchResult.Failed.Count service request(s) failed:
                </MudAlert>
                <MudList T="string" Dense="true">
                    @foreach (var fail in _batchResult.Failed)
                    {
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Error" IconColor="Color.Error">
                            @fail.ServiceRequestId: @fail.Reason
                        </MudListItem>
                    }
                </MudList>
            }
        </MudPaper>
    }
</MudStack>

@code {
    private string? _keyword;
    private string? _dealershipId;
    private bool _searching;
    private bool _applying;
    private string? _searchError;
    private List<ServiceRequestSummaryResponseDto> _searchResults = [];
    private HashSet<ServiceRequestSummaryResponseDto> _selectedItems = [];
    private OutcomeModel _outcome = new();
    private string? _partsInput;
    private BatchOutcomeResponseDto? _batchResult;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var dealerships = await LookupClient.GetDealershipsAsync();
            _dealershipId = dealerships.FirstOrDefault()?.Id;
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
    }

    private async Task SearchAsync()
    {
        if (_dealershipId is null) return;

        _searching = true;
        _searchError = null;
        _batchResult = null;
        StateHasChanged();

        try
        {
            var request = new ServiceRequestSearchRequestDto
            {
                Keyword = _keyword,
                PageSize = 50
            };

            var response = await SrClient.SearchAsync(_dealershipId, request);
            _searchResults = response.Results.Items;
            _selectedItems = [];
        }
        catch (Exception ex)
        {
            _searchError = ex.Message;
        }
        finally
        {
            _searching = false;
        }
    }

    private async Task ApplyOutcomeAsync()
    {
        if (_dealershipId is null || _selectedItems.Count == 0) return;

        _applying = true;
        StateHasChanged();

        try
        {
            var parts = string.IsNullOrWhiteSpace(_partsInput)
                ? null
                : _partsInput.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

            var request = new BatchOutcomeRequestDto
            {
                ServiceRequestIds = _selectedItems.Select(s => s.Id).ToList(),
                FailureMode = _outcome.FailureMode,
                RepairAction = _outcome.RepairAction,
                PartsUsed = parts,
                LaborHours = _outcome.LaborHours
            };

            _batchResult = await SrClient.BatchOutcomeAsync(_dealershipId, request);
            Snackbar.Add($"Batch outcome applied: {_batchResult.Succeeded.Count} succeeded, {_batchResult.Failed.Count} failed.",
                _batchResult.Failed.Count == 0 ? Severity.Success : Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Batch outcome failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _applying = false;
        }
    }

    private sealed class OutcomeModel
    {
        public string? FailureMode { get; set; }
        public string? RepairAction { get; set; }
        public decimal? LaborHours { get; set; }
    }
}
