@inherits LayoutComponentBase
@implements IDisposable
@inject RVS.Blazor.Manager.State.ManagerAppState AppState
@inject ThemeService ThemeService

<MudThemeProvider Theme="ThemeService.CurrentTheme" IsDarkMode="ThemeService.IsDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingAuthenticationState>
    <AuthorizeView>
        <Authorized>
            @{ _isAuthorized = true; }
        </Authorized>
        <NotAuthorized>
            @{ _isAuthorized = false; }
        </NotAuthorized>
    </AuthorizeView>
</CascadingAuthenticationState>

<MudLayout Style="@GetLayoutStyle()">
    <MudAppBar Elevation="2"
               Color="Color.Primary">
        @if (_isAuthorized)
        {
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           Edge="Edge.Start"
                           aria-label="Toggle navigation menu"
                           OnClick="ToggleDrawer" />
        }
        <MudIconButton Icon="@Icons.Material.Filled.RvHookup"
                       Color="Color.Inherit"
                       Href="/"
                       aria-label="RVS Manager home" />
        <MudText Typo="Typo.h6" Class="ml-2" Style="@($"color: {(ThemeService.Mode == ThemeMode.HighContrast ? "black" : "white")};")">
            RVS Manager
        </MudText>
        <MudSpacer />
        @if (_isAuthorized)
        {
            <LoginDisplay />
        }
        <MudIconButton Icon="@GetThemeIcon()"
                       Color="Color.Inherit"
                       aria-label="@GetThemeAriaLabel()"
                       OnClick="CycleThemeAsync" />
    </MudAppBar>

    @if (_isAuthorized)
    {
        <MudDrawer @bind-Open="_drawerOpen" Elevation="1" ClipMode="DrawerClipMode.Always"
                   Style="@(ThemeService.IsDarkMode ? "color: white;" : "")">
            <NavMenu />
        </MudDrawer>
    }

    <MudMainContent Style="@GetMainContentStyle()">
        @if (_isAuthorized)
        {
            <ErrorBoundary>
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <MudAlert Severity="Severity.Error" Class="ma-4">@ex.Message</MudAlert>
                </ErrorContent>
            </ErrorBoundary>
        }
        else
        {
            <ErrorBoundary>
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <MudAlert Severity="Severity.Error" Class="ma-4">@ex.Message</MudAlert>
                </ErrorContent>
            </ErrorBoundary>
        }
    </MudMainContent>

</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isAuthorized;

    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AppState.InitializeAsync();
            await ThemeService.InitializeAsync();
        }
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= StateHasChanged;
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private Task CycleThemeAsync()
    {
        var next = ThemeService.Mode switch
        {
            ThemeMode.Light => ThemeMode.Dark,
            ThemeMode.Dark => ThemeMode.HighContrast,
            _ => ThemeMode.Light
        };
        return ThemeService.SetModeAsync(next);
    }

    private string GetThemeIcon() => ThemeService.Mode switch
    {
        ThemeMode.Light => Icons.Material.Filled.LightMode,
        ThemeMode.Dark => Icons.Material.Filled.DarkMode,
        ThemeMode.HighContrast => Icons.Material.Filled.Contrast,
        _ => Icons.Material.Filled.LightMode
    };

    private string GetThemeAriaLabel() => ThemeService.Mode switch
    {
        ThemeMode.Light => "Switch to dark theme",
        ThemeMode.Dark => "Switch to high contrast theme",
        ThemeMode.HighContrast => "Switch to light theme",
        _ => "Switch theme"
    };

    private string GetMainContentStyle()
    {
        return _isAuthorized
            ? string.Empty
            : "min-height: calc(100vh - var(--mud-appbar-height));";
    }

    private string GetLayoutStyle()
    {
        return _isAuthorized
            ? string.Empty
            : "background: url('images/tetons-desktop.jpg') center 40%/cover no-repeat fixed; min-height: 100vh;";
    }
}
