@inject NavigationManager Navigation
@inject ThemeService ThemeService

<AuthorizeView Context="authState">
    <Authorized>
        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            <ActivatorContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2"
                           Style="cursor: pointer;" @onclick="context.ToggleAsync">
                    <MudText Typo="Typo.body2" Color="Color.Inherit">
                        @GetFirstName(authState)
                    </MudText>
                    <MudAvatar Color="Color.Secondary" Size="Size.Small"
                               aria-label="@GetDisplayName(authState)">
                        @GetUserInitials(authState)
                    </MudAvatar>
                </MudStack>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem Disabled="true">
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.subtitle2">@GetDisplayName(authState)</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@GetUserEmail(authState)</MudText>
                    </MudStack>
                </MudMenuItem>
                <MudDivider />
                <div class="px-4 py-2">
                    <MudStack Spacing="1">
                        <MudText Color="Color.Secondary" Style="font-size: 0.7rem;">Theme</MudText>
                        <MudRadioGroup T="ThemeMode" Value="ThemeService.Mode" ValueChanged="OnThemeModeChangedAsync" Style="font-size: 0.75rem;">
                            <MudRadio T="ThemeMode" Value="ThemeMode.Light" Dense="true" Size="Size.Small" Color="Color.Primary" Style="font-size: 0.75rem;">Light</MudRadio>
                            <MudRadio T="ThemeMode" Value="ThemeMode.Dark" Dense="true" Size="Size.Small" Color="Color.Primary" Style="font-size: 0.75rem;">Dark</MudRadio>
                            <MudRadio T="ThemeMode" Value="ThemeMode.HighContrast" Dense="true" Size="Size.Small" Color="Color.Primary" Style="font-size: 0.75rem;">High Contrast</MudRadio>
                        </MudRadioGroup>
                    </MudStack>
                </div>
                <MudDivider />
                <div class="px-4 py-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               FullWidth="true"
                               OnClick="BeginLogout">
                        Log Out
                    </MudButton>
                </div>
            </ChildContent>
        </MudMenu>
    </Authorized>
    <NotAuthorized>
        <MudButton Variant="Variant.Text" Color="Color.Inherit"
                   OnClick="BeginLogin">
            Log in
        </MudButton>
    </NotAuthorized>
</AuthorizeView>

@code {
    private void BeginLogin()
    {
        Navigation.NavigateToLogin("authentication/login");
    }

    private void BeginLogout()
    {
        Navigation.NavigateToLogout("authentication/logout");
    }

    private async Task OnThemeModeChangedAsync(ThemeMode mode)
    {
        await ThemeService.SetModeAsync(mode);
    }

    private static string GetFirstName(AuthenticationState authState)
    {
        var givenName = authState.User.FindFirst("given_name")?.Value;
        if (!string.IsNullOrWhiteSpace(givenName))
        {
            return givenName;
        }

        var fullName = GetDisplayName(authState);
        var nameParts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return nameParts.Length > 0 ? nameParts[0] : "User";
    }

    private static string GetDisplayName(AuthenticationState authState)
    {
        return authState.User.Identity?.Name
            ?? authState.User.FindFirst("email")?.Value
            ?? authState.User.FindFirst("preferred_username")?.Value
            ?? "User";
    }

    private static string GetUserInitials(AuthenticationState authState)
    {
        var fullName = GetDisplayName(authState);
        var nameParts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (nameParts.Length >= 2)
        {
            return $"{nameParts[0][0]}{nameParts[^1][0]}".ToUpper();
        }

        if (nameParts.Length == 1 && nameParts[0].Length > 0)
        {
            return nameParts[0][..Math.Min(2, nameParts[0].Length)].ToUpper();
        }

        return "U";
    }

    private static string GetUserEmail(AuthenticationState authState)
    {
        return authState.User.FindFirst("email")?.Value
            ?? authState.User.FindFirst("preferred_username")?.Value
            ?? authState.User.FindFirst("upn")?.Value
            ?? string.Empty;
    }
}
