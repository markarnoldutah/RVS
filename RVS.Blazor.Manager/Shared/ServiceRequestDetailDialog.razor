        if (_dealershipId is null || _sr is null) return;

        try
        {
            var sas = await AttachmentClient.GetReadSasAsync(_dealershipId, _sr.Id, attachment.AttachmentId);
            Navigation.NavigateTo(sas.SasUrl, forceLoad: true);
