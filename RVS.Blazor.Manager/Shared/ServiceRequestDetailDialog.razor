        catch (Exception ex)
        {
            _statusError = $"Failed to open attachment: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task CloseDialog()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(false);
    }

    private async Task OnDrawerOpenChanged(bool open)
    {
        if (open == Visible) return;
        Visible = open;
        await VisibleChanged.InvokeAsync(open);
    }

    private static string FormatStatus(string status) => status switch
    {
        "InProgress"        => "In Progress",
        "WaitingOnCustomer" => "Waiting on Customer",
        "WaitingOnParts"    => "Waiting on Parts",
        "Completed"         => "Complete",
        _                   => status
    };

    private static string ShortId(string id) =>
        string.IsNullOrEmpty(id) || id.Length <= 8 ? id : id[^8..];

    private static string ResolveDisplayName(System.Security.Claims.ClaimsPrincipal user)
    {
        var name = user.Identity?.Name;
        if (!string.IsNullOrWhiteSpace(name)) return name;
        return user.FindFirst("name")?.Value
            ?? user.FindFirst("email")?.Value
            ?? user.FindFirst("preferred_username")?.Value
            ?? "User";
    }

    private static string ResolveInitials(string displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName)) return "?";
        var parts = displayName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        if (parts.Length == 1)
            return parts[0].Length >= 2
                ? parts[0].Substring(0, 2).ToUpperInvariant()
                : parts[0][0].ToString().ToUpperInvariant();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }

    @* Parses a title of form "FirstName LastName, Year Manufacturer, Model" back into parts.
       Tolerant of missing pieces; year detected only when the leading token is a 4-digit number 1950–2100. *@
    private static (string FirstName, string LastName, int? Year, string? Manufacturer, string? Model) ParseTitle(string title)
    {
        var parts = (title ?? string.Empty).Split(',', 3, StringSplitOptions.TrimEntries);

        var firstName = string.Empty;
        var lastName = string.Empty;
        if (parts.Length > 0 && !string.IsNullOrWhiteSpace(parts[0]))
        {
            var nameTokens = parts[0].Split(' ', 2, StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries);
            firstName = nameTokens.Length > 0 ? nameTokens[0] : string.Empty;
            lastName  = nameTokens.Length > 1 ? nameTokens[1] : string.Empty;
        }

        int? year = null;
        string? manufacturer = null;
        if (parts.Length > 1 && !string.IsNullOrWhiteSpace(parts[1]))
        {
            var seg = parts[1].Trim();
            var spaceIdx = seg.IndexOf(' ');
            if (spaceIdx > 0
                && int.TryParse(seg[..spaceIdx], out var y) && y is >= 1950 and <= 2100)
            {
                year = y;
                var rest = seg[(spaceIdx + 1)..].Trim();
                manufacturer = string.IsNullOrWhiteSpace(rest) ? null : rest;
            }
            else if (int.TryParse(seg, out var yOnly) && yOnly is >= 1950 and <= 2100)
            {
                year = yOnly;
            }
            else
            {
                manufacturer = seg;
            }
        }

        string? model = null;
        if (parts.Length > 2 && !string.IsNullOrWhiteSpace(parts[2]))
        {
            model = parts[2].Trim();
        }

        return (firstName, lastName, year, manufacturer, model);
    }

    private static string FormatTitleLine(ServiceRequestDetailResponseDto sr)
    {
        var name = $"{sr.Customer.FirstName} {sr.Customer.LastName}".Trim();
        var asset = AssetYearMakeModel(sr);
        return string.IsNullOrWhiteSpace(asset) ? name : $"{name}, {asset}";
    }

    private static string AssetYearMakeModel(ServiceRequestDetailResponseDto sr)
    {
        var makeModel = new List<string>();
        if (!string.IsNullOrEmpty(sr.Asset.Manufacturer)) makeModel.Add(sr.Asset.Manufacturer);
        if (!string.IsNullOrEmpty(sr.Asset.Model)) makeModel.Add(sr.Asset.Model);
        var makeModelStr = string.Join(", ", makeModel);
        if (sr.Asset.Year.HasValue && makeModelStr.Length > 0)
            return $"{sr.Asset.Year.Value} {makeModelStr}";
        if (sr.Asset.Year.HasValue)
            return sr.Asset.Year.Value.ToString();
        return makeModelStr;
    }

    private static string GetAttachmentIcon(string contentType)
    {
        if (contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
            return Icons.Material.Filled.Image;
        if (contentType.Contains("pdf", StringComparison.OrdinalIgnoreCase))
            return Icons.Material.Filled.PictureAsPdf;
        return Icons.Material.Filled.InsertDriveFile;
    }

    private static string FormatFileSize(long bytes) => bytes switch
    {
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:F1} KB",
        _ => $"{bytes / (1024.0 * 1024.0):F1} MB"
    };

    @* Stub data for the customer comms timeline — full email/SMS history wiring is a separate story. *@
    private static IReadOnlyList<CommsEvent> BuildCommsStub(ServiceRequestDetailResponseDto sr)
    {
        var created = sr.CreatedAtUtc;
        return
        [
            new CommsEvent(
                "Intake confirmation sent",
                $"Email to {sr.Customer.Email}: \"We've received your service request — we'll be in touch.\"",
                created.AddMinutes(2),
                Icons.Material.Filled.Email,
                Color.Info),
            new CommsEvent(
                "SMS reply received",
                "Customer: \"Thanks — when can I drop it off?\"",
                created.AddHours(4),
                Icons.Material.Filled.Sms,
                Color.Success),
            new CommsEvent(
                "Status update sent",
                "Email: Diagnosis complete, estimate attached.",
                sr.UpdatedAtUtc ?? created.AddDays(1),
                Icons.Material.Filled.Email,
                Color.Info),
        ];
    }

    private sealed record CommsEvent(
        string Title,
        string Preview,
        DateTime TimestampUtc,
        string Icon,
        Color Color);

