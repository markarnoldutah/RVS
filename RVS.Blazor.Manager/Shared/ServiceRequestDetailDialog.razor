@inject ServiceRequestApiClient SrClient
@inject LookupApiClient LookupClient
@inject AttachmentApiClient AttachmentClient
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject ThemeService ThemeService
@inject AuthenticationStateProvider AuthProvider
@implements IDisposable

<MudDrawer Open="Visible" OpenChanged="OnDrawerOpenChanged"
           Anchor="Anchor.End"
           Variant="@DrawerVariant.Temporary"
           Fixed="true"
           Elevation="0"
           Width="min(1000px, 100vw)"
           Overlay="true"
           Style="@($"border-left: 1px solid {DrawerBorderColor};")">
    <div class="d-flex flex-column" style="@($"height: 100vh; background: {ColumnBackground};")">
        @* Sticky title header — full width *@
        <MudPaper Elevation="0" Square="true" Class="px-4 py-3"
                  Style="@HeaderFooterStyle">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="width: 100%;">
                @if (_mode == DialogMode.Create)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary" />
                    <MudText Typo="Typo.h5" Style="font-weight: 600;">New Service Request</MudText>
                }
                else if (_sr is not null)
                {
                    <MudStack Spacing="1" Style="min-width: 0; flex-grow: 1;">
                        <MudText Typo="Typo.h5" Style="font-weight: 600;">
                            @FormatTitleLine(_sr)
                        </MudText>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <StatusBadge Status="@_sr.Status" />
                            @if (!string.IsNullOrEmpty(_sr.Priority))
                            {
                                <PriorityBadge Priority="@_sr.Priority" />
                            }
                        </MudStack>
                    </MudStack>
                }
                else
                {
                    <MudText Typo="Typo.h5" Style="font-weight: 600;">Service Request</MudText>
                }
                <MudSpacer />
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Class="section-icon-btn"
                               aria-label="Close"
                               OnClick="CloseDialog" />
            </MudStack>
        </MudPaper>

        @* Scrollable body *@
        <div class="flex-grow-1 px-4 py-4" style="overflow-y: auto;">
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="ma-2">@_error</MudAlert>
        }
        else if (_mode == DialogMode.Create)
        {
            @* Create form — single column, unchanged *@
            <MudForm @ref="_createFormRef">
                <MudStack Spacing="4">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.h6" Style="color: var(--mud-palette-text-primary);">Customer</MudText>
                        <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">
                            Who is this service request for?
                        </MudText>
                    </MudStack>

                    <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">First name</MudText>
                            <MudTextField T="string" @bind-Value="_createForm.FirstName"
                                          Validation="@(new Func<string?, string?>(ValidateFirstName))"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          autocomplete="given-name" />
                        </MudStack>
                    </MudPaper>

                    <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Last name</MudText>
                            <MudTextField T="string" @bind-Value="_createForm.LastName"
                                          Validation="@(new Func<string?, string?>(ValidateLastName))"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          autocomplete="family-name" />
                        </MudStack>
                    </MudPaper>

                    <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Email</MudText>
                            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Service updates are sent here</MudText>
                            <MudTextField T="string" @bind-Value="_createForm.Email"
                                          Validation="@(new Func<string?, string?>(ValidateEmail))"
                                          InputType="InputType.Email"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Placeholder="name@example.com"
                                          autocomplete="email" />
                        </MudStack>
                    </MudPaper>

                    <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Phone</MudText>
                            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Optional — for SMS status updates</MudText>
                            <MudTextField T="string" @bind-Value="_createForm.Phone"
                                          InputType="InputType.Telephone"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Placeholder="(555) 123-4567"
                                          autocomplete="tel" />
                        </MudStack>
                    </MudPaper>

                    <MudStack Spacing="1" Class="mt-2">
                        <MudText Typo="Typo.h6" Style="color: var(--mud-palette-text-primary);">Asset / Vehicle</MudText>
                    </MudStack>

                    <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">VIN / Asset ID</MudText>
                            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">17-character VIN or dealer asset tag</MudText>
                            <MudTextField T="string" @bind-Value="_createForm.AssetId"
                                          Validation="@(new Func<string?, string?>(ValidateAssetId))"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Placeholder="e.g., 1HGCM82633A123456"
                                          autocomplete="off" />
                        </MudStack>
                    </MudPaper>

                    <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Manufacturer</MudText>
                            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Optional</MudText>
                            <MudTextField T="string" @bind-Value="_createForm.Manufacturer"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Placeholder="e.g., Winnebago, Thor, Jayco"
                                          autocomplete="off" />
                        </MudStack>
                    </MudPaper>

                    <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Model</MudText>
                            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Optional</MudText>
                            <MudTextField T="string" @bind-Value="_createForm.Model"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Placeholder="e.g., Vista, Aria, Eagle"
                                          autocomplete="off" />
                        </MudStack>
                    </MudPaper>

                    <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Year</MudText>
                            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Optional</MudText>
                            <MudNumericField T="int?" @bind-Value="_createForm.Year"
                                             Min="1950" Max="2100"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             InputMode="InputMode.numeric"
                                             Placeholder="e.g., 2023" />
                        </MudStack>
                    </MudPaper>

                    <MudStack Spacing="1" Class="mt-2">
                        <MudText Typo="Typo.h6" Style="color: var(--mud-palette-text-primary);">Issue</MudText>
                    </MudStack>

                    <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Issue category</MudText>
                            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">e.g. Electrical, Plumbing, Slide-out</MudText>
                            <MudTextField T="string" @bind-Value="_createForm.IssueCategory"
                                          Validation="@(new Func<string?, string?>(ValidateIssueCategory))"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Placeholder="Enter a category"
                                          autocomplete="off" />
                        </MudStack>
                    </MudPaper>

                    <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Priority</MudText>
                            <MudSelect T="string" @bind-Value="_createForm.Priority"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       AnchorOrigin="Origin.BottomCenter"
                                       TransformOrigin="Origin.TopCenter">
                                <MudSelectItem T="string" Value="@("Critical")">Critical</MudSelectItem>
                                <MudSelectItem T="string" Value="@("High")">High</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Medium")">Medium</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Low")">Low</MudSelectItem>
                            </MudSelect>
                        </MudStack>
                    </MudPaper>

                    <MudPaper Elevation="1" Class="pa-4" Style="background: var(--mud-palette-background);">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body1" Style="font-weight: 700; color: var(--mud-palette-text-primary);">Description</MudText>
                            <MudText Typo="Typo.body1" Style="color: var(--mud-palette-text-secondary);">Symptoms, when they started, and anything already tried</MudText>
                            <MudTextField T="string" @bind-Value="_createForm.IssueDescription"
                                          Validation="@(new Func<string?, string?>(ValidateIssueDescription))"
                                          Lines="4"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Placeholder="Describe the issue in detail" />
                        </MudStack>
                    </MudPaper>
                </MudStack>
            </MudForm>
        }
        else if (_sr is not null)
        {
            @* Detail view — 70/30 two-column layout, GitHub-issue style *@
            <MudGrid Spacing="6">
                @* Left column — 70% — issue body *@
                <MudItem xs="12" md="8">
                    <MudStack Spacing="0">
                        @* Issue Details *@
                        <MudText Typo="Typo.body2" Style="font-weight: 700;" Class="mb-2">Issue Details</MudText>
                        <MudStack Spacing="3">
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Info">Description</MudText>
                                <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@_sr.IssueDescription</MudText>
                            </div>
                            <MudGrid Spacing="2">
                                <MudItem xs="6" sm="3">
                                    <MudText Typo="Typo.caption" Color="Color.Info">Category</MudText>
                                    <MudText Typo="Typo.body2">@_sr.IssueCategory</MudText>
                                </MudItem>
                                <MudItem xs="6" sm="3">
                                    <MudText Typo="Typo.caption" Color="Color.Info">Urgency</MudText>
                                    <MudText Typo="Typo.body2">@(_sr.Urgency ?? "—")</MudText>
                                </MudItem>
                                <MudItem xs="6" sm="3">
                                    <MudText Typo="Typo.caption" Color="Color.Info">RV Usage</MudText>
                                    <MudText Typo="Typo.body2">@(_sr.RvUsage ?? "—")</MudText>
                                </MudItem>
                                <MudItem xs="6" sm="3">
                                    <MudText Typo="Typo.caption" Color="Color.Info">Scheduled</MudText>
                                    <MudText Typo="Typo.body2">@(_sr.ScheduledDateUtc?.ToLocalTime().ToString("g") ?? "—")</MudText>
                                </MudItem>
                            </MudGrid>
                        </MudStack>

                        @if (_sr.Attachments.Count > 0)
                        {
                            <MudDivider Class="my-5" />
                            <MudText Typo="Typo.body2" Style="font-weight: 700;" Class="mb-2">
                                Attachments (@_sr.Attachments.Count)
                            </MudText>
                            <MudGrid Spacing="2">
                                @foreach (var att in _sr.Attachments)
                                {
                                    <MudItem xs="6" sm="4" md="3">
                                        <div class="text-center">
                                            <MudIcon Icon="@GetAttachmentIcon(att.ContentType)"
                                                     Size="Size.Large" Color="Color.Info" />
                                            <MudText Typo="Typo.caption" Class="d-block text-truncate">
                                                @att.FileName
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Info">
                                                @FormatFileSize(att.SizeBytes)
                                            </MudText>
                                            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                                                       OnClick="@(() => ViewAttachmentAsync(att))">
                                                View
                                            </MudButton>
                                        </div>
                                    </MudItem>
                                }
                            </MudGrid>
                        }

                        <MudDivider Class="my-5" />

                        @* Advisor Notes *@
                        <MudText Typo="Typo.body2" Style="font-weight: 700;" Class="mb-2">Advisor Notes</MudText>
                        @if (!string.IsNullOrWhiteSpace(_sr.TechnicianSummary))
                        {
                            <MudText Typo="Typo.body2" Style="white-space: pre-wrap;" Class="mb-3">
                                @_sr.TechnicianSummary
                            </MudText>
                        }

                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                            <MudAvatar Color="Color.Secondary"
                                       Style="width: 26px; height: 26px; font-size: 0.7rem; font-weight: 700;">
                                @_userInitials
                            </MudAvatar>
                            <MudText Typo="Typo.body2">Add a comment</MudText>
                        </MudStack>
                        <MudTextField T="string" @bind-Value="_commentText"
                                      Lines="3"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Placeholder="Type a comment…"
                                      FullWidth="true"
                                      Disabled="_commentSaving" />
                        @if (_commentError is not null)
                        {
                            <MudAlert Severity="Severity.Error" Dense="true" Class="mt-2">@_commentError</MudAlert>
                        }
                        <MudStack Row="true" Justify="Justify.FlexStart" Class="mt-2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       OnClick="AddCommentAsync"
                                       Disabled="@(_commentSaving || string.IsNullOrWhiteSpace(_commentText))">
                                @if (_commentSaving)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                }
                                Comment
                            </MudButton>
                        </MudStack>

                        <MudDivider Class="my-5" />

                        @* Customer Communications — UI stub *@
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                            <MudText Typo="Typo.body2" Style="font-weight: 700;">Customer Communications</MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                                Preview
                            </MudChip>
                        </MudStack>
                        <MudTimeline TimelinePosition="TimelinePosition.Start" TimelineOrientation="TimelineOrientation.Vertical">
                            @foreach (var evt in BuildCommsStub(_sr))
                            {
                                <MudTimelineItem Color="@evt.Color" Size="Size.Small">
                                    <ItemContent>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudIcon Icon="@evt.Icon" Size="Size.Small" Color="@evt.Color" />
                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@evt.Title</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Info">
                                                @evt.TimestampUtc.ToLocalTime().ToString("MMM d, h:mm tt")
                                            </MudText>
                                        </MudStack>
                                        <MudText Typo="Typo.body2" Color="Color.Info">@evt.Preview</MudText>
                                    </ItemContent>
                                </MudTimelineItem>
                            }
                        </MudTimeline>
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-2">
                            Customer communication tracking is a UI stub — full email/SMS history is coming in a later story.
                        </MudAlert>
                    </MudStack>
                </MudItem>

                @* Right column — 30% — sidebar metadata *@
                <MudItem xs="12" md="4">
                    <MudStack Spacing="0">
                        @if (_allowedStatuses.Count > 0)
                        {
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                                <MudText Typo="Typo.body2" Style="font-weight: 700;">Status</MudText>
                                @if (_statusUpdating)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                }
                            </MudStack>
                            <MudSelect T="string" Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       FullWidth="true"
                                       Value="@_selectedStatus"
                                       ValueChanged="OnStatusChangeAsync"
                                       AnchorOrigin="Origin.BottomCenter"
                                       TransformOrigin="Origin.TopCenter"
                                       Placeholder="Change status…">
                                @foreach (var status in _allowedStatuses)
                                {
                                    <MudSelectItem T="string" Value="@status">@FormatStatus(status)</MudSelectItem>
                                }
                            </MudSelect>
                            @if (_statusError is not null)
                            {
                                <MudAlert Severity="Severity.Error" Class="mt-2" Dense="true">@_statusError</MudAlert>
                            }
                            <MudDivider Class="my-4" />
                        }

                        @* Assigned Tech *@
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudText Typo="Typo.body2" Style="font-weight: 700;">Assigned Tech</MudText>
                            <MudSpacer />
                            @if (_techSaving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            }
                            else if (_editingTech)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Save" Size="Size.Small" Color="Color.Primary"
                                               Class="section-icon-btn"
                                               aria-label="Save assigned tech" OnClick="SaveTechAsync" />
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               Class="section-icon-btn"
                                               aria-label="Cancel editing assigned tech" OnClick="CancelEditTech" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Small"
                                               Class="section-icon-btn"
                                               aria-label="Edit assigned tech" OnClick="BeginEditTech" />
                            }
                        </MudStack>
                        @if (_editingTech)
                        {
                            <MudStack Spacing="3">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.body2" Style="@FieldLabelStyle">Technician</MudText>
                                    <MudTextField T="string" @bind-Value="_editTechId"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Placeholder="Unassigned"
                                                  Class="compact-field" />
                                </MudStack>
                                @if (_techError is not null)
                                {
                                    <MudAlert Severity="Severity.Error" Dense="true">@_techError</MudAlert>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.body2" Style="@ValueStyle">@(_sr.AssignedTechnicianId ?? "Unassigned")</MudText>
                                @if (_sr.RequiredSkills.Count > 0)
                                {
                                    <div>
                                        <MudText Typo="Typo.body2" Style="@LabelStyle" Class="mb-1">Required Skills</MudText>
                                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">
                                            @foreach (var skill in _sr.RequiredSkills)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info">@skill</MudChip>
                                            }
                                        </MudStack>
                                    </div>
                                }
                            </MudStack>
                        }

                        <MudDivider Class="my-4" />

                        @* Customer *@
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudText Typo="Typo.body2" Style="font-weight: 700;">Customer</MudText>
                            <MudSpacer />
                            @if (_customerSaving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            }
                            else if (_editingCustomer)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Save" Size="Size.Small" Color="Color.Primary"
                                               Class="section-icon-btn"
                                               aria-label="Save customer" OnClick="SaveCustomerAsync" />
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               Class="section-icon-btn"
                                               aria-label="Cancel editing customer" OnClick="CancelEditCustomer" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Small"
                                               Class="section-icon-btn"
                                               aria-label="Edit customer" OnClick="BeginEditCustomer" />
                            }
                        </MudStack>
                        @if (_editingCustomer)
                        {
                            <MudStack Spacing="3">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.body2" Style="@FieldLabelStyle">First name</MudText>
                                    <MudTextField T="string" @bind-Value="_editCustomerFirstName"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Class="compact-field" />
                                </MudStack>
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.body2" Style="@FieldLabelStyle">Last name</MudText>
                                    <MudTextField T="string" @bind-Value="_editCustomerLastName"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Class="compact-field" />
                                </MudStack>
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.body2" Style="@FieldLabelStyle">Email</MudText>
                                    <MudTextField T="string" @bind-Value="_editCustomerEmail"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  InputType="InputType.Email"
                                                  Class="compact-field" />
                                </MudStack>
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.body2" Style="@FieldLabelStyle">Phone</MudText>
                                    <MudTextField T="string" @bind-Value="_editCustomerPhone"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  InputType="InputType.Telephone"
                                                  Class="compact-field" />
                                </MudStack>
                                @if (_customerError is not null)
                                {
                                    <MudAlert Severity="Severity.Error" Dense="true">@_customerError</MudAlert>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.body2" Style="@ValueStyle">@_sr.Customer.FirstName @_sr.Customer.LastName</MudText>
                                <MudText Typo="Typo.body2" Style="@ValueStyleBreak">@_sr.Customer.Email</MudText>
                                @if (!string.IsNullOrEmpty(_sr.Customer.Phone))
                                {
                                    <MudText Typo="Typo.body2" Style="@ValueStyle">@_sr.Customer.Phone</MudText>
                                }
                            </MudStack>
                        }

                        <MudDivider Class="my-4" />

                        @* Asset *@
                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
                            <MudText Typo="Typo.body2" Style="font-weight: 700;">Asset / Vehicle</MudText>
                            <MudSpacer />
                            @if (_assetSaving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            }
                            else if (_editingAsset)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Save" Size="Size.Small" Color="Color.Primary"
                                               Class="section-icon-btn"
                                               aria-label="Save asset" OnClick="SaveAssetAsync" />
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               Class="section-icon-btn"
                                               aria-label="Cancel editing asset" OnClick="CancelEditAsset" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Settings" Size="Size.Small"
                                               Class="section-icon-btn"
                                               aria-label="Edit asset" OnClick="BeginEditAsset" />
                            }
                        </MudStack>
                        @if (_editingAsset)
                        {
                            <MudStack Spacing="3">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.body2" Style="@FieldLabelStyle">Year</MudText>
                                    <MudNumericField T="int?" @bind-Value="_editAssetYear"
                                                     Min="1950" Max="2100"
                                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Class="compact-field" />
                                </MudStack>
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.body2" Style="@FieldLabelStyle">Manufacturer</MudText>
                                    <MudTextField T="string" @bind-Value="_editAssetManufacturer"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Class="compact-field" />
                                </MudStack>
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.body2" Style="@FieldLabelStyle">Model</MudText>
                                    <MudTextField T="string" @bind-Value="_editAssetModel"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Class="compact-field" />
                                </MudStack>
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.body2" Style="@FieldLabelStyle">VIN / Asset ID</MudText>
                                    <MudTextField T="string" @bind-Value="_editAssetId"
                                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                                  Class="compact-field" />
                                </MudStack>
                                @if (_assetError is not null)
                                {
                                    <MudAlert Severity="Severity.Error" Dense="true">@_assetError</MudAlert>
                                }
                            </MudStack>
                        }
                        else
                        {
                            <MudStack Spacing="1">
                                @if (_sr.Asset.Year.HasValue || !string.IsNullOrEmpty(_sr.Asset.Manufacturer) || !string.IsNullOrEmpty(_sr.Asset.Model))
                                {
                                    <MudText Typo="Typo.body2" Style="@ValueStyle">@AssetYearMakeModel(_sr)</MudText>
                                }
                                <MudText Typo="Typo.body2" Style="@ValueStyleBreak">@_sr.Asset.AssetId</MudText>
                            </MudStack>
                        }

                        <MudDivider Class="my-4" />

                        @* Metadata *@
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.caption" Color="Color.Info">
                                Created @_sr.CreatedAtUtc.ToLocalTime().ToString("g")
                            </MudText>
                            @if (_sr.UpdatedAtUtc.HasValue)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Info">
                                    Updated @_sr.UpdatedAtUtc.Value.ToLocalTime().ToString("g")
                                </MudText>
                            }
                            <MudText Typo="Typo.caption" Color="Color.Info" Style="word-break: break-all;">
                                ID: @_sr.Id
                            </MudText>
                        </MudStack>
                    </MudStack>
                </MudItem>
            </MudGrid>
        }
        </div>

        @* Sticky footer — create mode only *@
        @if (_mode == DialogMode.Create)
        {
            <MudPaper Elevation="0" Square="true" Class="pa-3"
                      Style="@FooterStyle">
                <MudStack Row="true" Spacing="2" Justify="Justify.FlexEnd">
                    <MudButton OnClick="CloseDialog">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               OnClick="CreateAsync" Disabled="_saving">
                        @if (_saving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        }
                        Create
                    </MudButton>
                </MudStack>
            </MudPaper>
        }
    </div>
</MudDrawer>

@code {
    /// <summary>
    /// Controls visibility of the dialog. Bind two-way from parent.
    /// </summary>
    [Parameter]
    public bool Visible { get; set; }

    [Parameter]
    public EventCallback<bool> VisibleChanged { get; set; }

    /// <summary>
    /// Service request ID to display. Null for create mode.
    /// </summary>
    [Parameter]
    public string? ServiceRequestId { get; set; }

    /// <summary>
    /// Current column/status to pre-populate in create mode.
    /// </summary>
    [Parameter]
    public string? CurrentStatus { get; set; }

    /// <summary>
    /// Fired after a service request is created or updated so the parent can refresh.
    /// </summary>
    [Parameter]
    public EventCallback OnChanged { get; set; }

    private enum DialogMode { View, Create }

    private DialogMode _mode;
    private ServiceRequestDetailResponseDto? _sr;
    private bool _loading;
    private string? _error;
    private string? _dealershipId;
    private List<string> _allowedStatuses = [];
    private string? _selectedStatus;
    private bool _statusUpdating;
    private string? _statusError;
    private bool _saving;
    private CreateForm _createForm = new();
    private MudForm? _createFormRef;
    private bool _createSubmitted;
    private string? _previousServiceRequestId;
    private bool _previousVisible;
    private string _userInitials = "?";
    private string _userDisplayName = "User";
    private string? _commentText;
    private bool _commentSaving;
    private string? _commentError;

    private bool _editingCustomer;
    private bool _customerSaving;
    private string? _customerError;
    private string? _editCustomerFirstName;
    private string? _editCustomerLastName;
    private string? _editCustomerEmail;
    private string? _editCustomerPhone;

    private bool _editingAsset;
    private bool _assetSaving;
    private string? _assetError;
    private int? _editAssetYear;
    private string? _editAssetManufacturer;
    private string? _editAssetModel;
    private string? _editAssetId;

    private bool _editingTech;
    private bool _techSaving;
    private string? _techError;
    private string? _editTechId;

    private bool _editingTitle;
    private bool _titleSaving;
    private string? _titleError;
    private string? _editTitleText;

    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += HandleThemeChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _userDisplayName = ResolveDisplayName(user);
            _userInitials = ResolveInitials(_userDisplayName);
        }
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= HandleThemeChanged;
    }

    private void HandleThemeChanged() => InvokeAsync(StateHasChanged);

    private string ColumnBackground => ThemeService.Mode == ThemeMode.Dark
        ? "#181818"
        : "var(--mud-palette-background)";

    private string DrawerBorderColor => ThemeService.Mode switch
    {
        ThemeMode.Dark          => "rgba(255,255,255,0.12)",
        ThemeMode.HighContrast  => "#FFFF00",
        _                       => "rgba(0,0,0,0.12)"
    };

    private string LabelColor => ThemeService.Mode == ThemeMode.HighContrast
        ? "#FFFF00"
        : "#9198A1";

    private string ValueColor => ThemeService.Mode switch
    {
        ThemeMode.Dark => "#FFFFFF",
        ThemeMode.HighContrast => "#FFFF00",
        _ => "var(--mud-palette-text-primary)"
    };

    private string HeaderFooterStyle =>
        $"position: sticky; top: 0; z-index: 2; border-bottom: 1px solid var(--mud-palette-divider); background: {ColumnBackground};";

    private string FooterStyle =>
        $"position: sticky; bottom: 0; z-index: 2; border-top: 1px solid var(--mud-palette-divider); background: {ColumnBackground};";

    private string LabelStyle => $"font-weight: 700; color: {LabelColor};";

    private string FieldLabelStyle => $"font-weight: 700; color: {ValueColor};";

    private string ValueStyle => $"color: {ValueColor};";

    private string ValueStyleBreak => $"color: {ValueColor}; word-break: break-all;";

    private string? ValidateFirstName(string? value) =>
        _createSubmitted && string.IsNullOrWhiteSpace(value) ? "Enter the customer's first name" : null;

    private string? ValidateLastName(string? value) =>
        _createSubmitted && string.IsNullOrWhiteSpace(value) ? "Enter the customer's last name" : null;

    private string? ValidateEmail(string? value)
    {
        if (!_createSubmitted) return null;
        if (string.IsNullOrWhiteSpace(value)) return "Enter an email address";
        return value.Contains('@') && value.Contains('.') ? null : "Enter a valid email address";
    }

    private string? ValidateAssetId(string? value) =>
        _createSubmitted && string.IsNullOrWhiteSpace(value) ? "Enter a VIN or asset ID" : null;

    private string? ValidateIssueCategory(string? value) =>
        _createSubmitted && string.IsNullOrWhiteSpace(value) ? "Enter an issue category" : null;

    private string? ValidateIssueDescription(string? value) =>
        _createSubmitted && string.IsNullOrWhiteSpace(value) ? "Describe the issue" : null;

    protected override async Task OnParametersSetAsync()
    {
        var needsLoad = false;

        if (Visible && !_previousVisible)
        {
            needsLoad = true;
        }
        else if (Visible && ServiceRequestId != _previousServiceRequestId)
        {
            needsLoad = true;
        }

        _previousVisible = Visible;
        _previousServiceRequestId = ServiceRequestId;

        if (!needsLoad) return;

        _error = null;
        _sr = null;
        _statusError = null;
        _selectedStatus = null;

        if (string.IsNullOrEmpty(ServiceRequestId))
        {
            _mode = DialogMode.Create;
            _createForm = new CreateForm();
            _createSubmitted = false;
            return;
        }

        _mode = DialogMode.View;
        _loading = true;

        try
        {
            _dealershipId ??= await ResolveDealershipIdAsync();

            if (_dealershipId is null)
            {
                _error = "No dealership found.";
                return;
            }

            _sr = await SrClient.GetByIdAsync(_dealershipId, ServiceRequestId);
            RefreshAllowedStatuses();
        }
        catch (AccessTokenNotAvailableException ex)
        {
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<string?> ResolveDealershipIdAsync()
    {
        var dealerships = await LookupClient.GetDealershipsAsync();
        return dealerships.FirstOrDefault()?.Id;
    }

    private void RefreshAllowedStatuses()
    {
        if (_sr is null) return;
        _allowedStatuses = ["New", "InProgress", "WaitingOnCustomer", "WaitingOnParts", "Completed", "Cancelled"];
        _selectedStatus = _sr.Status;
    }

    private async Task OnStatusChangeAsync(string newStatus)
    {
        if (_sr is null || _dealershipId is null || string.IsNullOrEmpty(newStatus)) return;

        _statusUpdating = true;
        _statusError = null;
        StateHasChanged();

        try
        {
            var request = new ServiceRequestUpdateRequestDto
            {
                Status = newStatus,
                IssueDescription = _sr.IssueDescription,
                Priority = _sr.Priority ?? "Medium"
            };

            _sr = await SrClient.UpdateAsync(_dealershipId, _sr.Id, request);
            RefreshAllowedStatuses();
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _statusError = ex.Message;
        }
        finally
        {
            _statusUpdating = false;
        }
    }

    private async Task AddCommentAsync()
    {
        if (_sr is null || _dealershipId is null || string.IsNullOrWhiteSpace(_commentText)) return;

        _commentSaving = true;
        _commentError = null;
        StateHasChanged();

        try
        {
            var byline = $"[{_userDisplayName} — {DateTime.Now:MMM d, yyyy h:mm tt}]";
            var newEntry = $"{byline}\n{_commentText.Trim()}";
            var combined = string.IsNullOrWhiteSpace(_sr.TechnicianSummary)
                ? newEntry
                : $"{newEntry}\n\n{_sr.TechnicianSummary}";

            var request = new ServiceRequestUpdateRequestDto
            {
                Status = _sr.Status,
                IssueDescription = _sr.IssueDescription,
                Priority = _sr.Priority ?? "Medium",
                TechnicianSummary = combined
            };

            _sr = await SrClient.UpdateAsync(_dealershipId, _sr.Id, request);
            _commentText = null;
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _commentError = ex.Message;
        }
        finally
        {
            _commentSaving = false;
        }
    }

    private void BeginEditCustomer()
    {
        if (_sr is null) return;
        _editCustomerFirstName = _sr.Customer.FirstName;
        _editCustomerLastName  = _sr.Customer.LastName;
        _editCustomerEmail     = _sr.Customer.Email;
        _editCustomerPhone     = _sr.Customer.Phone;
        _customerError = null;
        _editingCustomer = true;
    }

    private void CancelEditCustomer()
    {
        _editingCustomer = false;
        _customerError = null;
    }

    private async Task SaveCustomerAsync()
    {
        if (_sr is null || _dealershipId is null) return;
        _customerSaving = true;
        _customerError = null;
        StateHasChanged();
        try
        {
            var request = new ServiceRequestUpdateRequestDto
            {
                Status = _sr.Status,
                IssueDescription = _sr.IssueDescription,
                Priority = _sr.Priority ?? "Medium",
                Customer = new CustomerInfoDto
                {
                    FirstName = _editCustomerFirstName ?? string.Empty,
                    LastName  = _editCustomerLastName  ?? string.Empty,
                    Email     = _editCustomerEmail     ?? string.Empty,
                    Phone     = _editCustomerPhone
                }
            };
            _sr = await SrClient.UpdateAsync(_dealershipId, _sr.Id, request);
            _editingCustomer = false;
            await OnChanged.InvokeAsync();
        }
        catch (Exception ex) { _customerError = ex.Message; }
        finally { _customerSaving = false; }
