    private async Task CreateAsync()
    {
        _createSubmitted = true;
        if (_createFormRef is not null)
        {
            await _createFormRef.ValidateAsync();
            if (!_createFormRef.IsValid)
            {
                Snackbar.Add("Fix the highlighted fields and try again.", Severity.Warning);
                return;
            }
        }

        _saving = true;
        StateHasChanged();

        try
        {
            _dealershipId ??= await ResolveDealershipIdAsync();

            if (_dealershipId is null)
            {
                Snackbar.Add("No dealership found.", Severity.Error);
                return;
            }

            var request = new ServiceRequestCreateRequestDto
            {
                Customer = new CustomerInfoDto
                {
                    FirstName = _createForm.FirstName!,
                    LastName = _createForm.LastName!,
                    Email = _createForm.Email!,
                    Phone = _createForm.Phone
                },
                Asset = new AssetInfoDto
                {
                    AssetId = _createForm.AssetId!,
                    Manufacturer = _createForm.Manufacturer,
                    Model = _createForm.Model,
                    Year = _createForm.Year
                },
                IssueCategory = _createForm.IssueCategory!,
                IssueDescription = _createForm.IssueDescription!
            };

            await SrClient.CreateAsync(_dealershipId, request);
            Snackbar.Add("Service request created.", Severity.Success);
            await OnChanged.InvokeAsync();
            await CloseDialog();
        }
        catch (Exception ex)
        {
