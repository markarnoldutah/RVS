@using System.Security.Claims

<AuthorizeView>
    <Authorized>
        @if (_locations.Count > 1)
        {
            <FluentCard Style="padding: 16px;">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Location())" Color="Color.Accent" />
                    <FluentSelect TOption="string"
                                  Label="Select Location"
                                  Items="@_locations"
                                  @bind-SelectedOption="@SelectedLocation"
                                  Style="min-width: 250px;" />
                </FluentStack>
            </FluentCard>
        }
        else if (_locations.Count == 1)
        {
            <FluentCard Style="padding: 16px;">
                <FluentStack Orientation="Orientation.Horizontal" VerticalAlignment="VerticalAlignment.Center" HorizontalGap="12">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Location())" Color="Color.Accent" />
                    <span>Location: <strong>@_locations[0]</strong></span>
                </FluentStack>
            </FluentCard>
        }
    </Authorized>
</AuthorizeView>

@code {
    private List<string> _locations = [];

    [Parameter]
    public string? SelectedLocation { get; set; }

    [Parameter]
    public EventCallback<string?> SelectedLocationChanged { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask is null) return;

        var authState = await AuthStateTask;
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true) return;

        // Extract location IDs from claims (Auth0 custom claim)
        var locationClaims = user.FindAll("app_metadata/locationIds");
        foreach (var claim in locationClaims)
        {
            if (!string.IsNullOrWhiteSpace(claim.Value))
            {
                _locations.Add(claim.Value);
            }
        }

        // Auto-select if only one location
        if (_locations.Count == 1 && SelectedLocation is null)
        {
            SelectedLocation = _locations[0];
            await SelectedLocationChanged.InvokeAsync(SelectedLocation);
        }
    }
}
