@inject RVS.UI.Shared.Services.LookupApiClient LookupClient
@inject RVS.Blazor.Manager.State.ManagerAppState AppState

<AuthorizeView>
    <Authorized>
        @if (_locations.Count > 1)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Primary"
                         aria-hidden="true" />
                <MudSelect T="string" Label="Location"
                           Value="AppState.SelectedLocation"
                           ValueChanged="OnLocationSelectedAsync"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           TransformOrigin="Origin.TopCenter"
                           RelativeWidth="DropdownWidth.Adaptive"
                           aria-label="Select your location"
                           Style="max-width: 280px; width: auto;"
                           Dense="true">
                    @foreach (var location in _locations)
                    {
                        <MudSelectItem T="string" Value="@location.LocationId">@location.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudStack>
        }
        else if (_locations.Count == 1)
        {
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Primary"
                         aria-hidden="true" />
                <MudText Typo="Typo.body1">
                    Location: <strong>@_locations[0].Name</strong>
                </MudText>
            </MudStack>
        }
    </Authorized>
</AuthorizeView>

@code {
    private List<LocationSummaryResponseDto> _locations = [];

    protected override async Task OnInitializedAsync()
    {
        _locations = await LookupClient.GetLocationsAsync();

        // Auto-select single location, or validate persisted selection still exists
        if (_locations.Count == 1 && AppState.SelectedLocation is null)
        {
            await AppState.SetLocationAsync(_locations[0].LocationId);
        }
        else if (AppState.SelectedLocation is not null &&
                 !_locations.Any(l => l.LocationId == AppState.SelectedLocation))
        {
            // Persisted location no longer valid — clear it
            await AppState.SetLocationAsync(null);
        }
    }

    private async Task OnLocationSelectedAsync(string? value)
    {
        await AppState.SetLocationAsync(value);
    }
}
